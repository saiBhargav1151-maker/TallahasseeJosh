<div class="row">
    <div class="col-lg-3">
        <div class="radio">
            <label>
                <input type="radio" name="optionsRadios1" id="optionsRadios11" value="option1" checked>
                View Current Items Only
            </label>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="radio">
            <label>
                <input type="radio" name="optionsRadios1" id="optionsRadios12" value="option2">
                View Current and Obsolete Items
            </label>
        </div>
    </div>
</div>
<div class="row">
    <div class="col-lg-12">
        <accordion>
            <accordion-group heading="{{payItemStructureGroup.heading}}" ng-repeat="payItemStructureGroup in payItemStructureGroups" is-open="payItemStructureGroup.isOpen" >
                <strong>
                    <a href="" ng-click="showContent(payItemStructureGroup)">{{payItemStructureGroup.showList ? 'Add New Structure' : 'Show List'}}</a>    
                </strong>
                <br/>
                <br/>
                <admin-pay-item-structure ng-show="!payItemStructureGroup.showList" pay-item-structure="newPayItemStructure" prefix="payItemStructureGroup.prefix"></admin-pay-item-structure>
                <div class="row" ng-show="payItemStructureGroup.showList">
                    <div class="col-lg-3">
                        <strong>Pay Item Structure ID</strong>
                    </div>
                    <div class="col-lg-9">
                        <strong>Title</strong>
                    </div>
                    <hr />
                </div>
                <admin-pay-item-structure ng-show="payItemStructureGroup.showList" ng-repeat="payItemStructure in payItemStructureGroup.payItemStructures | orderBy:payItemStructure.structureId" pay-item-structure="payItemStructure" prefix="payItemStructureGroup.prefix"></admin-pay-item-structure>
            </accordion-group>
        </accordion>
    </div>
</div>