<!DOCTYPE html>
<html lang="en">
    <head>
        <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
        <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1" />
        <meta name="keywords" content="" />
        <meta name="author" content="Alltech Consulting &copy;2013" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>@ViewBag.Title</title>
        <link href="~/Content/bootstrap.min.css" rel="stylesheet" media="screen">
        <link href="~/Content/bootstrap-theme.min.css" rel="stylesheet" media="screen">
        <link href="~/Content/site.css" rel="stylesheet" media="screen">
    </head>
    <body class="container">
        <div id="statusMessage" class="alert alert-success">
            <button type="button" class="close" data-dismiss="alert">&times;</button>
            <span class="glyphicon glyphicon-info-sign"></span>&nbsp;<strong>Notification:</strong>&nbsp;<span id="statusMessageText"></span>
        </div>
        @Html.Action("Navigation", "Site", new { Area = ""})
        <br/>
        <div class="well well-sm">
            <h4>@ViewBag.Title</h4>    
        </div>
        @RenderBody()  
        <script type="text/javascript" src="~/Scripts/jquery-2.1.1.js"></script>
        <script type="text/javascript" src="~/Scripts/bootstrap.min.js"></script>
        <script type="text/javascript" src="~/Scripts/jquery.signalR-2.0.3.min.js"></script>
        <script type="text/javascript" src="~/Scripts/Custom/app.js"></script>
        <script type="text/javascript">
            $(function () {
                InitializeConnection('@Url.Content(@"~/dispatch")');
            });
        </script>
        @RenderSection("ScriptSection", false)
    </body>
</html>