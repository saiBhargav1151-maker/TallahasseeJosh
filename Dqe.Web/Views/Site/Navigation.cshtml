<div class="navbar navbar-default navbar-fixed-top" role="navigation">
    <div class="navbar-header">
        <button type="button" class="navbar-toggle" data-toggle="collapse" data-target=".navbar-collapse-user-menu">
            <span class="sr-only">Toggle navigation</span>
            <span class="icon-bar"></span>
            <span class="icon-bar"></span>
            <span class="icon-bar"></span>
        </button>
        <a class="navbar-brand" href="~/">Dqe</a>
    </div>
    <div class="collapse navbar-collapse navbar-collapse-user-menu">
        <ul class="nav navbar-nav">
            <li class="active">
                <a href="~/">Home</a>
            </li>
        </ul>
        <ul class="nav navbar-nav navbar-right">
            <li class="dropdown">
                @if (User.Identity.IsAuthenticated)
                {
                    <a class="dropdown-toggle" data-toggle="dropdown" href="#">
                        <span class="glyphicon glyphicon-log-out"></span>&nbsp;@User.Identity.Name<b class="caret"></b>
                    </a>
                    <ul class="dropdown-menu">
                        <li>@Html.ActionLink("Sign Out", "SignOut", "User", new {Area = "Account"}, null)</li>
                        <li>@Html.ActionLink("User Profile", "UserProfile", "User", new {Area = "Account"}, null)</li>
                        <li>@Html.ActionLink("Change Password", "ChangePassword", "User", new {Area = "Account"}, null)</li>
                        <li>@Html.ActionLink("Change Account Name", "ChangeAccountName", "User", new {Area = "Account"}, null)</li>
                    </ul>
                }
                else
                {
                    <a class="dropdown-toggle" data-toggle="dropdown" href="#">
                        <span class="glyphicon glyphicon-log-in"></span>&nbsp;Account<b class="caret"></b>
                    </a>
                    <ul class="dropdown-menu">
                        <li>@Html.ActionLink("Sign In", "Authenticate", "User", new {Area = "Account"}, null)</li>
                        <li>@Html.ActionLink("Need an account?", "Register", "User", new { Area = "Account" }, null)</li>
                        <li>@Html.ActionLink("Can't access your account?", "Reset", "User", new { Area = "Account" }, null)</li>          
                    </ul>
                } 
            </li>
        </ul>
    </div>
</div>