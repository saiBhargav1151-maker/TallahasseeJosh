	  <add key="LogPostsToMessageBus" value="false" />
	  <add key="SendPostEmailsToAddresses" value="" />
	  <add key="SendUsageEmailsToAddresses" value="" />
	  <add key="ApplicationAcronym" value="DQE" />
	  <add key="Microsoft.ServiceBus.ConnectionString" value="Endpoint=sb://alltech.servicebus.windows.net/;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=AYBn0V2xdLa2QPNZgOF8AQzd5Vh2ccNuAVEHFcTD93I=" />
	  <add key="ClientSideExceptionLoggingEnabled" value="true" />
	  <add key="SendClientSideExceptionEmails" value="true" />
	  <add key="AddClientSideExceptionsToMessageBus" value="true" />
	  <add key="SendClientSideExceptionEmailsToAddresses" value="" />
	  <add key="EnvironmentLevelToken" value="L" />
