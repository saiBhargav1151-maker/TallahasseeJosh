@using Dqe.Web.Areas.Account.Models
@model ChangePasswordViewModel
@{ ViewBag.Title = "Change Password"; }
@using (Html.BeginForm("ChangePassword", "User", new { Area = "Account" }, FormMethod.Post, new{ role="form" }))
{
    <div>@Html.LabelFor(i => i.CurrentPassword)</div>
    <div class="row form-group">
        <div class="col-lg-4">@Html.PasswordFor(i => i.CurrentPassword, new{@class="form-control"})</div>
        <div class="col-lg-8 text-danger">@Html.ValidationMessageFor(i => i.CurrentPassword)</div>
    </div>
    <div>@Html.LabelFor(i => i.NewPassword)</div>
    <div class="row form-group">
        <div class="col-lg-4">@Html.PasswordFor(i => i.NewPassword, new{@class="form-control"})</div>
        <div class="col-lg-8 text-danger">@Html.ValidationMessageFor(i => i.NewPassword)</div>
    </div>
    <div>@Html.LabelFor(i => i.ConfirmPassword)</div>
    <div class="row form-group">
        <div class="col-lg-4">@Html.PasswordFor(i => i.ConfirmPassword, new{@class="form-control"})</div>
        <div class="col-lg-8 text-danger">@Html.ValidationMessageFor(i => i.ConfirmPassword)</div>
    </div>
    <div><button type="submit" class="btn btn-primary">Submit</button></div> 
}    