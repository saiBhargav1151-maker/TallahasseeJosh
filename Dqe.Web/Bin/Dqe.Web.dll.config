  </runtime>
  <system.webServer>
      <handlers>
        <remove name="ExtensionlessUrlHandler-Integrated-4.0" />
        <remove name="OPTIONSVerbHandler" />
        <remove name="TRACEVerbHandler" />
        <add name="ExtensionlessUrlHandler-Integrated-4.0" path="*." verb="*" type="System.Web.Handlers.TransferRequestHandler" preCondition="integratedMode,runtimeVersionv4.0" />
        <add name="Glimpse" path="glimpse.axd" verb="GET" type="Glimpse.AspNet.HttpHandler, Glimpse.AspNet" preCondition="integratedMode" />
      </handlers>
    <validation validateIntegratedModeConfiguration="false" />
    <modules>
      <add name="Glimpse" type="Glimpse.AspNet.HttpModule, Glimpse.AspNet" preCondition="integratedMode" />
    </modules>
  </system.webServer>
  <system.serviceModel>
    <behaviors>
      <endpointBehaviors>
        <behavior name="securitybehavior">
          <clientCredentials>
            <serviceCertificate>
              <authentication certificateValidationMode="None" revocationMode="NoCheck" />
            </serviceCertificate>
          </clientCredentials>
        </behavior>
      </endpointBehaviors>
    </behaviors>
    <bindings>
      <wsHttpBinding>
        <binding name="WSHttpBinding_IEstimatorService" maxBufferPoolSize="504003200" maxReceivedMessageSize="504003200">
          <readerQuotas maxArrayLength="504003200" maxStringContentLength="504003200" maxBytesPerRead="504003200" maxNameTableCharCount="504003200" />
          <security>
            <message clientCredentialType="UserName" />
          </security>
        </binding>
      </wsHttpBinding>
    </bindings>
    <client>
      <endpoint address="http://dotscowtrnsu02.co.dot.state.fl.us:7000/ApiHost/estimator.svc" binding="wsHttpBinding" bindingConfiguration="WSHttpBinding_IEstimatorService" contract="WtEstimatorService.IEstimatorService" name="WSHttpBinding_IEstimatorService" behaviorConfiguration="securitybehavior">
        <identity>
          <certificate encodedValue="" />
        </identity>
      </endpoint>
    </client>
  </system.serviceModel>
  <glimpse defaultRuntimePolicy="On" endpointBaseUri="~/Glimpse.axd" />
