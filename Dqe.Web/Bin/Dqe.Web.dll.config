    <add key="OisLinkUrl" value="http://infonet.dot.state.fl.us/officeofinformationsystems" />
    <add key="OisImageUrl" value="http://www3.dot.state.fl.us/images/OISLogosm.jpg" />
    <add key="nhibernate-logger" value="NHibernate.Glimpse.LoggerFactory, NHibernate.Glimpse" />
    <add key="NHibernate.Glimpse.Loggers" value="command" />
    <add key="fdot.testbanner.disable" value="true" />
    <add key="executeDdl" value="false" />
    <add key="exportDdl" value="false" />
    <add key="exportDdlFile" value="c:\temp\DQE-DDL.sql" />
    <add key="vpn" value="true" />
    <add key="loadWtPayItems" value="false" />
    <add key="aspnet:MaxJsonDeserializerMembers" value="150000" />
    <add key="owin:AutomaticAppStartup" value="true" />
	<add key="reportServerUrl" value="http://kevin-laptop/ReportServer_SQLEXPRESS?"/>
	<add key="reportServerUrlDot" value="http://dcs-dot-db07.dot.dcs.sdc.state.fl.us/Reportserver_SSRSDEV?"/>
    <add key="muhimbiServiceUrl" value="http://localhost:41734/Muhimbi.DocumentConverter.WebService/" />
    <!--<add key="muhimbiServiceUrl" value="http://AlltechPdf.cloudapp.net:41734/Muhimbi.DocumentConverter.WebService/"/>-->
  </appSettings>
  <system.web>
    <compilation debug="true" targetFramework="4.5" />
    <httpRuntime targetFramework="4.5" />
  <!-- Glimpse: This can be commented in to add additional data to the Trace tab when using WebForms
        <trace writeToDiagnosticsTrace="true" enabled="true" pageOutput="false"/> -->
    <httpModules>
      <add name="Glimpse" type="Glimpse.AspNet.HttpModule, Glimpse.AspNet" />
    </httpModules>
    <httpHandlers>
      <add path="glimpse.axd" verb="GET" type="Glimpse.AspNet.HttpHandler, Glimpse.AspNet" />
    </httpHandlers>
    <customErrors mode="Off" />
  </system.web>
  <system.web.extensions>
    <scripting>
      <webServices>
        <jsonSerialization maxJsonLength="2147483644" />
      </webServices>
    </scripting>
  </system.web.extensions>
