  <DataSources>
    <DataSource Name="DQE">
      <DataSourceReference>DQE</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>cf015987-3516-4cd5-b2c4-fa4333ce9ce5</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="ProjectSummary">
      <Query>
        <DataSourceName>DQE</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ReportProposalId">
            <Value>=Parameters!ReportProposalId.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ProjectNumber">
            <Value>=Parameters!ProjectNumber.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT        rps.RPT_PROJ_SUM_SQ AS Id, rps.ALT_DS AS AlternateDescription, rps.CAT_ALT_SET_TXT AS CategoryAlternateSet, rps.CAT_ALT_MBR_TXT AS CategoryAlternateMember, 
                         rps.ITM_ALT_SET_TXT AS ItemAlternateSet, rps.ITM_ALT_MBR_TXT AS ItemAlternateMember, rps.LOW_CST_CD AS IsLowCost, rps.TOT_AMT AS Total, rps.RPT_PROJ_SQ AS ReportProjectId
FROM            DQET033_RPT_PROJ AS rp INNER JOIN
                         DQET035_RPT_PRJ_SM AS rps ON rp.RPT_PROJ_SQ = rps.RPT_PROJ_SQ
WHERE        (rp.RPT_PRPOS_SQ = @ReportProposalId) AND (rp.PROJ_NM = @ProjectNumber)</CommandText>
      </Query>
      <Fields>
        <Field Name="Id">
          <DataField>Id</DataField>
          <rd:TypeName>System.Int64</rd:TypeName>
        </Field>
        <Field Name="AlternateDescription">
          <DataField>AlternateDescription</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CategoryAlternateSet">
          <DataField>CategoryAlternateSet</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CategoryAlternateMember">
          <DataField>CategoryAlternateMember</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ItemAlternateSet">
          <DataField>ItemAlternateSet</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ItemAlternateMember">
          <DataField>ItemAlternateMember</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="IsLowCost">
          <DataField>IsLowCost</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Total">
          <DataField>Total</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="ReportProjectId">
          <DataField>ReportProjectId</DataField>
          <rd:TypeName>System.Int64</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Categories">
      <Query>
        <DataSourceName>DQE</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ReportProposalId">
            <Value>=Parameters!ReportProposalId.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ProjectNumber">
            <Value>=Parameters!ProjectNumber.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT        rc.CAT_DS
FROM            DQET033_RPT_PROJ AS rp INNER JOIN
                         DQET030_RPT_CAT AS rc ON rp.RPT_PROJ_SQ = rc.RPT_PROJ_SQ
WHERE        (rp.RPT_PRPOS_SQ = @ReportProposalId) AND (rp.PROJ_NM = @ProjectNumber)
ORDER BY rc.CAT_DS</CommandText>
      </Query>
      <Fields>
        <Field Name="CAT_DS">
          <DataField>CAT_DS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ProjectDetailHeader">
      <Query>
        <DataSourceName>DQE</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ReportProposalId">
            <Value>=Parameters!ReportProposalId.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ProjectNumber">
            <Value>=Parameters!ProjectNumber.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT        rp.PROJ_DS AS ProjectDescription, rp.LET_DT AS LettingDate, rp.TOT_AMT AS ProjectTotal, rc.CAT_DS AS CategoryDescription, rc.ALT_DS AS CategoryAlternateDescription, rp.PROJ_NM AS ProjectNumber, 
                         rp.WRK_TYP_TXT AS WorkType, rp.FED_PROJ_TXT AS FederalAid, rp.CNTY_TXT AS County, rp.DIST_TXT AS District
FROM            DQET033_RPT_PROJ AS rp INNER JOIN
                         DQET030_RPT_CAT AS rc ON rp.RPT_PROJ_SQ = rc.RPT_PROJ_SQ
WHERE        (rp.RPT_PRPOS_SQ = @ReportProposalId) AND (rp.PROJ_NM = @ProjectNumber)</CommandText>
      </Query>
      <Fields>
        <Field Name="ProjectDescription">
          <DataField>ProjectDescription</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="LettingDate">
          <DataField>LettingDate</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="ProjectTotal">
          <DataField>ProjectTotal</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="CategoryDescription">
          <DataField>CategoryDescription</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CategoryAlternateDescription">
          <DataField>CategoryAlternateDescription</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ProjectNumber">
          <DataField>ProjectNumber</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="WorkType">
          <DataField>WorkType</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="FederalAid">
          <DataField>FederalAid</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="County">
          <DataField>County</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="District">
          <DataField>District</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
