<hibernate-mapping xmlns="urn:nhibernate-mapping-2.2" assembly="Dqe.Domain" namespace="Dqe.Domain.Model">
  <class name="CostGroupPayItem" table="CostGroupPayItem">
    <id name="Id">
      <generator class="identity" />
    </id>
    <many-to-one name="MyCostGroup" column="CostGroupId" class="CostGroup" not-null="true"/>
    <many-to-one name="MyPayItem" column="PayItemMasterId" class="PayItemMaster" not-null="true"/>
    <property name="ConversionFactor" not-null="true"/>
  </class>
</hibernate-mapping>