<?xml version="1.0" encoding="utf-8" ?>
<!-- MAKE SURE THIS FILE IS AN EMBEDDED RESOURCE -->
<hibernate-mapping xmlns="urn:nhibernate-mapping-2.2" assembly="Dqe.Domain" namespace="Dqe.Domain.Model">
  <class name="ProposalHistory" table="DQET011_PRPOS_HST">
    <id name="Id" column="PRPOS_HST_SQ">
      <generator class="sequence">
        <param name="sequence">DQEQ011_PRPOS_HST</param>
      </generator>
    </id>
    <many-to-one name="MyPayItemMaster" column="PAY_ITM_SQ" not-null="true"/>
    <property name="ProposalNumber" type="AnsiString">
      <column name="PRPOS_NM" sql-type="varchar(20)" not-null="true"/>
    </property>
    <property name="LettingDate">
      <column name="LET_DT" sql-type="datetime2" not-null="true"/>
    </property>
    <property name="County" type="AnsiString">
      <column name="CNTY_NM" sql-type="varchar(100)" not-null="true"/>
    </property>
    <property name="Quantity">
      <column name="QTY_NUM" sql-type="decimal(14, 2)" not-null="true"/>
    </property>
    <property name="Duration">
      <column name="DUR_NUM" not-null="true"/>
    </property>
    <property name="ProposalType" type="AnsiString">
      <column name="PRPOS_TYP_TXT" sql-type="varchar(20)" not-null="true"/>
    </property>
    <property name="ContractType" type="AnsiString">
      <column name="CNTRT_TYP_TXT" sql-type="varchar(20)" not-null="true"/>
    </property>
    <property name="ContractWorkType" type="AnsiString">
      <column name="CNTRT_WRK_TYP_TXT" sql-type="varchar(20)" not-null="true"/>
    </property>
    <set name="BidHistories" lazy="true" inverse="true" cascade="all-delete-orphan" access="field.camelcase-underscore">
      <key column="PRPOS_HST_SQ"/>
      <one-to-many class="BidHistory"/>
    </set>
  </class>
</hibernate-mapping>