<?xml version="1.0" encoding="utf-8" ?>
<!-- MAKE SURE THIS FILE IS AN EMBEDDED RESOURCE -->
<hibernate-mapping xmlns="urn:nhibernate-mapping-2.2" assembly="Dqe.Domain" namespace="Dqe.Domain.Model">
  <class name="ProposalHistory" table="ProposalHistory10">
    <id name="Id">
      <generator class="identity" />
    </id>
    <many-to-one name="MyProjectItem" column="ProjectItemId" not-null="true"/>
    <property name="ProposalNumber" not-null="true" length="20" />
    <property name="LettingDate" not-null="true"/>
    <property name="AwardedDate" not-null="false"/>
    <property name="ExecutedDate" not-null="false"/>
    <set name="BidHistories" lazy="true" inverse="true" cascade="all-delete-orphan" access="field.camelcase-underscore">
      <key column="ProposalHistoryId"/>
      <one-to-many class="BidHistory"/>
    </set>
  </class>
</hibernate-mapping>