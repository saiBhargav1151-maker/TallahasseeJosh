<?xml version="1.0" encoding="utf-8" ?>
<!-- MAKE SURE THIS FILE IS AN EMBEDDED RESOURCE -->
<hibernate-mapping xmlns="urn:nhibernate-mapping-2.2" assembly="Dqe.Domain" namespace="Dqe.Domain.Model">
  <class name="MasterFile" table="MasterFile7">
    <id name="Id">
      <generator class="identity" />
    </id>
    <natural-id>
      <property name="FileNumber" not-null="true" />  
    </natural-id>
    <set name="PayItems" lazy="true" inverse="true" cascade="all-delete-orphan" access="field.camelcase-underscore" >
      <key column="MasterFileId"/>
      <one-to-many class="PayItem"/>
    </set>
    <set name="Projects" lazy="true" inverse="true" cascade="all-delete-orphan" access="field.camelcase-underscore" >
      <key column="MasterFileId"/>
      <one-to-many class="Project"/>
    </set>
  </class>
</hibernate-mapping>