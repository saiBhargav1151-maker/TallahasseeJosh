<?xml version="1.0" encoding="utf-8" ?>
<!-- MAKE SURE THIS FILE IS AN EMBEDDED RESOURCE -->
<hibernate-mapping xmlns="urn:nhibernate-mapping-2.2" assembly="Dqe.Domain" namespace="Dqe.Domain.Model">
  <class name="MasterFile" table="DQET019_MSTR_FILE">
    <id name="Id" column="MSTR_FILE_SQ">
      <generator class="sequence">
        <param name="sequence">DQEQ019_MSTR_FILE</param>
      </generator>
    </id>
    <natural-id>
      <property name="FileNumber">
        <column name="FILE_NUM" not-null="true"/>
      </property>  
    </natural-id>
    <property name="DoMasterFileCopy" type="Dqe.Infrastructure.Types.BoolType, Dqe.Infrastructure">
      <column name="MSTR_FILE_CPY_CD" sql-type="char(1)" not-null="true"/>
    </property>
    <property name="EffectiveDate">
      <column name="MSTR_FILE_EFFCT_DT" sql-type="datetime2" not-null="false"/>
    </property>
    <set name="PayItemMasters" lazy="true" inverse="true" cascade="all-delete-orphan" access="field.camelcase-underscore" >
      <key column="MSTR_FILE_SQ"/>
      <one-to-many class="PayItemMaster"/>
    </set>
    <set name="Projects" lazy="true" inverse="true" cascade="all-delete-orphan" access="field.camelcase-underscore" >
      <key column="MSTR_FILE_SQ"/>
      <one-to-many class="Project"/>
    </set>
  </class>
</hibernate-mapping>