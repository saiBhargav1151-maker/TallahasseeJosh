<?xml version="1.0" encoding="utf-8"?>
<hibernate-mapping schema="transport" assembly="Dqe.Domain" namespace="Dqe.Domain.Model.Wt" xmlns="urn:nhibernate-mapping-2.2">
  <class name="District" table="DISTRICT" schema="trnsport" mutable="false">
    <id name="Id" type="Int64">
      <column name="DISTRICT_ID" not-null="true" sql-type="bigint" />
      <generator class="identity" />
    </id>
    <many-to-one name="MyProject" column="PROJECT_ID" class="Project" not-null="false"/>
    <many-to-one name="MyRefDistrict" column="REFDISTRICT_ID" class="RefDistrict" not-null="false"/>
    <property name="PrimaryDistrict">
      <column name="PRIMARY_DISTRICT" not-null="true" sql-type="bit" />
    </property>
  </class>
</hibernate-mapping>