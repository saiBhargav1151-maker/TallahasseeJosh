<?xml version="1.0" encoding="utf-8"?>
<hibernate-mapping schema="transport" assembly="Dqe.Domain" namespace="Dqe.Domain.Model.Wt" xmlns="urn:nhibernate-mapping-2.2">
  <class name="County" table="COUNTY" schema="trnsport" mutable="false">
    <id name="Id" type="Int64">
      <column name="COUNTY_ID" not-null="true" sql-type="bigint" />
      <generator class="identity" />
    </id>
    <many-to-one name="MyProject" column="PROJECT_ID" class="Project" not-null="false"/>
    <many-to-one name="MyRefCounty" column="REFCOUNTY_ID" class="RefCounty" not-null="false"/>
    <property name="Percentage">
      <column name="PERCENTAGE" not-null="true" precision="7" scale="4" sql-type="numeric" />
    </property>
    <property name="PrimaryCounty">
      <column name="PRIMARY_COUNTY" not-null="true" sql-type="bit" />
    </property>
  </class>
</hibernate-mapping>