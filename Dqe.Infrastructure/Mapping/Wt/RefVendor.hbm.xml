<?xml version="1.0" encoding="utf-8"?>
<hibernate-mapping schema="transport" assembly="Dqe.Domain" namespace="Dqe.Domain.Model.Wt" xmlns="urn:nhibernate-mapping-2.2">
	<class name="RefVendor" table="REFVENDOR" schema="trnsport" mutable="false">
		<id name="Id" type="Int64">
			<column name="REFVENDOR_ID" not-null="true" sql-type="bigint" />
			<generator class="identity" />
		</id>
		<property name="VendorName" type="String">
			<column name="VENDORNAME" not-null="true" length="100" sql-type="varchar" />
		</property>
		<property name="VendorType" type="String">
			<column name="VENDORTYPE" not-null="false" length="10" sql-type="varchar" />
		</property>
		<property name="CertificationType" type="String">
			<column name="CERTIFICATIONTYPE" not-null="false" length="10" sql-type="varchar" />
		</property>
		<set name="ProposalVendors" inverse="true" cascade="none" lazy="true" access="field.camelcase-underscore">
			<key>
				<column name="REFVENDOR_ID"/>
			</key>
			<one-to-many class="ProposalVendor"/>
		</set>
	</class>
</hibernate-mapping>