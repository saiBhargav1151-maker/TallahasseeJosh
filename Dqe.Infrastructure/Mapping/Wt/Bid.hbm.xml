<?xml version="1.0" encoding="utf-8"?>
<hibernate-mapping schema="transport" assembly="Dqe.Domain" namespace="Dqe.Domain.Model.Wt" xmlns="urn:nhibernate-mapping-2.2">
  <class name="Bid" table="BID" schema="trnsport" mutable="false">
    <id name="Id" type="Int64">
      <column name="BID_ID" not-null="true" sql-type="bigint" />
      <generator class="identity" />
    </id>
    <many-to-one name="MyProposalVendor" column="PROPOSALVENDOR_ID" class="ProposalVendor" not-null="false"/>
    <many-to-one name="MyProposalItem" column="PROPOSALITEM_ID" class="ProposalItem" not-null="false"/>
    <property name="ValidBid">
      <column name="VALIDBID" not-null="true" sql-type="bit" />
    </property>
    <property name="BidPrice">
      <column name="BIDPRICE" not-null="true" precision="16" scale="5" sql-type="numeric" />
    </property>
    <property name="LowCost">
      <column name="LOWCOSTFLAG" not-null="true" sql-type="bit" />
    </property>
  </class>
</hibernate-mapping>