<?xml version="1.0" encoding="utf-8"?>
<hibernate-mapping schema="transport" assembly="Dqe.Domain" namespace="Dqe.Domain.Model.Wt" xmlns="urn:nhibernate-mapping-2.2">
	<class name="Letting" table="LETTING" schema="trnsport" mutable="false">
		<id name="Id" type="Int64">
			<column name="LETTING_ID" not-null="true" sql-type="bigint" />
			<generator class="identity" />
		</id>
		<property name="LettingDate" >
			<column name="LETTING_DT" not-null="true" sql-type="datetime2" />
		</property>
    <property name="LettingStatus" >
      <column name="LETTINGSTATUS" not-null="true" sql-type="string" />
    </property>
		<property name="LettingName" >
			<column name="LETTING_NM" not-null="true" sql-type="string" />
		</property>
		<set name="Proposals" lazy="true" inverse="true" cascade="none" access="field.camelcase-underscore">
			<key column="LETTING_ID"/>
			<one-to-many class="Proposal"/>
		</set>
	</class>
</hibernate-mapping>