<?xml version="1.0" encoding="utf-8"?>
<hibernate-mapping schema="transport" assembly="Dqe.Domain" namespace="Dqe.Domain.Model.Wt" xmlns="urn:nhibernate-mapping-2.2">
  <class name="Alternate" table="ALTERNATESET" schema="trnsport" mutable="false">
    <id name="Id" type="Int64">
      <column name="ALTERNATESET_ID" not-null="true" sql-type="bigint" />
      <generator class="identity" />
    </id>
    <property name="Name" type="String">
      <column name="ALTERNATESET_NM" not-null="true" length="20" sql-type="varchar" />
    </property>
    <property name="Description" type="String">
      <column name="DESCR" not-null="true" length="256" sql-type="varchar" />
    </property>
    <set name="ProjectItems" inverse="true" cascade="none" lazy="true" access="field.camelcase-underscore">
      <key>
        <column name="ALTERNATESET_ID"/>
      </key>
      <one-to-many class="ProjectItem"/>
    </set>
  </class>
</hibernate-mapping>