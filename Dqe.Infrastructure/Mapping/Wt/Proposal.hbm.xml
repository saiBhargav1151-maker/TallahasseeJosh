<?xml version="1.0" encoding="utf-8"?>
<hibernate-mapping schema="transport" assembly="Dqe.Domain" namespace="Dqe.Domain.Model.Wt" xmlns="urn:nhibernate-mapping-2.2">
  <class name="Proposal" table="PROPOSAL" schema="trnsport" mutable="false">
    <id name="Id" type="Int64">
      <column name="PROPOSAL_ID" not-null="true" sql-type="bigint" />
      <generator class="identity" />
    </id>
    <many-to-one name="MyLetting" column="LETTING_ID" class="Letting" not-null="false"/>
    <many-to-one name="County" column="PRIMARY_REFCOUNTY_ID" class="RefCounty" not-null="false"/>
    <many-to-one name="District" column="PRIMARY_REFDISTRICT_ID" class="RefDistrict" not-null="false"/>
    <property name="ProposalNumber" type="String" >
      <column name="PROPOSAL_NM" not-null="true" length="20" sql-type="varchar" />
    </property>
    <property name="ProposalStatus" type="String" >
      <column name="PROPOSALSTATUS" not-null="false" length="20" sql-type="varchar" />
    </property>
	<property name="StatusDate" >
	  <column name="STATUS_DT" not-null="false" sql-type="datetime2" />
	</property>
    <property name="Description" type="String" >
      <column name="DESCR" not-null="true" length="256" sql-type="varchar" />
    </property>
	  <property name="ExecutedDate">
		  <column name="LPDT2" not-null="false" sql-type="datetime2" />
	  </property>
    <property name="IsRejected" >
      <column name="REJECTED" not-null="true" sql-type="bit" />
    </property>
    <property name="ContractType" type="String" >
      <column name="CONTRACTTYPE" not-null="false" length="20" sql-type="varchar" />
    </property>
    <property name="ProposalType" type="String" >
      <column name="PROPOSALTYPE" not-null="false" length="20" sql-type="varchar" />
    </property>
    <property name="ContractWorkType" type="String" >
      <column name="CONTRACTWORKTYPE" not-null="false" length="20" sql-type="varchar" />
    </property>
    <property name="OfficialEstimate" type="String" >
      <column name="PRFLG4" not-null="false" length="1" sql-type="varchar" />
    </property>
	<property name="PassToDss" type="String" >
	  <column name="PASSDSS " not-null="false" length="1" sql-type="varchar" />
	</property>
	<property name="PassToDssDate" >
	  <column name="PASSEDTODSS_DT " not-null="false" sql-type="datetime2" />
	</property>
    <!-- Pricing -->
    <property name="ProposalItemTotal" >
      <column name="PROPOSALITEMTOTAL" precision="14" scale="2" sql-type="numeric"  not-null="false" />
    </property>
    <property name="LastUpdatedDate" >
      <column name="LASTUPDATED_DT" not-null="false" sql-type="datetime2" />
    </property>
    <property name="LastUpdatedBy" >
      <column name="LASTUPDATEDBY" length="256" not-null="false" sql-type="varchar" />
    </property>
    <!-- End Pricing-->
    <set name="Projects" lazy="true" inverse="true" cascade="none" access="field.camelcase-underscore">
      <key column="PROPOSAL_ID"/>
      <one-to-many class="Project"/>
    </set>
    <set name="Sections" lazy="true" inverse="true" cascade="none" access="field.camelcase-underscore">
      <key column="PROPOSAL_ID"/>
      <one-to-many class="Section"/>
    </set>
    <set name="ProposalVendors" lazy="true" inverse="true" cascade="none" access="field.camelcase-underscore">
      <key column="PROPOSAL_ID"/>
      <one-to-many class="ProposalVendor"/>
    </set>
	  <set name="Milestones" lazy="true" inverse="true" cascade="none" access="field.camelcase-underscore">
		  <key column="PROPOSAL_ID"/>
		  <one-to-many class="Milestone"/>
	  </set>
  </class>
</hibernate-mapping>