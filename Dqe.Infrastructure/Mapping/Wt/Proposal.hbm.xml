<?xml version="1.0" encoding="utf-8"?>
<hibernate-mapping schema="transport" assembly="Dqe.Domain" namespace="Dqe.Domain.Model.Wt" xmlns="urn:nhibernate-mapping-2.2">
  <class name="Proposal" table="PROPOSAL" schema="trnsport">
    <id name="Id" type="Int64">
      <column name="PROPOSAL_ID" not-null="true" sql-type="bigint" />
      <generator class="identity" />
    </id>
    <many-to-one name="MyLetting" column="LETTING_ID" class="Letting" not-null="false"/>
    <property name="ProposalNumber" type="String">
      <column name="PROPOSAL_NM" not-null="true" length="20" sql-type="varchar" />
    </property>
    <property name="Description" type="String">
      <column name="DESCR" not-null="true" length="256" sql-type="varchar" />
    </property>
    <set name="Projects" lazy="true" inverse="true" cascade="none" access="field.camelcase-underscore" >
      <key column="PROPOSAL_ID"/>
      <one-to-many class="Project"/>
    </set>
    <set name="Sections" lazy="true" inverse="true" cascade="none" access="field.camelcase-underscore" >
      <key column="PROPOSAL_ID"/>
      <one-to-many class="Section"/>
    </set>
  </class>
</hibernate-mapping>