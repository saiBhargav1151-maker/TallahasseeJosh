<?xml version="1.0" encoding="utf-8" ?>
<!-- MAKE SURE THIS FILE IS AN EMBEDDED RESOURCE -->
<hibernate-mapping xmlns="urn:nhibernate-mapping-2.2" assembly="Dqe.Domain" namespace="Dqe.Domain.Model">
  <class name="ProjectVersion" table="ProjectVersion7">
    <id name="Id">
      <generator class="identity" />
    </id>
    <natural-id>
      <many-to-one name="MyProject" class="Project" column="ProjectId" not-null="true"/>
      <property name="Version" not-null="true"/>
    </natural-id>
    <many-to-one name="SnapshotSource" class="ProjectSnapshot" column="SourceProjectId" not-null="false"/>
    <many-to-one name="VersionOwner" class="DqeUser" column="VersionOwnerId" not-null="true"/>
    <property name="ProjectSource" not-null="true"/>
    <set name="ProjectSnapshots" lazy="true" inverse="true" cascade="all-delete-orphan" access="field.camelcase-underscore" >
      <key column="ProjectVersionId"/>
      <one-to-many class="ProjectSnapshot"/>
    </set>
  </class>
</hibernate-mapping>