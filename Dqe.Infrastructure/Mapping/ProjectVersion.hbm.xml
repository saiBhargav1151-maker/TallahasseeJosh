<?xml version="1.0" encoding="utf-8" ?>
<!-- MAKE SURE THIS FILE IS AN EMBEDDED RESOURCE -->
<hibernate-mapping xmlns="urn:nhibernate-mapping-2.2" assembly="Dqe.Domain" namespace="Dqe.Domain.Model">
  <class name="ProjectVersion" table="DQET029_PROJ_VER">
    <id name="Id" column="PROJ_VER_SQ">
      <generator class="sequence">
        <param name="sequence">DQEQ029_PROJ_VER</param>
      </generator>
    </id>
    <natural-id>
      <many-to-one name="MyProject" class="Project" column="PROJ_SQ" not-null="true"/>
      <property name="Version">
        <column name="VER_NUM" not-null="true"/>
      </property>
    </natural-id>
    <many-to-one name="EstimateSource" class="ProjectEstimate" column="PROJ_ESTM_SQ" not-null="false"/>
    <many-to-one name="VersionOwner" class="DqeUser" column="USER_ACCT_SQ" not-null="true"/>
    <many-to-one name="MyProposal" class="Proposal" column="PRPOS_SQ" not-null="false"/>
    <property name="ProjectSource" type="NHibernate.Type.EnumCharType`1[Dqe.Domain.Model.ProjectSourceType, Dqe.Domain], NHibernate">
      <column name="PROJ_VER_SRCE_CD" not-null="true"/>
    </property>
    <set name="ProjectEstimates" lazy="true" inverse="true" cascade="all-delete-orphan" access="field.camelcase-underscore" >
      <key column="PROJ_VER_SQ"/>
      <one-to-many class="ProjectEstimate"/>
    </set>
  </class>
</hibernate-mapping>