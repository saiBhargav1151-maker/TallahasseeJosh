<?xml version="1.0" encoding="utf-8" ?>
<!-- MAKE SURE THIS FILE IS AN EMBEDDED RESOURCE -->
<hibernate-mapping xmlns="urn:nhibernate-mapping-2.2" assembly="Dqe.Domain" namespace="Dqe.Domain.Model">
  <class name="Project" table="DQET020_PROJ">
    <id name="Id" column="PROJ_SQ">
      <generator class="sequence">
        <param name="sequence">DQEQ020_PROJ</param>
      </generator>
    </id>
    <natural-id>
      <property name="ProjectNumber" type="AnsiString">
        <column name="PROJ_NM" sql-type="varchar(20)" not-null="true"/>
      </property>
    </natural-id>
    <many-to-one name="MyMasterFile" class="MasterFile" column="MSTR_FILE_SQ" not-null="true"/>
    <many-to-one name="CustodyOwner" class="DqeUser" column="USER_ACCT_SQ" not-null="false"/>
    <many-to-one name="MyCounty" class="County" column="CNTY_SQ" not-null="true"/>
    <property name="WtId">
      <column name="TRNSP_SYS_NUM" not-null="true"/>
    </property>
    <property name="WtLsDbId">
      <column name="DSGN_BLD_NUM" not-null="true"/>
    </property>
    <property name="LsDbCode" type="AnsiString">
      <column name="DSGN_BLD_CD" sql-type="varchar(2)" not-null="true"/>
    </property>
    <property name="Description" type="AnsiString">
      <column name="PROJ_DS" sql-type="varchar(256)" not-null="false"/>
    </property>
    <property name="District" type="AnsiString">
      <column name="DIST_TXT" sql-type="varchar(256)" not-null="false"/>
    </property>
    <property name="DesignerName" type="AnsiString">
      <column name="DSGN_TXT" sql-type="varchar(256)" not-null="false"/>
    </property>
    <property name="EstimateInitial">
      <column name="ESTM_INIT_AMT" sql-type="decimal(14, 2)" not-null="false"/>
    </property>
    <property name="EstimateScope">
      <column name="ESTM_SCOP_AMT" sql-type="decimal(14, 2)" not-null="false"/>
    </property>
    <property name="EstimatePhase1">
      <column name="ESTM_PHAS_1_AMT" sql-type="decimal(14, 2)" not-null="false"/>
    </property>
    <property name="EstimatePhase2">
      <column name="ESTM_PHAS_2_AMT" sql-type="decimal(14, 2)" not-null="false"/>
    </property>
    <property name="EstimatePhase3">
      <column name="ESTM_PHAS_3_AMT" sql-type="decimal(14, 2)" not-null="false"/>
    </property>
    <property name="EstimatePhase4">
      <column name="ESTM_PHAS_4_AMT" sql-type="decimal(14, 2)" not-null="false"/>
    </property>
    <!--<property name="PseeContactSrsId">
      <column name="PseeContactSrsId" not-null="false"/>
    </property>-->
    <set name="ProjectVersions" lazy="true" inverse="true" cascade="all-delete-orphan" access="field.camelcase-underscore" >
      <key column="PROJ_SQ"/>
      <one-to-many class="ProjectVersion"/>
    </set>
    <set name="Proposals" lazy="true" inverse="false" cascade="save-update" access="field.camelcase-underscore" table="DQET021_PRPOS_PROJ">
      <key column="PROJ_SQ"/>
      <many-to-many class="Proposal" column="PRPOS_SQ"/>
    </set>
    <set name="AssignedUsers" lazy="true" inverse="false" cascade="save-update" access="field.camelcase-underscore" table="DQET023_PROJ_ASSGN">
      <key column="PROJ_SQ"/>
      <many-to-many class="DqeUser" column="USER_ACCT_SQ"/>
    </set>
  </class>
</hibernate-mapping>