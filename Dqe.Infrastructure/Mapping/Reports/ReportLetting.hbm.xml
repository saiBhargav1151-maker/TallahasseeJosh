<?xml version="1.0" encoding="utf-8" ?>
<hibernate-mapping xmlns="urn:nhibernate-mapping-2.2" assembly="Dqe.Domain" namespace="Dqe.Domain.Model.Reports">
	<class name="ReportLetting" table="DQET031_RPT_LET">
		<id name="Id" column="RPT_LET_SQ">
      <generator class="sequence">
        <param name="sequence">DQEQ031_RPT_LET</param>
      </generator>
		</id>
    <property name="LettingDate">
      <column name="LET_DT" sql-type="datetime2" not-null="true"/>
    </property>
    <property name="LettingName" type="AnsiString">
      <column name="LET_NM" sql-type="varchar(20)" not-null="true"/>
    </property>
    <property name="Total">
      <column name="TOT_NUM" sql-type="decimal(14, 2)" not-null="true"/>
    </property>
		<set name="ReportProposals" lazy="true" inverse="true" cascade="all-delete-orphan" access="field.camelcase-underscore">
			<key column="RPT_LET_SQ"/>
			<one-to-many class="ReportProposal"/>
		</set>
		<set name="ReportLettingSummaries" lazy="true" inverse="true" cascade="all-delete-orphan" access="field.camelcase-underscore">
			<key column="RPT_LET_SQ"/>
			<one-to-many class="ReportLettingSummary"/>
		</set>
	</class>
</hibernate-mapping>