<?xml version="1.0" encoding="utf-8" ?>
<hibernate-mapping xmlns="urn:nhibernate-mapping-2.2" assembly="Dqe.Domain" namespace="Dqe.Domain.Model.Reports">
	<class name="ReportProjectItem" table="ReportProjectItem">
		<id name="Id">
			<generator class="identity" />
		</id>
		<property name="ItemNumber" not-null="true"/>
		<property name="Description" not-null="true" />
		<property name="WorkClass" not-null="true" />
		<property name="TechSpec" not-null="true"/>
		<property name="DoNotBid" not-null="true" />
		<property name="ItemAlternateSet" not-null="true" />
		<property name="ItemAlternateMember" not-null="true"/>
		<property name="IsLowCost" not-null="true" />
		<property name="Unit" not-null="true" />
		<property name="Quantity" not-null="true"/>
		<property name="Price" not-null="true" />
		<property name="ObsoleteDate" not-null="false" />
		<property name="IsObsolete" not-null="true" />
		<!--<property name="Total" not-null="false" />-->

		<many-to-one name="MyReportCategory" class="ReportCategory" column="ReportCategoryId" not-null="true"/>

	</class>
</hibernate-mapping>