<?xml version="1.0" encoding="utf-8" ?>
<hibernate-mapping xmlns="urn:nhibernate-mapping-2.2" assembly="Dqe.Domain" namespace="Dqe.Domain.Model.Reports">
	<class name="ReportProposalMilestone" table="DQET038_RPT_MLSTN">
		<id name="Id" column="RPT_MLSTN_SQ">
			<generator class="sequence">
        <param name="sequence">DQEQ038_RPT_MLSTN</param>
      </generator>
		</id>
    <many-to-one name="MyReportProposal" class="ReportProposal" column="RPT_PRPOS_SQ" not-null="true"/>
    <property name="Description" type="AnsiString">
      <column name="MLSTN_DS" sql-type="varchar(256)" not-null="true"/>
    </property>
		<property name="Unit" type="AnsiString">
      <column name="UNIT_TXT" sql-type="varchar(20)" not-null="false"/>
    </property>
		<property name="ConstructionDays">
      <column name="DY_NUM" not-null="true"/>
    </property>
		<property name="CostPerDay">
      <column name="DY_CST_NUM" sql-type="decimal(14, 2)" not-null="true"/>
    </property>
		<property name="Total">
      <column name="TOT_NUM" sql-type="decimal(14, 2)" not-null="true"/>
    </property>
	</class>
</hibernate-mapping>