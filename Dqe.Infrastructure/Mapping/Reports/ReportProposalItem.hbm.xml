<?xml version="1.0" encoding="utf-8" ?>
<hibernate-mapping xmlns="urn:nhibernate-mapping-2.2" assembly="Dqe.Domain" namespace="Dqe.Domain.Model.Reports">
	<class name="ReportProposalItem" table="DQET037_RPT_PRO_IT">
		<id name="Id" column="RPT_PRPOS_ITM_SQ">
      <generator class="sequence">
        <param name="sequence">DQEQ037_RPT_PRO_IT</param>
      </generator>
		</id>
		<many-to-one name="MyReportProposal" class="ReportProposal" column="RPT_PRPOS_SQ" not-null="true"/>
    <property name="ItemNumber" type="AnsiString">
      <column name="ITM_NM" sql-type="varchar(20)" not-null="true"/>
    </property>
	<property name="LineNumber" type="AnsiString">
	 <column name="LINE_TXT" sql-type="varchar(10)" not-null="true"/>
	</property>
		<property name="CategoryDescription" type="AnsiString">
      <column name="CAT_DS" sql-type="varchar(256)" not-null="true"/>
    </property>
		<property name="Description" type="AnsiString">
      <column name="ITM_DS" sql-type="varchar(256)" not-null="true"/>
    </property>
		<property name="SupplementalDescription" type="AnsiString">
			<column name="SPLMNT_DS" sql-type="varchar(256)" not-null="true"/>
		</property>
		<property name="WorkClass" type="AnsiString">
      <column name="WRK_CLS_TXT" sql-type="varchar(20)" not-null="true"/>
    </property>
		<property name="TechSpec" type="AnsiString">
      <column name="TECH_SPEC_TXT" sql-type="varchar(20)" not-null="true"/>
    </property>
		<property name="DoNotBid" type="Dqe.Infrastructure.Types.BoolType, Dqe.Infrastructure">
      <column name="NO_BID_CD" sql-type="char(1)" not-null="true"/>
    </property>
		<property name="AlternateDescription" type="AnsiString">
      <column name="ALT_DS" sql-type="varchar(256)" not-null="true"/>
    </property>
		<property name="CategoryAlternateSet" type="AnsiString">
      <column name="CAT_ALT_SET_TXT" sql-type="varchar(20)" not-null="true"/>
    </property>
		<property name="CategoryAlternateMember" type="AnsiString">
      <column name="CAT_ALT_MBR_TXT" sql-type="varchar(20)" not-null="true"/>
    </property>
		<property name="ItemAlternateSet" type="AnsiString">
      <column name="ITM_ALT_SET_TXT" sql-type="varchar(20)" not-null="true"/>
    </property>
		<property name="ItemAlternateMember" type="AnsiString">
      <column name="ITM_ALT_MBR_TXT" sql-type="varchar(20)" not-null="true"/>
    </property>
		<property name="IsLowCost" type="Dqe.Infrastructure.Types.BoolType, Dqe.Infrastructure">
      <column name="LOW_CST_CD" sql-type="char(1)" not-null="true"/>
    </property>
		<property name="Unit" type="AnsiString">
      <column name="UNIT_TXT" sql-type="varchar(280)" not-null="true"/>
    </property>
		<property name="Quantity">
      <column name="QTY_NUM" sql-type="decimal(14, 3)" not-null="true"/>
    </property>
		<property name="Price">
      <column name="PRCE_NUM" sql-type="decimal(14, 2)" not-null="true"/>
    </property>
		<property name="ObsoleteDate">
      <column name="OBSLT_DT" sql-type="datetime2" not-null="false"/>
    </property>
		<property name="IsObsolete" type="Dqe.Infrastructure.Types.BoolType, Dqe.Infrastructure">
      <column name="OBSLT_CD" sql-type="char(1)" not-null="true"/>
    </property>
		<property name="AverageBidPrice">
	  <column name="AVG_BID_PRCE_NUM" sql-type="decimal(14, 2)" not-null="true"/>
	</property>
		<property name="Magnitude">
			<column name="ESTM_DFFR_NUM" sql-type="decimal(14, 2)" not-null="false"/>
		</property>
		<property name="Total">
      <column name="TOT_NUM" sql-type="decimal(14, 2)" not-null="true"/>
    </property>		
		<set name="ReportVendorBids" lazy="true" inverse="true" cascade="all-delete-orphan" access="field.camelcase-underscore" >
			<key column="RPT_PRPOS_ITM_SQ"/>
			<one-to-many class="ReportVendorBid"/>
		</set>
	</class>
</hibernate-mapping>
