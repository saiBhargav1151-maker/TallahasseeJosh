<?xml version="1.0" encoding="utf-8" ?>
<hibernate-mapping xmlns="urn:nhibernate-mapping-2.2" assembly="Dqe.Domain" namespace="Dqe.Domain.Model.Reports">
	<class name="ReportProject" table="DQET033_RPT_PROJ">
		<id name="Id" column="RPT_PROJ_SQ">
      <generator class="sequence">
        <param name="sequence">DQEQ033_RPT_PROJ</param>
      </generator>
		</id>
    <many-to-one name="MyReportProposal" class="ReportProposal" column="RPT_PRPOS_SQ" not-null="true"/>
    <property name="ProjectNumber" type="AnsiString">
      <column name="PROJ_NM" sql-type="varchar(20)" not-null="true"/>
    </property>
		<property name="Description" type="AnsiString">
      <column name="PROJ_DS" sql-type="varchar(256)" not-null="true"/>
    </property>
		<property name="ProjectWorkType" type="AnsiString">
			<column name="WRK_TYP_TXT" sql-type="varchar(300)" not-null="true"/>
		</property>
		<property name="FederalProjectNumber" type="AnsiString">
			<column name="FED_PROJ_TXT" sql-type="varchar(40)" not-null="true"/>
		</property>
		<property name="Primary" type="AnsiString">
			<column name="PRIM_CD " sql-type="char(1)" not-null="true"/>
		</property>
		<property name="County" type="AnsiString">
      <column name="CNTY_TXT" sql-type="varchar(100)" not-null="true"/>
    </property>
		<property name="District">
      <column name="DIST_TXT" sql-type="char(2)" not-null="true"/>
    </property>
		<property name="LettingDate">
      <column name="LET_DT" sql-type="datetime2" not-null="false"/>
    </property>
		<property name="Total">
      <column name="TOT_AMT" sql-type="decimal(14, 2)" not-null="true"/>
    </property>
		<set name="ReportCategories" lazy="true" inverse="true" cascade="all-delete-orphan" access="field.camelcase-underscore" >
			<key column="RPT_PROJ_SQ"/>
			<one-to-many class="ReportCategory"/>
		</set>
		<set name="ReportProjectSummaries" lazy="true" inverse="true" cascade="all-delete-orphan" access="field.camelcase-underscore" >
			<key column="RPT_PROJ_SQ"/>
			<one-to-many class="ReportProjectSummary"/>
		</set>
	</class>
</hibernate-mapping>
