<?xml version="1.0" encoding="utf-8" ?>
<hibernate-mapping xmlns="urn:nhibernate-mapping-2.2" assembly="Dqe.Domain" namespace="Dqe.Domain.Model.Reports">
	<class name="ReportProposalVendor" table="DQET040_RPT_PRO_VD">
		<id name="Id" column="RPT_PRPOS_VEND_SQ">
      <generator class="sequence">
        <param name="sequence">DQEQ040_RPT_PRO_VD</param>
      </generator>
		</id>
    <many-to-one name="MyReportProposal" class="ReportProposal" column="RPT_PRPOS_SQ" not-null="true"/>
    <property name="Name" type="AnsiString">
      <column name="VEND_NM" sql-type="varchar(100)" not-null="true"/>
    </property>
		<property name="BidType" type="AnsiString">
      <column name="BID_TYP_TXT" sql-type="varchar(20)" not-null="true"/>
    </property>
		<property name="BidStatus" type="AnsiString">
      <column name="BID_STAT_TXT" sql-type="varchar(20)" not-null="true"/>
    </property>
		<property name="Awarded" type="Dqe.Infrastructure.Types.BoolType, Dqe.Infrastructure">
      <column name="AWRD_CD" sql-type="char(1)" not-null="true"/>
    </property>
		<property name="Total">
      <column name="TOT_NUM" sql-type="decimal(14, 2)" not-null="true"/>
    </property>
		<set name="ReportVendorBids" lazy="true" inverse="true" cascade="all-delete-orphan" access="field.camelcase-underscore" >
			<key column="RPT_PRPOS_VEND_SQ"/>
			<one-to-many class="ReportVendorBid"/>
		</set>
	</class>
</hibernate-mapping>