<?xml version="1.0" encoding="utf-8" ?>
<hibernate-mapping xmlns="urn:nhibernate-mapping-2.2" assembly="Dqe.Domain" namespace="Dqe.Domain.Model.Reports">
	<class name="ReportLettingSummary" table="DQET032_RPT_LET_SM">
		<id name="Id" column="RPT_LET_SUM_SQ">
      <generator class="sequence">
        <param name="sequence">DQEQ032_RPT_LET_SM</param>
      </generator>
		</id>
    <many-to-one name="MyReportLetting" class="ReportLetting" column="RPT_LET_SQ" not-null="true"/>
    <property name="ContractRange" type="AnsiString">
      <column name="CNTRT_RNG_TXT" sql-type="varchar(35)" not-null="true"/>
    </property>
    <property name="NumberOfContracts">
      <column name="CNTCT_NUM" not-null="true"/>
    </property>
    <property name="ValueInCategory">
      <column name="CAT_VAL_NUM" sql-type="decimal(14, 2)" not-null="true"/>
    </property>
		<property name="ValueOfEstimate">
      <column name="ESTM_VAL_NUM" sql-type="decimal(14, 2)" not-null="true"/>
    </property>
		<property name="PercentageOfContracts">
      <column name="CNTRT_PCT_NUM" sql-type="decimal(14, 2)" not-null="true"/>
    </property>
		<property name="PercentageOfLettingTotal">
      <column name="LET_TOT_PCT_NUM" sql-type="decimal(14, 2)" not-null="true"/>
    </property>
		<property name="NumberOfContractsBelowEstimate">
      <column name="CNTRT_UNDR_NUM" not-null="true"/>
    </property>
		<property name="PercentageRangeDifferenceBelow" type="AnsiString">
      <column name="PCT_UNDR_DFFR_TXT" sql-type="varchar(20)" not-null="true"/>
    </property>
		<property name="AveragePercentageBelowEstimate">
      <column name="AVG_UNDR_DFFR_NUM" sql-type="decimal(14, 2)" not-null="true"/>
    </property>
		<property name="NumberOfContractsAboveEstimate">
      <column name="CNTRT_OV_NUM" not-null="true"/>
    </property>
		<property name="PercentageRangeDifferenceAbove" type="AnsiString">
      <column name="PCT_OV_DFFR_TXT" sql-type="varchar(20)" not-null="true"/>
    </property>
		<property name="AveragePercentageAboveEstimate">
      <column name="AVG_OV_DFFR_NUM" sql-type="decimal(14, 2)" not-null="true"/>
    </property>
		<property name="AverageBidsPerContract">
      <column name="AVG_CNTRT_BID_NUM" sql-type="decimal(14, 2)" not-null="true"/>
    </property>
	</class>
</hibernate-mapping>