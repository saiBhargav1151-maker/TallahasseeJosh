<?xml version="1.0" encoding="utf-8" ?>
<hibernate-mapping xmlns="urn:nhibernate-mapping-2.2" assembly="Dqe.Domain" namespace="Dqe.Domain.Model.Reports">
	<class name="ReportProposal" table="ReportProposal">
		<id name="Id">
			<generator class="identity" />
		</id>
		<natural-id>
			<property name="ProposalNumber" not-null="true" length="20" />
			<property name="ProposalLevel" not-null="true"/>
		</natural-id>
		<property name="LettingId" not-null="true"/>
		<property name="LettingDate" not-null="false" />
		<property name="ConstructionDays" not-null="true" />
		<property name="CostPerDay" not-null="true" />
		<property name="Description" not-null="true"/>
		<property name="WorkType" not-null="true"/>
		<property name="County" not-null="true"/>
		<property name="HasOversight" not-null="true"/>
		<property name="Total" not-null="true"/>

		<set name="ReportProposalSummaries" lazy="true" inverse="true" cascade="all-delete-orphan" access="field.camelcase-underscore" >
			<key column="ReportProposalId"/>
			<one-to-many class="ReportProposalSummary"/>
		</set>
		<set name="ReportProposalItems" lazy="true" inverse="true" cascade="all-delete-orphan" access="field.camelcase-underscore" >
			<key column="ReportProposalId"/>
			<one-to-many class="ReportProposalItem"/>
		</set>
		<set name="ReportProjects" lazy="true" inverse="true" cascade="all-delete-orphan" access="field.camelcase-underscore" >
			<key column="ReportProposalId"/>
			<one-to-many class="ReportProject"/>
		</set>
	</class>
</hibernate-mapping>
