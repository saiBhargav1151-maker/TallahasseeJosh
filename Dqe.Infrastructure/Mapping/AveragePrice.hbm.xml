<hibernate-mapping xmlns="urn:nhibernate-mapping-2.2" assembly="Dqe.Domain" namespace="Dqe.Domain.Model">
  <class name="AveragePrice" table="DQET015_AVG_PRCE">
    <id name="Id" column="AVG_PRCE_SQ">
      <generator class="sequence">
        <param name="sequence">DQEQ015_AVG_PRCE</param>
      </generator>
    </id>
    <discriminator force="true">
      <column name="AVG_PRCE_TYP_CD" sql-type="char(1)" not-null="true"/>
    </discriminator>
    <many-to-one name="MyPayItemMaster" column="PAY_ITM_SQ" not-null="true"/>
