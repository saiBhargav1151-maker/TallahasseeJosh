      <column name="PRCE_AMT" sql-type="decimal(14, 2)" not-null="true"/>
    </property>
    <subclass discriminator-value="C" name="CountyAveragePrice">
      <many-to-one name="MyCounty" column="CNTY_SQ" not-null="false"/>  
    </subclass>
    <subclass discriminator-value="M" name="MarketAreaAveragePrice">
      <many-to-one name="MyMarketArea" column="MKT_AREA_SQ" not-null="false"/>
    </subclass>
  </class>
</hibernate-mapping>