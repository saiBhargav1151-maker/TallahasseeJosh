<hibernate-mapping xmlns="urn:nhibernate-mapping-2.2" assembly="Dqe.Domain" namespace="Dqe.Domain.Model">
  <class name="AveragePrice" table="AveragePrice10">
    <id name="Id">
      <generator class="identity" />
    </id>
    <discriminator column="AveragePriceType" force="true" not-null="true"/>
    <many-to-one name="MyPayItemMaster" column="PayItemMasterId" not-null="true"/>
    <property name="Price" not-null="true" />
    <subclass discriminator-value="C" name="CountyAveragePrice">
      <many-to-one name="MyCounty" column="CountyId" not-null="false"/>  
    </subclass>
    <subclass discriminator-value="M" name="MarketAreaAveragePrice">
      <many-to-one name="MyMarketArea" column="MarketAreaId" not-null="false"/>
    </subclass>
  </class>
</hibernate-mapping>