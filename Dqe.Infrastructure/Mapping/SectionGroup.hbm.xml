<?xml version="1.0" encoding="utf-8" ?>
<!-- MAKE SURE THIS FILE IS AN EMBEDDED RESOURCE -->
<hibernate-mapping xmlns="urn:nhibernate-mapping-2.2" assembly="Dqe.Domain" namespace="Dqe.Domain.Model">
  <class name="SectionGroup" table="DQET024_SECT">
    <id name="Id" column="SECT_SQ">
      <generator class="sequence">
        <param name="sequence">DQEQ024_SECT</param>
      </generator>
    </id>
    <many-to-one name="MyProposal" column="PRPOS_SQ" not-null="true"/>
    <property name="WtId">
      <column name="TRNSP_SYS_NUM" not-null="true"/>
    </property>
    <property name="Description" type="AnsiString">
      <column name="SECT_DS" sql-type="varchar(256)" not-null="true"/>
    </property>
    <property name="Name" type="AnsiString">
      <column name="SECT_NM" sql-type="varchar(20)" not-null="true"/>
    </property>
    <property name="AlternateSet" type="AnsiString">
      <column name="ALT_SET_TXT" sql-type="varchar(20)" not-null="true"/>
    </property>
    <property name="AlternateMember" type="AnsiString">
      <column name="ALT_MBR_TXT" sql-type="varchar(20)" not-null="true"/>
    </property>
    <set name="ProposalItems" lazy="true" inverse="true" cascade="all-delete-orphan" access="field.camelcase-underscore" >
      <key column="SECT_SQ"/>
      <one-to-many class="ProposalItem"/>
    </set>
  </class>
</hibernate-mapping>