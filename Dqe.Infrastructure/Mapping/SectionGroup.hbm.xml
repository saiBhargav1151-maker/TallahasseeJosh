<?xml version="1.0" encoding="utf-8" ?>
<!-- MAKE SURE THIS FILE IS AN EMBEDDED RESOURCE -->
<hibernate-mapping xmlns="urn:nhibernate-mapping-2.2" assembly="Dqe.Domain" namespace="Dqe.Domain.Model">
  <class name="SectionGroup" table="SectionGroup">
    <id name="Id">
      <generator class="identity" />
    </id>
    <many-to-one name="MyProposal" column="ProposalId" not-null="true"/>
    <property name="WtId" not-null="true"/>
    <property name="Description" not-null="true" length="256" />
    <property name="Name" not-null="true" length="20" />
    <property name="AlternateSet" not-null="true" length="20" />
    <property name="AlternateMember" not-null="true" length="20" />
    <set name="ProposalItems" lazy="true" inverse="true" cascade="all-delete-orphan" access="field.camelcase-underscore" >
      <key column="SectionGroupId"/>
      <one-to-many class="ProposalItem"/>
    </set>
  </class>
</hibernate-mapping>