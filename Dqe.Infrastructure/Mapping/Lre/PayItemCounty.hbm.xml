<?xml version="1.0" encoding="utf-8" ?>
<!-- MAKE SURE THIS FILE IS AN EMBEDDED RESOURCE -->
<hibernate-mapping xmlns="urn:nhibernate-mapping-2.2" assembly="Dqe.Domain" namespace="Dqe.Domain.Model.Lre">
  <class name="PayItemCounty" table="LRET025_PI_CNTY">
    <composite-id name="Id" class="PayItemCountyId">
      <key-property name="PayItemId" column="PAY_ITM_ID" />
      <key-property name="County" column="DOT_CNTY_CD" />
    </composite-id>
    <many-to-one name="MyPayItem" class="PayItem" column="PAY_ITM_ID" insert="false" update="false"/>
    <property name="UnitPrice" column="UNIT_PRCE_AMT" not-null="true"/>
    <property name="LockCode" column="UNIT_PRCE_LOCK_CD" not-null="true"/>
    <set name="PayItemDistricts" lazy="true" inverse="true" cascade="all-delete-orphan" access="field.camelcase-underscore">
      <key>
        <column name="PAY_ITM_ID"/>
        <column name="DOT_CNTY_CD"/>
      </key>
      <one-to-many class="PayItemDistrict"/>
    </set>
  </class>
</hibernate-mapping>