<hibernate-mapping xmlns="urn:nhibernate-mapping-2.2" assembly="Dqe.Domain" namespace="Dqe.Domain.Model.Lre">
  <class name="PayItemDistrict" table="LRET026_PI_DIST_CN">
    <composite-id name="Id" class="PayItemDistrictId">
      <key-property name="PayItemId" column="PAY_ITM_ID" />
      <key-property name="County" column="DOT_CNTY_CD" />
      <key-property name="District" column="MNG_DIST_CD" />
    </composite-id>
    <many-to-one name="MyPayItemCounty" class="PayItemCounty" insert="false" update="false">
      <column name="PAY_ITM_ID"/>
      <column name="DOT_CNTY_CD"/>
    </many-to-one>
    <property name="UnitPrice" column="UNIT_PRCE_AMT" not-null="true"/>
    <property name="LockCode" column="UNIT_PRCE_LOCK_CD" not-null="true"/>
  </class>
</hibernate-mapping>