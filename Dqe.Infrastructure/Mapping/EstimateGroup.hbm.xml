<?xml version="1.0" encoding="utf-8" ?>
<!-- MAKE SURE THIS FILE IS AN EMBEDDED RESOURCE -->
<hibernate-mapping xmlns="urn:nhibernate-mapping-2.2" assembly="Dqe.Domain" namespace="Dqe.Domain.Model">
  <class name="EstimateGroup" table="EstimateGroup">
    <id name="Id">
      <generator class="identity" />
    </id>
    <many-to-one name="MyProjectEstimate" column="ProjectEstimateId" not-null="true"/>
    <property name="WtId" not-null="true"/>
    <property name="Name" not-null="true" length="20" />
    <property name="Description" not-null="true" length="256" />
    <property name="AlternateSet" not-null="true" length="20" />
    <property name="AlternateMember" not-null="true" length="20" />
    <property name="IsLsDbSummary" not-null="true" />
    <property name="FederalConstructionClass" not-null="true" length="20" />
    <property name="CombineWithLikeItems" not-null="true"/>
    <set name="ProjectItems" lazy="true" inverse="true" cascade="all-delete-orphan" access="field.camelcase-underscore" >
      <key column="EstimateGroupId"/>
      <one-to-many class="ProjectItem"/>
    </set>
  </class>
</hibernate-mapping>