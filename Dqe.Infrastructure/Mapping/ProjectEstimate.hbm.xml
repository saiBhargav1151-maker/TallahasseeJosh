<?xml version="1.0" encoding="utf-8" ?>
<!-- MAKE SURE THIS FILE IS AN EMBEDDED RESOURCE -->
<hibernate-mapping xmlns="urn:nhibernate-mapping-2.2" assembly="Dqe.Domain" namespace="Dqe.Domain.Model">
  <class name="ProjectEstimate" table="DQET028_PROJ_ESTM">
    <id name="Id" column="PROJ_ESTM_SQ">
      <generator class="sequence">
        <param name="sequence">DQEQ028_PROJ_ESTM</param>
      </generator>
    </id>
    <natural-id>
      <many-to-one name="MyProjectVersion" class="ProjectVersion" column="PROJ_VER_SQ" not-null="true"/>
      <property name="Estimate">
        <column name="ESTM_NUM" not-null="true"/>
      </property>
    </natural-id>
    <property name="EstimateComment" type="AnsiString">
      <column name="CM_TXT" sql-type="varchar(500)" not-null="false"/>
    </property>
    <property name="LastUpdated">
      <column name="LAST_UPDT_TMS" sql-type="datetime2" not-null="true"/>
    </property>
    <property name="Created">
      <column name="CREA_TMS" sql-type="datetime2" not-null="true"/>
    </property>
    <property name="Label">
      <column name="LABL_NUM" not-null="true"/>
    </property>
    <property name="IsWorkingEstimate" type="Dqe.Infrastructure.Types.BoolType, Dqe.Infrastructure">
      <column name="WRK_ESTM_CD" sql-type="char(1)" not-null="true"/>
    </property>
    <set name="EstimateGroups" lazy="true" inverse="true" cascade="all-delete-orphan" access="field.camelcase-underscore" >
      <key column="PROJ_ESTM_SQ"/>
      <one-to-many class="EstimateGroup"/>
    </set>
    <set name="Users" lazy="true" inverse="false" cascade="save-update" access="field.camelcase-underscore" >
      <key column="PROJ_ESTM_SQ"/>
      <one-to-many class="DqeUser"/>
    </set>
  </class>
</hibernate-mapping>