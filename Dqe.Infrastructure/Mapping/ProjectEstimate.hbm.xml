<?xml version="1.0" encoding="utf-8" ?>
<!-- MAKE SURE THIS FILE IS AN EMBEDDED RESOURCE -->
<hibernate-mapping xmlns="urn:nhibernate-mapping-2.2" assembly="Dqe.Domain" namespace="Dqe.Domain.Model">
  <class name="ProjectEstimate" table="ProjectEstimate10">
    <id name="Id">
      <generator class="identity" />
    </id>
    <natural-id>
      <many-to-one name="MyProjectVersion" class="ProjectVersion" column="ProjectVersionId" not-null="true"/>
      <property name="Estimate" not-null="true"/>
    </natural-id>
    <property name="EstimateComment" not-null="false" length="500"/>
    <property name="LastUpdated" not-null="true" />
    <property name="Created" not-null="true" />
    <property name="Label" not-null="true" />
    <property name="IsWorkingEstimate" not-null="true" />
    <set name="EstimateGroups" lazy="true" inverse="true" cascade="all-delete-orphan" access="field.camelcase-underscore" >
      <key column="ProjectEstimateId"/>
      <one-to-many class="EstimateGroup"/>
    </set>
  </class>
</hibernate-mapping>