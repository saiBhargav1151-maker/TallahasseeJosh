<?xml version="1.0" encoding="utf-8" ?>
<!-- MAKE SURE THIS FILE IS AN EMBEDDED RESOURCE -->
<hibernate-mapping xmlns="urn:nhibernate-mapping-2.2" assembly="Dqe.Domain" namespace="Dqe.Domain.Model">
  <class name="DqeCode" abstract="true" table="DqeCode">
    <id name="Id">
      <generator class="sequence">
        <param name="sequence">SQ_DqeCode</param>
      </generator>
    </id>
    <discriminator>
      <column name="code_type" sql-type="char(2)" not-null="true"/>
    </discriminator>
    <property name="Name" type="AnsiString">
      <column name="Name" sql-type="varchar(255)" not-null="true"/>
    </property>
    <property name="IsActive" type="Dqe.Infrastructure.Types.BoolType, Dqe.Infrastructure">
      <column name="IsActive" sql-type="char(1)" not-null="true"/>
    </property>
    <subclass discriminator-value="CS" name="CaddSummary">
    </subclass>
  </class>
</hibernate-mapping>