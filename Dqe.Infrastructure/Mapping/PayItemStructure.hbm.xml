<?xml version="1.0" encoding="utf-8" ?>
<!-- MAKE SURE THIS FILE IS AN EMBEDDED RESOURCE -->
<hibernate-mapping xmlns="urn:nhibernate-mapping-2.2" assembly="Dqe.Domain" namespace="Dqe.Domain.Model">
  <class name="PayItemStructure" table="PayItemStructure">
    <id name="Id">
      <generator class="identity" />
    </id>
    <natural-id mutable="true">
      <property name="StructureId" not-null="true" length="12" />  
    </natural-id>
    <many-to-one name="MyCostBasedTemplate" column="CostBasedTemplateId" not-null="false"/>
    <property name="Title" not-null="true" length="255" />
    <property name="EffectiveDate" not-null="true" />
    <property name="ObsoleteDate" not-null="false" />
    <property name="IsPlanQuantity" not-null="true" />
    <property name="IsDoNotBid" not-null="true" />
    <property name="IsFixedPrice" not-null="true" />
    <property name="FixedAmount" not-null="false" />
    <property name="Accuracy" not-null="true" />
    <property name="OtherReferenceNotes" not-null="false" length="255" />
    <property name="Notes" not-null="false" length="200" />
    <property name="Details" not-null="false" length="5000" />
    <property name="PendingInformation" not-null="false" length="5000" />
    <property name="EssHistory" not-null="false" length="5000" />
    <property name="BoeRecentChangeDate" not-null="false" />
    <property name="BoeRecentChangeDescription" not-null="false" length="200" />
    <property name="StructureDescription" not-null="false" length="5000" />
    <property name="PlanSummary" not-null="false" length="5000" />
    <property name="IsMonitored" not-null="false" />
    <property name="SecondaryUnit" not-null="false" />
    <property name="PrimaryUnit" not-null="true" />
    <property name="SrsId" not-null="true"/>
    <set name="OtherReferences" lazy="true" inverse="false" cascade="save-update" access="field.camelcase-underscore" table="PayItemStructureOtherReferenceWebLinks">
      <key column="PayItemStructureId"/>
      <many-to-many class="OtherReferenceWebLink" column="OtherReferenceWebLinkId"/>
    </set>
    <set name="Standards" lazy="true" inverse="false" cascade="save-update" access="field.camelcase-underscore" table="PayItemStructureStandardWebLinks">
      <key column="PayItemStructureId"/>
      <many-to-many class="StandardWebLink" column="StandardWebLinkId"/>
    </set>
    <set name="PpmChapters" lazy="true" inverse="false" cascade="save-update" access="field.camelcase-underscore" table="PayItemStructurePpmChapterWebLinks">
      <key column="PayItemStructureId"/>
      <many-to-many class="PpmChapterWebLink" column="PpmChapterWebLinkId"/>
    </set>
    <set name="Specifications" lazy="true" inverse="false" cascade="save-update" access="field.camelcase-underscore" table="PayItemStructureSpecificationWebLinks">
      <key column="PayItemStructureId"/>
      <many-to-many class="SpecificationWebLink" column="SpecificationWebLinkId"/>
    </set>
    <set name="PrepAndDocChapters" lazy="true" inverse="false" cascade="save-update" access="field.camelcase-underscore" table="PayItemStructurePrepAndDocChapterWebLinks">
      <key column="PayItemStructureId"/>
      <many-to-many class="PrepAndDocChapterWebLink" column="PrepAndDocChapterWebLinkId"/>
    </set>
    <set name="PayItems" lazy="true" inverse="true" cascade="all-delete-orphan" access="field.camelcase-underscore" >
      <key column="PayItemStructureId"/>
      <one-to-many class="PayItem"/>
    </set>
    <set name="PayItemMasters" lazy="true" inverse="true" cascade="all-delete-orphan" access="field.camelcase-underscore" >
      <key column="PayItemStructureId"/>
      <one-to-many class="PayItemMaster"/>
    </set>
  </class>
</hibernate-mapping>