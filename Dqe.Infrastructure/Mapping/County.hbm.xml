<?xml version="1.0" encoding="utf-8" ?>
<!-- MAKE SURE THIS FILE IS AN EMBEDDED RESOURCE -->
<hibernate-mapping xmlns="urn:nhibernate-mapping-2.2" assembly="Dqe.Domain" namespace="Dqe.Domain.Model">
  <class name="County" table="County10">
    <id name="Id">
      <generator class="identity" />
    </id>
    <natural-id mutable="true">
      <property name="Name" not-null="true" length="100" />
    </natural-id>
    <many-to-one name="MyMarketArea" column="MarketAreaId" not-null="false"/>
    <property name="Code" not-null="true" length="2" unique="true" />
    <set name="Projects" lazy="true" inverse="true" cascade="all-delete-orphan" access="field.camelcase-underscore" >
      <key column="CountyId"/>
      <one-to-many class="Project"/>
    </set>
  </class>
</hibernate-mapping>