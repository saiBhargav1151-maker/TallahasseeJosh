<?xml version="1.0" encoding="utf-8" ?>
<!-- MAKE SURE THIS FILE IS AN EMBEDDED RESOURCE -->
<hibernate-mapping xmlns="urn:nhibernate-mapping-2.2" assembly="Dqe.Domain" namespace="Dqe.Domain.Model">
  <class name="DqeUser" table="DQET022_USER_ACCT">
    <id name="Id" column="USER_ACCT_SQ">
      <generator class="sequence">
        <param name="sequence">DQEQ022_USER_ACCT</param>
      </generator>
    </id>
    <natural-id>
      <property name="SrsId">
        <column name="STAF_MBR_CNCT_SQ" not-null="true"/>
      </property>
    </natural-id>
    <many-to-one name="MyRecentProjectEstimate" class="ProjectEstimate" column="PROJ_ESTM_SQ" not-null="false"/>
    <many-to-one name="MyRecentProposal" class="Proposal" column="PRPOS_SQ" not-null="false"/>
    <property name="Role">
      <column name="ROLE_NUM" not-null="true"/>
    </property>
    <property name="District">
      <column name="DIST_CD" sql-type="char(2)" not-null="true"/>
    </property>
    <property name="CostGroupAuthorization">
      <column name="CST_GRP_AUTH_CD" sql-type="char(1)" not-null="true"/>
    </property>
    <property name="IsActive" type="Dqe.Infrastructure.Types.BoolType, Dqe.Infrastructure">
      <column name="ACTV_CD" sql-type="char(1)" not-null="true"/>
    </property>
    <set name="AssignedProjects" lazy="true" inverse="false" cascade="save-update" access="field.camelcase-underscore" table="DQET023_PROJ_ASSGN">
      <key column="USER_ACCT_SQ"/>
      <many-to-many class="Project" column="PROJ_SQ"/>
    </set>
  </class>
</hibernate-mapping>