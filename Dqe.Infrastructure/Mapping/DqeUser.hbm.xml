<?xml version="1.0" encoding="utf-8" ?>
<!-- MAKE SURE THIS FILE IS AN EMBEDDED RESOURCE -->
<hibernate-mapping xmlns="urn:nhibernate-mapping-2.2" assembly="Dqe.Domain" namespace="Dqe.Domain.Model">
  <class name="DqeUser" table="DqeUser5">
    <id name="Id">
      <generator class="identity" />
    </id>
    <natural-id>
      <property name="SrsId" not-null="true"/>
    </natural-id>
    <many-to-one name="MyRecentProject" column="ProjectId" not-null="false"/>
    <property name="Role" not-null="true" />
    <property name="District" not-null="true" length="2"/>
    <property name="IsActive" not-null="true" />
    <set name="Projects" lazy="true" inverse="true" cascade="all-delete-orphan" access="field.camelcase-underscore" >
      <key column="OwnerId"/>
      <one-to-many class="Project"/>
    </set>
  </class>
</hibernate-mapping>