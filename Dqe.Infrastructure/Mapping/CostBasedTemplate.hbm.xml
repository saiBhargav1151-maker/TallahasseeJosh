<?xml version="1.0" encoding="utf-8" ?>
<!-- MAKE SURE THIS FILE IS AN EMBEDDED RESOURCE -->
<hibernate-mapping xmlns="urn:nhibernate-mapping-2.2" assembly="Dqe.Domain" namespace="Dqe.Domain.Model">
  <class name="CostBasedTemplate" table="CostBasedTemplate4">
    <id name="Id">
      <generator class="identity" />
    </id>
    <property name="Name" not-null="true" length="255" />
    <property name="ResultCell" not-null="true" />
    <set name="DocumentVersions" lazy="true" inverse="false" cascade="save-update" access="field.camelcase-underscore">
      <key column="CostBasedTemplateId"/>
      <one-to-many class="CostBasedTemplateDocumentVersion"/>
    </set>
    <set name="PayItemStructures" lazy="true" inverse="true" cascade="save-update" access="field.camelcase-underscore" >
      <key column="CostBasedTemplateId"/>
      <one-to-many class="PayItemStructure"/>
    </set>
    <set name="PayItems" lazy="true" inverse="true" cascade="save-update" access="field.camelcase-underscore" >
      <key column="CostBasedTemplateId"/>
      <one-to-many class="PayItem"/>
    </set>
  </class>
</hibernate-mapping>