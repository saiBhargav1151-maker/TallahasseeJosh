<?xml version="1.0" encoding="utf-8" ?>
<!-- MAKE SURE THIS FILE IS AN EMBEDDED RESOURCE -->
<hibernate-mapping xmlns="urn:nhibernate-mapping-2.2" assembly="Dqe.Domain" namespace="Dqe.Domain.Model">
  <class name="ProposalItem" table="DQET025_PRPOS_ITM">
    <id name="Id" column="PRPOS_ITM_SQ">
      <generator class="sequence">
        <param name="sequence">DQEQ025_PRPOS_ITM</param>
      </generator>
    </id>
    <many-to-one name="MySectionGroup" column="SECT_SQ" not-null="true"/>
    <property name="WtId">
      <column name="TRNSP_SYS_NUM" not-null="true"/>
    </property>
    <property name="Quantity">
      <column name="QTY_NUM" sql-type="decimal(12, 3)" not-null="true"/>
    </property>
    <property name="PayItemNumber" type="AnsiString">
      <column name="ITM_NM" sql-type="varchar(20)" not-null="false"/>
    </property>
    <property name="PayItemDescription" type="AnsiString">
      <column name="ITM_DS" sql-type="varchar(256)" not-null="false"/>
    </property>
    <property name="AlternateSet" type="AnsiString">
      <column name="ALT_SET_TXT" sql-type="varchar(20)" not-null="true"/>
    </property>
    <property name="AlternateMember" type="AnsiString">
      <column name="ALT_MBR_TXT" sql-type="varchar(20)" not-null="true"/>
    </property>
    <property name="SupplementalDescription" type="AnsiString">
      <column name="SPLMNT_DS" sql-type="varchar(256)" not-null="true"/>
    </property>
    <property name="CalculatedUnit" type="AnsiString">
      <column name="UNIT_DS" sql-type="varchar(280)" not-null="true"/>
    </property>
    <property name="Unit" type="AnsiString">
      <column name="UNIT_TXT" sql-type="varchar(10)" not-null="true"/>
    </property>
    <set name="ProjectItems" lazy="true" inverse="true" cascade="save-update" access="field.camelcase-underscore" >
      <key column="PRPOS_ITM_SQ"/>
      <one-to-many class="ProjectItem"/>
    </set>
  </class>
</hibernate-mapping>