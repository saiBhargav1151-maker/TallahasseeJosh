<?xml version="1.0" encoding="utf-8" ?>
<!-- MAKE SURE THIS FILE IS AN EMBEDDED RESOURCE -->
<hibernate-mapping xmlns="urn:nhibernate-mapping-2.2" assembly="Dqe.Domain" namespace="Dqe.Domain.Model">
  <class name="ProposalItem" table="ProposalItem10">
    <id name="Id">
      <generator class="identity" />
    </id>
    <many-to-one name="MySectionGroup" column="SectionGroupId" not-null="true"/>
    <property name="WtId" not-null="true"/>
    <property name="Quantity" not-null="true" />
    <property name="PayItemNumber" not-null="false" length="12" />
    <property name="PayItemDescription" not-null="false" length="256" />
    <property name="AlternateSet" not-null="true" length="20" />
    <property name="AlternateMember" not-null="true" length="20" />
    <property name="SupplementalDescription" not-null="true" length="256"/>
    <property name="CalculatedUnit" not-null="true" length="200"/>
    <property name="Unit" not-null="true" length="10"/>
    <set name="ProjectItems" lazy="true" inverse="true" cascade="save-update" access="field.camelcase-underscore" >
      <key column="ProposalItemId"/>
      <one-to-many class="ProjectItem"/>
    </set>
  </class>
</hibernate-mapping>