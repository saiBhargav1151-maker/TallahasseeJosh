<?xml version="1.0" encoding="utf-8" ?>
<!-- MAKE SURE THIS FILE IS AN EMBEDDED RESOURCE -->
<hibernate-mapping xmlns="urn:nhibernate-mapping-2.2" assembly="Dqe.Domain" namespace="Dqe.Domain.Model">
  <class name="Proposal" table="DQET018_PRPOS">
    <id name="Id" column="PRPOS_SQ">
      <generator class="sequence">
        <param name="sequence">DQEQ018_PRPOS</param>
      </generator>
    </id>
    <natural-id>
      <property name="ProposalNumber" type="AnsiString">
        <column name="PRPOS_NM" sql-type="varchar(20)" not-null="true"/>
      </property>
    </natural-id>
    <many-to-one name="County" class="County" column="CNTY_SQ" not-null="false"/>
    <many-to-one name="CurrentEstimator" class="DqeUser" column="USER_ACCT_SQ" not-null="false"/>
    <property name="Comment" type="AnsiString">
      <column name="CM_TXT" sql-type="varchar(500)" not-null="false"/>
    </property>
    <property name="WtId">
      <column name="TRNSP_SYS_NUM" not-null="true"/>
    </property>
    <property name="ProposalSource">
      <column name="PRPOS_SRCE_NUM" not-null="true"/>
    </property>
    <property name="Created">
      <column name="CREA_TMS" sql-type="datetime2" not-null="true"/>
    </property>
    <property name="LastUpdated">
      <column name="LAST_UPDT_TMS" sql-type="datetime2" not-null="true"/>
    </property>
    <property name="Description" type="AnsiString">
      <column name="PRPOS_DS" sql-type="varchar(256)" not-null="false"/>
    </property>
    <property name="LettingDate">
      <column name="LET_DT" sql-type="datetime2" not-null="false"/>
    </property>
    <property name="District" type="AnsiString">
      <column name="DIST_TXT" sql-type="varchar(256)" not-null="false"/>
    </property>
    <set name="ProjectVersions" lazy="true" inverse="true" cascade="all-delete-orphan" access="field.camelcase-underscore" >
      <key column="PRPOS_SQ"/>
      <one-to-many class="ProjectVersion"/>
    </set>
    <set name="Projects" lazy="true" inverse="true" cascade="save-update" access="field.camelcase-underscore" table="DQET021_PRPOS_PROJ">
      <key column="PRPOS_SQ"/>
      <many-to-many class="Project" column="PROJ_SQ"/>
    </set>
    <set name="SectionGroups" lazy="true" inverse="true" cascade="all-delete-orphan" access="field.camelcase-underscore">
      <key column="PRPOS_SQ"/>
      <one-to-many class="SectionGroup"/>
    </set>
    <set name="Users" lazy="true" inverse="false" cascade="save-update" access="field.camelcase-underscore" >
      <key column="PRPOS_SQ"/>
      <one-to-many class="DqeUser"/>
    </set>
  </class>
</hibernate-mapping>