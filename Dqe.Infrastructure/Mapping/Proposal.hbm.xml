<?xml version="1.0" encoding="utf-8" ?>
<!-- MAKE SURE THIS FILE IS AN EMBEDDED RESOURCE -->
<hibernate-mapping xmlns="urn:nhibernate-mapping-2.2" assembly="Dqe.Domain" namespace="Dqe.Domain.Model">
  <class name="Proposal" table="Proposal">
    <id name="Id">
      <generator class="identity" />
    </id>
    <natural-id>
      <property name="ProposalNumber" not-null="true" length="20" />
    </natural-id>
    <many-to-one name="County" class="County" column="CountyId" not-null="false"/>
    <many-to-one name="CurrentEstimator" class="DqeUser" column="CurrentEstimatorId" not-null="false"/>
    <property name="Comment" not-null="false" length="500" />
    <property name="WtId" not-null="true"/>
    <property name="ProposalSource" not-null="true"/>
    <property name="Created" not-null="true"/>
    <property name="LastUpdated" not-null="true"/>
    <property name="Description" not-null="false"/>
    <property name="LettingDate" not-null="false" />
    <property name="District" not-null="false" length="256" />
    <set name="ProjectVersions" lazy="true" inverse="true" cascade="all-delete-orphan" access="field.camelcase-underscore" >
      <key column="ProposalId"/>
      <one-to-many class="ProjectVersion"/>
    </set>
    <set name="Projects" lazy="true" inverse="true" cascade="save-update" access="field.camelcase-underscore" table="ProposalProjects">
      <key column="ProposalId"/>
      <many-to-many class="Project" column="ProjectId"/>
    </set>
    <set name="SectionGroups" lazy="true" inverse="true" cascade="all-delete-orphan" access="field.camelcase-underscore">
      <key column="ProposalId"/>
      <one-to-many class="SectionGroup"/>
    </set>
  </class>
</hibernate-mapping>