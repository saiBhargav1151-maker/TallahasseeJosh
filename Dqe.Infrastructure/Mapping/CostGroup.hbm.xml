<?xml version="1.0" encoding="utf-8" ?>
<!-- MAKE SURE THIS FILE IS AN EMBEDDED RESOURCE -->
<hibernate-mapping xmlns="urn:nhibernate-mapping-2.2" assembly="Dqe.Domain" namespace="Dqe.Domain.Model">
  <class name="CostGroup" table="CostGroup">
    <id name="Id">
      <generator class="identity" />
    </id>
    <property name="Name" not-null="true" length="20"/>
    <property name="Description" not-null="true" length="256" />
    <property name="Unit" not-null="true" length="20" />
    <set name="PayItems" lazy="true" inverse="true" cascade="all-delete-orphan" access="field.camelcase-underscore" >
      <key column="CostGroupId"/>
      <one-to-many class="CostGroupPayItem"/>
    </set>
  </class>
</hibernate-mapping>