<?xml version="1.0" encoding="utf-8" ?>
<!-- MAKE SURE THIS FILE IS AN EMBEDDED RESOURCE -->
<hibernate-mapping xmlns="urn:nhibernate-mapping-2.2" assembly="Dqe.Domain" namespace="Dqe.Domain.Model">
  <class name="PricingParameter" abstract="true" table="PricingParameter">
    <id name="Id">
      <generator class="sequence">
        <param name="sequence">SQ_PricingParameter</param>
      </generator>
    </id>
    <discriminator>
      <column name="type" sql-type="char(2)" not-null="true"/>
    </discriminator>
    <property name="Months">
      <column name="Months" not-null="true"/>
    </property>
    <property name="ContractType">
      <column name="ContractType" not-null="true"/>
    </property>
    <property name="Quantities">
      <column name="Quantities" not-null="true"/>
    </property>
    <property name="PricingModel">
      <column name="PricingModel" not-null="true"/>
    </property>
    <property name="Bidders">
      <column name="Bidders" not-null="true"/>
    </property>
    <set name="WorkTypes" lazy="false" access="field.camelcase-underscore" table="PricingParametersWorkTypes">
      <key column="WorkTypeId"/>
      <element column="Value" type="Int32"></element>
    </set>
    <subclass discriminator-value="SD" name="StatewidePricingParameter">
    </subclass>
    <subclass discriminator-value="DD" name="DistrictPricingParameter">
      <property name="District">
        <column name="District" sql-type="char(2)" not-null="false"/>
      </property>
    </subclass>
    <subclass discriminator-value="ED" name="EstimatorPricingParameter">
      <many-to-one name="User" column="UserId" />
    </subclass>
  </class>
</hibernate-mapping>