<?xml version="1.0" encoding="utf-8" ?>
<!-- MAKE SURE THIS FILE IS AN EMBEDDED RESOURCE -->
<hibernate-mapping xmlns="urn:nhibernate-mapping-2.2" assembly="Dqe.Domain" namespace="Dqe.Domain.Model">
  <class name="ProjectItem" table="DQET026_PROJ_ITM">
    <id name="Id" column="PROJ_ITM_SQ">
      <generator class="sequence">
        <param name="sequence">DQEQ026_PROJ_ITM</param>
      </generator>
    </id>
    <many-to-one name="MyEstimateGroup" column="CAT_SQ" not-null="true"/>
    <many-to-one name="MyProposalItem" column="PRPOS_ITM_SQ" not-null="false"/>
    <property name="WtId">
      <column name="TRNSP_SYS_NUM" not-null="true"/>
    </property>
    <property name="Quantity">
      <column name="QTY_NUM" sql-type="decimal(12, 3)" not-null="true"/>
    </property>
    <property name="Price">
      <column name="PRCE_NUM" sql-type="decimal(16, 5)" not-null="true"/>
    </property>
    <property name="PreviousPrice">
      <column name="PREV_PRCE_NUM" sql-type="decimal(16, 5)" not-null="false"/>
    </property>
    <property name="PublicPrice">
      <column name="PUB_PRCE_NUM" sql-type="decimal(16, 5)" not-null="true"/>
    </property>
    <property name="PriceSet">
      <column name="PRCE_TYP_NUM" not-null="true"/>
    </property>
    <property name="PayItemNumber" type="AnsiString">
      <column name="ITM_NM" sql-type="varchar(20)" not-null="false"/>
    </property>
    <property name="PayItemDescription" type="AnsiString">
      <column name="ITM_DS" sql-type="varchar(256)" not-null="false"/>
    </property>
    <property name="CalculatedUnit" type="AnsiString">
      <column name="UNIT_DS" sql-type="varchar(280)" not-null="true"/>
    </property>
    <property name="Unit" type="AnsiString">
      <column name="UNIT_TXT" sql-type="varchar(10)" not-null="true"/>
    </property>
    <property name="CombineWithLikeItems" type="Dqe.Infrastructure.Types.BoolType, Dqe.Infrastructure">
      <column name="CMB_CD" sql-type="char(1)" not-null="true"/>
    </property>
    <property name="AlternateSet" type="AnsiString">
      <column name="ALT_SET_TXT" sql-type="varchar(20)" not-null="true"/>
    </property>
    <property name="AlternateMember" type="AnsiString">
      <column name="ALT_MBR_TXT" sql-type="varchar(20)" not-null="true"/>
    </property>
    <property name="SupplementalDescription" type="AnsiString">
      <column name="SPLMNT_DS" sql-type="varchar(256)" not-null="true"/>
    </property>
    <property name="Fund" type="AnsiString">
      <column name="FND_TXT" sql-type="varchar(20)" not-null="true"/>
    </property>
    <!--<property name="BidHistoryMonthRange">
      <column name="BidHistoryMonthRange" not-null="true"/>
    </property>-->
    <property name="ProposalItemId" insert="false" update="false">
      <column name="PRPOS_ITM_SQ" not-null="false"/>
    </property>
  </class>
</hibernate-mapping>