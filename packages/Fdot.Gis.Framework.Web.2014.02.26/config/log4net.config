<?xml version="1.0"?>
<log4net>
  <root>
    <level value="ALL" />
    <appender-ref ref="LossySmtpAppender" />
    <appender-ref ref="trace" />
    
    <!--<level value="INFO" />-->
    <!--<appender-ref ref="trace" />
    <appender-ref ref="exception" />-->
  </root>
  
  <logger name="default">
    <level value="ALL" />
    <appender-ref ref="LossySmtpAppender" />
    <appender-ref ref="trace" />
  </logger>

  <appender name="trace" type="log4net.Appender.RollingFileAppender">
    <file value="gisframework.log" />
    <appendToFile value="true" />
    <rollingStyle value="Date" />
    <datePattern value=" yyyy-MM-dd+HH'.log'" />
    <layout type="log4net.Layout.PatternLayout">
      <conversionPattern value="%date [%thread] %-5level %message%newline" />
      <conversionPattern value="%date [%thread] %-5level %logger :: %property{signature} &gt; %message%newline" />
    </layout>
  </appender>
  
  <appender name="SmtpAppender" type="log4net.Appender.SmtpAppender">
    <to value="CO-EntGIS-Dev@dot.state.fl.us" />
    <from value="CO-EntGIS-Dev@dot.state.fl.us" />
    <subject value="CRITICAL: Error message from GIS Framework" />
    <smtpHost value="mail.co.dot.state.fl.us" />
    <layout type="log4net.Layout.PatternLayout">
      <conversionPattern value="%date [%thread] %-5level %message%newline" />
      <conversionPattern value="%date [%thread] %-5level %logger :: %property{signature} &gt; %message%newline" />
    </layout>
  </appender>

  <appender name="LossySmtpAppender" type="log4net.Appender.BufferingForwardingAppender">
    <bufferSize value="1000" />
    <lossy value="true"/>
    <evaluator type="log4net.Core.LevelEvaluator">
      <threshold value="ERROR" />
    </evaluator>
    <appender-ref ref="SmtpAppender" />
  </appender>

</log4net>
