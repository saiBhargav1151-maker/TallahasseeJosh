<?xml version="1.0"?>
<!-- This file is just a token that IIS can monitor for changes if it's set as the target
of a configSource attribute in web.config. Adding its path in the appSettings section with 
the key "recycleTokenPath" will cause the FileWatcherManager to use this file for touches
instead of web.config.  This is a little safer, since the touch requires write permissions.
This file name is a guid to provide a little extra safety. -->
<recycleToken></recycleToken>