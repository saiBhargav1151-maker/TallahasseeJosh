<configuration>
  <configSections>
    <section name="frameworkConfig" type="FDOT.GIS.Web.Configuration.GisFrameworkConfigurationSection, FDOT.GIS.Web" restartOnExternalChanges="true"/>
    <section name="log4net" type="log4net.Config.Log4NetConfigurationSectionHandler, log4net"/>
    <section name="recycleToken" type="System.Configuration.NameValueFileSectionHandler" restartOnExternalChanges="true"/>
  </configSections>
  <frameworkConfig>
    <virtualApplications>
      <virtualApplication initialExtent="-9826373.649,3704108.612,-8689284.583,2780875.748" name="default"
                          logoImage="http://gis.dot.state.fl.us/gisframework/images/dotlogo.png" authType="None"
                          title="FDOT GIS Framework" helpText="This is example is built on the FDOT Enterprise GIS Framework, using the services and components available through the GIS Enterprise View.  For details on the components included, please refer to the help provided at [^http://cbtsystest.dot.state.fl.us/ois/GEVCBTs/|GIS Enterprise View System Tools]."
                          isDefault="true">
        <mapServices sourceConfig="config\virtualApplications\default\mapservices.config"/>
        <components sourceConfig="config\virtualApplications\default\components.config"/>
        <commands sourceConfig="config\virtualApplications\default\commands.config"/>
        <featureActions sourceConfig="config\virtualApplications\default\featureActions.config"/>
        <dataVisualizers sourceConfig="config\virtualApplications\default\dataVisualizers.config"/>
        <dataExporters sourceConfig="config\virtualApplications\default\dataExporters.config"/>
      </virtualApplication>
    </virtualApplications>
  </frameworkConfig>
  <!--  This is an empty section that we're using to recycle the app on config changes.
        Modifying a file's last update to effect a touch requires write permissions, so this is a
        safer alternative to touching web.config.
  -->
  <recycleToken configSource="config\F10C0F35-7742-45E8-A5FF-E65B9869FABB.config"/>
  <log4net configSource="config\log4net.config"/>
  <appSettings>
    <add key="arcgisServer" value="gis.dot.state.fl.us"/>
    <add key="proxyServer" value="http://proxy.dot.state.fl.us"/>
    <!-- DotEnvironmentProvider = [Production | SystemTest | UnitTest | WorkstationOrUnknown] NOT case sensitive -->
    <add key="environmentProvider" value="FDOT.GIS.Web.Core.DotEnvironmentProvider, FDOT.GIS.Web"/>
    <!--  The path to the recycle token, so the file watcher can use it for touches.
          If this isn't specified, then web.config will be used.  Write permissions are required on the file to be touched.
    -->
    <add key="recycleTokenPath" value="config\F10C0F35-7742-45E8-A5FF-E65B9869FABB.config"/>
    <add key="DiscoveryProxies" value=""/>
    <add key="HostAddress" value="interdev.dot.state.fl.us"/>
    <add key="internetServer" value="dotintwww02k8.dot.state.fl.us"/>
  </appSettings>
  <system.webServer>
    <modules runAllManagedModulesForAllRequests="true">
      <add name="DomainServiceModule" preCondition="managedHandler" type="System.ServiceModel.DomainServices.Hosting.DomainServiceHttpModule, System.ServiceModel.DomainServices.Hosting, Version=4.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35"/>
    </modules>
    <handlers>
      <add name="ScriptResourceHandler" path="*.js" verb="GET" type="FDOT.GIS.Web.Scripts.ScriptResourceHandler"/>
    </handlers>
    <validation validateIntegratedModeConfiguration="false"/>
  </system.webServer>
  <system.web>
    <authentication mode="Forms"/>
    <membership defaultProvider="Racf">
      <providers>
        <clear/>
        <add name="Racf" type="FDOT.GIS.Web.Security.RACFMembershipProvider, FDOT.GIS.Web"/>
        <add name="InternetSubscriberAccount" type="FDOT.Enterprise.Architecture.Security.InternetSubscriberAccount.ISAMembershipProvider, FDOT.Enterprise.Architecture.Security.InternetSubscriberAccount, Version=2.0.0.0, Culture=neutral, PublicKeyToken=a11df4d9086030a8"/>
        <add name="ActiveDirectory" type="FDOT.GIS.Web.Security.ActiveDirectoryMembershipProvider, FDOT.GIS.Web"/>
      </providers>
    </membership>
    <roleManager enabled="true" defaultProvider="default">
      <providers>
        <add name="default" type="FDOT.GIS.Web.Security.MultiRoleProvider, FDOT.GIS.Web"/>
      </providers>
    </roleManager>
    <httpModules>
      <add name="DomainServiceModule" type="System.ServiceModel.DomainServices.Hosting.DomainServiceHttpModule, System.ServiceModel.DomainServices.Hosting, Version=4.0.0.0, Culture=neutral, PublicKeyToken=31bf3856ad364e35"/>
    </httpModules>
    <httpHandlers>
      <add path="*.js" verb="GET" type="FDOT.GIS.Web.Scripts.ScriptResourceHandler, FDOT.GIS.Web"/>
    </httpHandlers>
    <compilation targetFramework="4.0" debug="true">
      <assemblies>
        <add assembly="FDOT.Enterprise.Architecture.Security, Version=2.0.0.0, Culture=neutral, PublicKeyToken=A11DF4D9086030A8"/>
        <add assembly="FDOT.Enterprise.Architecture.Web.Security, Version=2.0.0.0, Culture=neutral, PublicKeyToken=A11DF4D9086030A8"/>
        <add assembly="FDOT.Enterprise.Architecture.Web.UserControl, Version=2.0.0.0, Culture=neutral, PublicKeyToken=A11DF4D9086030A8"/>
      </assemblies>
    </compilation>
    <customErrors mode="Off"/>
    <httpRuntime maxRequestLength="2147483647"/>
  </system.web>
  <system.serviceModel>
    <client>
      <endpoint address="http://gis.dot.state.fl.us/ArcGIS/services/GEV_DMS/MapServer" binding="basicHttpBinding" bindingConfiguration="MapServerBinding" contract="ESRI.Soap.MapServerPort" name="MapServerPort"/>
      <endpoint address="http://gis.dot.state.fl.us/ArcGIS/services/Geometry/GeometryServer" binding="basicHttpBinding" bindingConfiguration="GeometryServerBinding" contract="ESRI.SoapGeometry.GeometryServerPort" name="GeometryServerPort"/>
    </client>
    <services>
      <service name="FDOT.GIS.Web.Services.ConfigurationService" behaviorConfiguration="default">
        <endpoint address="" binding="basicHttpBinding" bindingConfiguration="BasicHttpBinding" contract="FDOT.GIS.Web.Services.IConfigurationService"/>
      </service>
      <service name="FDOT.GIS.Web.Services.QueryService" behaviorConfiguration="default">
        <endpoint address="" binding="basicHttpBinding" bindingConfiguration="BasicHttpBinding" contract="FDOT.GIS.Web.Services.IQueryService"/>
      </service>
      <service name="FDOT.GIS.Web.Services.GeometryService" behaviorConfiguration="default">
        <endpoint address="" binding="basicHttpBinding" bindingConfiguration="BasicHttpBinding" contract="FDOT.GIS.Web.Services.IGeometryService"/>
      </service>
      <service name="FDOT.GIS.Web.Services.PrintMapService" behaviorConfiguration="default">
        <endpoint address="" binding="basicHttpBinding" bindingConfiguration="BasicHttpBinding" contract="FDOT.GIS.Web.Services.IPrintMapService"/>
      </service>
      <service name="FDOT.GIS.Web.Services.DotcodesService" behaviorConfiguration="default">
        <endpoint address="" binding="basicHttpBinding" bindingConfiguration="BasicHttpBinding" contract="FDOT.GIS.Web.Services.IDotcodesService"/>
      </service>
      <service name="FDOT.GIS.Web.Services.LoggingService" behaviorConfiguration="default">
        <endpoint address="" binding="basicHttpBinding" bindingConfiguration="BasicHttpBinding" contract="FDOT.GIS.Web.Services.ILoggingService"/>
      </service>
      <service name="FDOT.GIS.Web.Services.ContentService" behaviorConfiguration="default">
        <endpoint address="" binding="basicHttpBinding" bindingConfiguration="BasicHttpBinding" contract="FDOT.GIS.Web.Services.IContentService"/>
      </service>
      <service name="FDOT.GIS.Web.Services.IconService" behaviorConfiguration="default">
        <endpoint address="" binding="basicHttpBinding" bindingConfiguration="BasicHttpBinding" contract="FDOT.GIS.Web.Services.IIconService"/>
      </service>
      <service name="FDOT.GIS.Web.Services.InventoryService" behaviorConfiguration="default">
        <endpoint address="" binding="basicHttpBinding" bindingConfiguration="BasicHttpBinding" contract="FDOT.GIS.Web.Services.IInventoryService"/>
      </service>
    </services>
    <bindings>
      <basicHttpBinding>
        <binding name="BasicHttpBinding" receiveTimeout="00:05:00" sendTimeout="00:05:00" maxBufferSize="2147483647" maxReceivedMessageSize="2147483647">
          <readerQuotas maxDepth="2147483647" maxStringContentLength="2147483647" maxArrayLength="2147483647" maxBytesPerRead="2147483647" maxNameTableCharCount="2147483647"/>
          <security mode="None"/>
        </binding>
        <binding name="SecureHttpBinding" receiveTimeout="00:05:00" sendTimeout="00:05:00" maxBufferSize="2147483647" maxReceivedMessageSize="2147483647">
          <readerQuotas maxDepth="2147483647" maxStringContentLength="2147483647" maxArrayLength="2147483647" maxBytesPerRead="2147483647" maxNameTableCharCount="2147483647"/>
          <security mode="Transport"/>
        </binding>
        <binding name="MapServerBinding" closeTimeout="00:01:00" openTimeout="00:01:00" receiveTimeout="00:10:00" sendTimeout="00:01:00" allowCookies="false" bypassProxyOnLocal="false" hostNameComparisonMode="StrongWildcard" maxBufferSize="65536" maxBufferPoolSize="524288" maxReceivedMessageSize="65536" messageEncoding="Text" textEncoding="utf-8" transferMode="Buffered" useDefaultWebProxy="true">
          <readerQuotas maxDepth="32" maxStringContentLength="8192" maxArrayLength="16384" maxBytesPerRead="4096" maxNameTableCharCount="16384"/>
          <security mode="None">
            <transport clientCredentialType="None" proxyCredentialType="None" realm=""/>
            <message clientCredentialType="UserName" algorithmSuite="Default"/>
          </security>
        </binding>
        <binding name="GeometryServerBinding" closeTimeout="00:01:00" openTimeout="00:01:00" receiveTimeout="00:10:00" sendTimeout="00:01:00" allowCookies="false" bypassProxyOnLocal="false" hostNameComparisonMode="StrongWildcard" maxBufferSize="65536" maxBufferPoolSize="524288" maxReceivedMessageSize="65536" messageEncoding="Text" textEncoding="utf-8" transferMode="Buffered" useDefaultWebProxy="true">
          <readerQuotas maxDepth="32" maxStringContentLength="8192" maxArrayLength="16384" maxBytesPerRead="4096" maxNameTableCharCount="16384"/>
          <security mode="None">
            <transport clientCredentialType="None" proxyCredentialType="None" realm=""/>
            <message clientCredentialType="UserName" algorithmSuite="Default"/>
          </security>
        </binding>
      </basicHttpBinding>
    </bindings>
    <behaviors>
      <serviceBehaviors>
        <behavior name="default">
          <serviceMetadata httpGetEnabled="true" httpsGetEnabled="true"/>
          <serviceDebug includeExceptionDetailInFaults="true"/>
          <dataContractSerializer maxItemsInObjectGraph="2147483647"/>
          <useRequestHeadersForMetadataAddress/>
        </behavior>
        <behavior name="">
          <serviceMetadata httpGetEnabled="true" httpsGetEnabled="true"/>
          <serviceDebug includeExceptionDetailInFaults="false"/>
          <dataContractSerializer maxItemsInObjectGraph="2147483647"/>
          <useRequestHeadersForMetadataAddress/>
