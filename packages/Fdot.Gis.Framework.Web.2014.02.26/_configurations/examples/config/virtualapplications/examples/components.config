<?xml version="1.0"?>
<components>

  <!-- 
    The following are components included in the GIS Enterprise View application, but which can also be included in your own
    customized virtual application. 
  -->
  <component name="Map Layers" type="FDOT.GIS.Client.Components.ViewModels.TocViewModel, FDOT.GIS.Client.Components, Version=1.0.0.0" xapuri="FDOT.GIS.Client.Components.xap" helpText="Switch basemaps or turn data layers on or off" hotkey="T" >
    <customSettings>
      <add name="CanAddLayers" value ="true" />
    </customSettings>
  </component>
  <!-- Sample components -->
  <component name="My Component" type="FDOT.GIS.Framework.Examples.ViewModels.MyComponentViewModel, FDOT.GIS.Framework.Examples, Version=1.0.0.0" xapuri="FDOT.GIS.Framework.Examples.xap" helpText="My Component" />
  <component name="Query By Address" type="FDOT.GIS.Framework.Examples.ViewModels.QueryByAddressViewModel, FDOT.GIS.Framework.Examples, Version=1.0.0.0"
             xapuri="FDOT.GIS.Framework.Examples.xap"
             helpText="Query By Address">
    <customSettings>
      <add name="DefaultAddress" value="605 Suwannee Street" />
      <add name="DefaultCity" value ="Tallahassee" />
      <add name="DefaultBufferRadius" value ="2" />
      <add name="DefaultBufferUnit" value ="Miles" />
    </customSettings>
  </component>
  <component name="Service Example" type="FDOT.GIS.Framework.Examples.ViewModels.ServiceExampleViewModel, FDOT.GIS.Framework.Examples, Version=1.0.0.0" xapuri="FDOT.GIS.Framework.Examples.xap" helpText="Service Example">
    <customSettings>
      <add name="servicePath" value="Services/ContentService.svc" />
    </customSettings>
  </component>
</components>
