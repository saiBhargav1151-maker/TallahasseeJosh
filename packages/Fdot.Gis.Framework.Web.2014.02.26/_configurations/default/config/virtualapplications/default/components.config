<?xml version="1.0"?>
<components>
  <component name="Map Layers" type="FDOT.GIS.Client.Components.ViewModels.TocViewModel, FDOT.GIS.Client.Components, Version=1.0.0.0" xapuri="FDOT.GIS.Client.Components.xap" helpText="Switch basemaps or turn data layers on or off" hotkey="T" >
    <customSettings>
      <add name="CanAddLayers" value ="true" />
    </customSettings>
  </component>
  <component name="Identify" type="FDOT.GIS.Client.Components.ViewModels.IdentifyViewModel, FDOT.GIS.Client.Components, Version=1.0.0.0" xapuri="FDOT.GIS.Client.Components.xap" helpText="Identify map feature" hotkey="I"/>
  <component name="Query" type="FDOT.GIS.Client.Components.ViewModels.QueryTool.QueryViewModel, FDOT.GIS.Client.Components, Version=1.0.0.0" xapuri="FDOT.GIS.Client.Components.xap" helpText="Query map layers" hotkey="Q" />
  <component name="Measure" type="FDOT.GIS.Client.Components.ViewModels.MeasureTool.MeasureToolViewModel, FDOT.GIS.Client.Components, Version=1.0.0.0" xapuri="FDOT.GIS.Client.Components.xap" helpText="Measure distances on the map" hotkey="M" />
  <component name="Draw" type="FDOT.GIS.Client.Components.ViewModels.DrawToolViewModel, FDOT.GIS.Client.Components, Version=1.0.0.0" xapuri="FDOT.GIS.Client.Components.xap" helpText="Draw geometry on the map" hotkey="D"/>
  <component name="Address Lookup" type="FDOT.GIS.Client.Components.ViewModels.AddressLookupTool.AddressLookupViewModel, FDOT.GIS.Client.Components, Version=1.0.0.0" xapuri="FDOT.GIS.Client.Components.xap" helpText="Locate Florida addresses" hotkey="A" />
  <component name="Zoom" type="FDOT.GIS.Client.Components.ZoomToBoxComponent, FDOT.GIS.Client.Components, Version=1.0.0.0" xapuri="FDOT.GIS.Client.Components.xap" helpText="Zoom to selected region" />
  <component name="Zoom To Feature" type="FDOT.GIS.Client.Components.ViewModels.ZoomToViewModel, FDOT.GIS.Client.Components, Version=1.0.0.0" xapuri="FDOT.GIS.Client.Components.xap" helpText="Zoom to specified map features" hotkey="Z"/>
  <component name="Get Coordinates" type="FDOT.GIS.Client.Components.ViewModels.CoordinatesViewModel, FDOT.GIS.Client.Components, Version=1.0.0.0" xapuri="FDOT.GIS.Client.Components.xap" helpText="Get lat/long coordinates" hotkey="C">
    <customSettings>
      <add name="Projections" value ="3087:Albers,102100:Web Mercator" />
    </customSettings>
  </component>
  
  <component name="Zoom To Coordinates" type="FDOT.GIS.Client.Components.ZoomToCoordinatesComponent, FDOT.GIS.Client.Components, Version=1.0.0.0" xapuri="FDOT.GIS.Client.Components.xap" helpText="Zoom to lat/long coordinates" />
  <!--<component name="Command Window" type="FDOT.GIS.SampleComponent.CommandProcessor" xapuri="FDOT.GIS.SampleComponent.xap" helpText="help" />-->
  <component name="Print" type="FDOT.GIS.Client.ViewModels.Printing.PrintPreviewViewModel, FDOT.GIS.Client, Version=1.0.0.0"
             xapuri="FDOT.GIS.Client.xap"
             helpText="Print the current map view"
             hotkey="P"/>
  <!--<component name="Previous Extent" type="FDOT.GIS.Client.Components.PreviousExtentComponent" xapuri="" helpText="Go to Previous Extent" />-->
  <!--<component name="Next Extent" type="FDOT.GIS.Client.Components.NextExtentComponent" xapuri="" helpText="Go to Next Extent" />-->
  <component name="Bookmark Extent" type="FDOT.GIS.Client.Components.ViewModels.BookmarkExtentViewModel, FDOT.GIS.Client.Components, Version=1.0.0.0" xapuri="FDOT.GIS.Client.Components.xap" helpText="Bookmark the current extent" />
</components>
