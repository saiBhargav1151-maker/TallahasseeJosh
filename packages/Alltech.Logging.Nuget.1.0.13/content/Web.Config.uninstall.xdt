<?xml version="1.0"?>
<configuration xmlns:xdt="http://schemas.microsoft.com/XML-Document-Transform">
  <appSettings>
	<add key="SendPostEmails" value="false" xdt:Transform="Remove" xdt:Locator="Match(key)"/>
    <add key="SendUsageEmails" value="false" xdt:Transform="Remove" xdt:Locator="Match(key)"/>
	<add key="LogUsageToMessageBus" value="true" xdt:Transform="Remove" xdt:Locator="Match(key)" />
    <add key="LogPostsToMessageBus" value="true" xdt:Transform="Remove" xdt:Locator="Match(key)"/>
	<add key="SendPostEmailsToAddresses" value="" xdt:Transform="Remove" xdt:Locator="Match(key)"/>
    <add key="SendUsageEmailsToAddresses" value="" xdt:Transform="Remove" xdt:Locator="Match(key)"/>
	<add key="ApplicationAcronym" value="" xdt:Transform="Remove" xdt:Locator="Match(key)"/>
    <add key="Microsoft.ServiceBus.ConnectionString" xdt:Transform="Remove" xdt:Locator="Match(key)"/>
  </appSettings>
  <system.net>
    <defaultProxy>
      <proxy usesystemdefault="true" proxyaddress="http://proxy.dot.state.fl.us" xdt:Transform="Remove"/>
    </defaultProxy>
  </system.net>
  <system.web>
    <httpModules>
      <!-- Pre IIS 7 or IIS 7 in Classic Mode -->
      <add name="ExceptionHandlerModule" type="Alltech.Logging.ExceptionHandlerModule, Alltech.Logging" xdt:Transform="Remove" xdt:Locator="Match(name)"/>
    </httpModules>
  </system.web>
  <system.webServer>
    <modules>
      <!-- IIS 7 in Integrated Mode -->
      <add name=" ExceptionHandlerModule" type="Alltech.Logging.ExceptionHandlerModule, Alltech.Logging" xdt:Transform="Remove" xdt:Locator="Match(name)"/>
    </modules>
  </system.webServer>
</configuration>