<configuration>
  <system.web>
      <httpModules>
          <!-- Pre IIS 7 or IIS 7 in Classic Mode -->
          <add name="AjaxExceptionHandler" type="AjaxExceptionOnErrorModule.OnErrorModule, AjaxExceptionOnErrorModule"/>
      </httpModules>
  </system.web>

  <system.webServer>
      <modules>
          <!-- IIS 7 in Integrated Mode -->
          <add name="AjaxExceptionHandler" type="AjaxExceptionOnErrorModule.OnErrorModule, AjaxExceptionOnErrorModule"/>
      </modules>
  </system.webServer>
</configuration>