<?xml version="1.0" encoding="utf-8"?>
<Report xmlns="http://schemas.microsoft.com/sqlserver/reporting/2016/01/reportdefinition" xmlns:rd="http://schemas.microsoft.com/SQLServer/reporting/reportdesigner">
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="DQE">
      <DataSourceReference>DQE</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>4e63ff8a-e255-4d96-88ce-3244e3774e3a</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DQE</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ProjectNumber">
            <Value>=Parameters!ProjectNumber.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT        pj.ESTM_INIT_AMT AS Estimate, 'Initial Estimate' AS ProposalLevel, 1 AS ColumnOrder
FROM            DQET020_PROJ AS pj LEFT OUTER JOIN
                         DQET033_RPT_PROJ AS repproj ON pj.PROJ_NM = repproj.PROJ_NM AND repproj.RPT_PROJ_SQ = 1 LEFT OUTER JOIN
                         DQET033_RPT_PROJ AS repproj2 ON pj.PROJ_NM = repproj2.PROJ_NM AND repproj2.RPT_PROJ_SQ = 2
WHERE        (pj.PROJ_NM = @ProjectNumber)
UNION
SELECT        pj.ESTM_SCOP_AMT AS Estimate, 'Scope Estimate' AS ProposalLevel, 2 AS ColumnOrder
FROM            DQET020_PROJ AS pj LEFT OUTER JOIN
                         DQET033_RPT_PROJ AS repproj ON pj.PROJ_NM = repproj.PROJ_NM AND repproj.RPT_PROJ_SQ = 1 LEFT OUTER JOIN
                         DQET033_RPT_PROJ AS repproj2 ON pj.PROJ_NM = repproj2.PROJ_NM AND repproj2.RPT_PROJ_SQ = 2
WHERE        (pj.PROJ_NM = @ProjectNumber)
UNION
SELECT        pj.ESTM_PHAS_1_AMT AS Estimate, 'Phase 1' AS ProposalLevel, 3 AS ColumnOrder
FROM            DQET020_PROJ AS pj LEFT OUTER JOIN
                         DQET033_RPT_PROJ AS repproj ON pj.PROJ_NM = repproj.PROJ_NM AND repproj.RPT_PROJ_SQ = 1 LEFT OUTER JOIN
                         DQET033_RPT_PROJ AS repproj2 ON pj.PROJ_NM = repproj2.PROJ_NM AND repproj2.RPT_PROJ_SQ = 2
WHERE        (pj.PROJ_NM = @ProjectNumber)
UNION
SELECT        pj.ESTM_PHAS_2_AMT AS Estimate, 'Phase 2' AS ProposalLevel, 4 AS ColumnOrder
FROM            DQET020_PROJ AS pj LEFT OUTER JOIN
                         DQET033_RPT_PROJ AS repproj ON pj.PROJ_NM = repproj.PROJ_NM AND repproj.RPT_PROJ_SQ = 1 LEFT OUTER JOIN
                         DQET033_RPT_PROJ AS repproj2 ON pj.PROJ_NM = repproj2.PROJ_NM AND repproj2.RPT_PROJ_SQ = 2
WHERE        (pj.PROJ_NM = @ProjectNumber)
UNION
SELECT        pj.ESTM_PHAS_3_AMT AS Estimate, 'Phase 3' AS ProposalLevel, 5 AS ColumnOrder
FROM            DQET020_PROJ AS pj LEFT OUTER JOIN
                         DQET033_RPT_PROJ AS repproj ON pj.PROJ_NM = repproj.PROJ_NM AND repproj.RPT_PROJ_SQ = 1 LEFT OUTER JOIN
                         DQET033_RPT_PROJ AS repproj2 ON pj.PROJ_NM = repproj2.PROJ_NM AND repproj2.RPT_PROJ_SQ = 2
WHERE        (pj.PROJ_NM = @ProjectNumber)
UNION
SELECT        pj.ESTM_PHAS_4_AMT AS Estimate, 'Phase 4' AS ProposalLevel, 6 AS ColumnOrder
FROM            DQET020_PROJ AS pj LEFT OUTER JOIN
                         DQET033_RPT_PROJ AS repproj ON pj.PROJ_NM = repproj.PROJ_NM AND repproj.RPT_PROJ_SQ = 1 LEFT OUTER JOIN
                         DQET033_RPT_PROJ AS repproj2 ON pj.PROJ_NM = repproj2.PROJ_NM AND repproj2.RPT_PROJ_SQ = 2
WHERE        (pj.PROJ_NM = @ProjectNumber)
UNION
SELECT        repproj.TOT_AMT AS Estimate, 'Authorization' AS ProposalLevel, 7 AS ColumnOrder
FROM            DQET020_PROJ AS pj LEFT OUTER JOIN
                         DQET033_RPT_PROJ AS repproj ON pj.PROJ_NM = repproj.PROJ_NM AND repproj.RPT_PROJ_SQ = 1 LEFT OUTER JOIN
                         DQET033_RPT_PROJ AS repproj2 ON pj.PROJ_NM = repproj2.PROJ_NM AND repproj2.RPT_PROJ_SQ = 2
WHERE        (pj.PROJ_NM = @ProjectNumber)
UNION
SELECT        repproj2.TOT_AMT AS Estimate, 'Official' AS ProposalLevel, 8 AS ColumnOrder
FROM            DQET020_PROJ AS pj LEFT OUTER JOIN
                         DQET033_RPT_PROJ AS repproj ON pj.PROJ_NM = repproj.PROJ_NM AND repproj.RPT_PROJ_SQ = 1 LEFT OUTER JOIN
                         DQET033_RPT_PROJ AS repproj2 ON pj.PROJ_NM = repproj2.PROJ_NM AND repproj2.RPT_PROJ_SQ = 2
WHERE        (pj.PROJ_NM = @ProjectNumber)
UNION
SELECT        repproj2.TOT_AMT AS Estimate, 'Review' AS ProposalLevel, 9 AS ColumnOrder
FROM            DQET020_PROJ AS pj LEFT OUTER JOIN
                         DQET033_RPT_PROJ AS repproj ON pj.PROJ_NM = repproj.PROJ_NM AND repproj.RPT_PROJ_SQ = 1 LEFT OUTER JOIN
                         DQET033_RPT_PROJ AS repproj2 ON pj.PROJ_NM = repproj2.PROJ_NM AND repproj2.RPT_PROJ_SQ = 2
WHERE        (pj.PROJ_NM = @ProjectNumber)</CommandText>
      </Query>
      <Fields>
        <Field Name="Estimate">
          <DataField>Estimate</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="ProposalLevel">
          <DataField>ProposalLevel</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ColumnOrder">
          <DataField>ColumnOrder</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
