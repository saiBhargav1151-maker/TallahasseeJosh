  <DataSources>
    <DataSource Name="DQE">
      <DataSourceReference>DQE</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>397a78e9-95b4-45b4-9267-bf3fe4479caf</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="AB_Milestone">
      <Query>
        <DataSourceName>DQE</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ProposalNumber">
            <Value>=Parameters!ProposalNumber.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ProposalLevel">
            <Value>=Parameters!ProposalLevel.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT        rpm.RPT_MLSTN_SQ AS Id, rpm.MLSTN_DS AS Description, rpm.UNIT_TXT AS Unit, rpm.DY_NUM AS ConstructionDays, rpm.DY_CST_NUM AS CostPerDay, rpm.TOT_NUM AS Total, 
                         rpm.RPT_PRPOS_SQ AS ReportProposalId
FROM            DQET036_RPT_PROPOS AS rp INNER JOIN
                         DQET038_RPT_MLSTN AS rpm ON rp.RPT_PRPOS_SQ = rpm.RPT_PRPOS_SQ
WHERE        (rp.PRPOS_NM = @ProposalNumber) AND (rp.PRPOS_LVL_NUM = @ProposalLevel)</CommandText>
      </Query>
      <Fields>
        <Field Name="Id">
          <DataField>Id</DataField>
          <rd:TypeName>System.Int64</rd:TypeName>
        </Field>
        <Field Name="Description">
          <DataField>Description</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Unit">
          <DataField>Unit</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ConstructionDays">
          <DataField>ConstructionDays</DataField>
          <rd:TypeName>System.Int64</rd:TypeName>
        </Field>
        <Field Name="CostPerDay">
          <DataField>CostPerDay</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="Total">
          <DataField>Total</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
