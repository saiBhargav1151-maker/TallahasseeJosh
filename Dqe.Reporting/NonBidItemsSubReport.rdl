  <DataSources>
    <DataSource Name="DQE">
      <DataSourceReference>DQE</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>445b84f6-dc9d-4870-acaa-1fa74fa9918f</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="FHP">
      <Query>
        <DataSourceName>DQE</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ProposalNumber">
            <Value>=Parameters!ProposalNumber.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ProposalLevel">
            <Value>=Parameters!ProposalLevel.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT        rp.PROJ_DS AS ProjectDescription, rp.LET_DT AS LettingDate, rp.TOT_AMT AS ProjectTotal, rpi.ITM_NM AS ItemNumber, rpi.ITM_DS AS ProjectItemDescription, rpi.WRK_CLS_TXT AS WorkClass, 
                         rpi.TECH_SPEC_TXT AS TechSpec, rpi.NO_BID_CD AS DoNotBid, rpi.ITM_ALT_SET_TXT AS ItemAlternateSet, rpi.ITM_ALT_MBR_TXT AS ItemAlternateMember, rpi.LOW_CST_CD AS IsLowCost, 
                         rpi.UNIT_TXT AS Unit, rpi.QTY_NUM AS Quantity, rpi.PRCE_AMT AS Price, rpi.OBSLT_DT AS ObsoleteDate, rpi.OBSLT_CD AS IsObsolete, rpi.TOT_AMT AS ProjectItemTotal, rpi.RPT_CAT_SQ AS ReportCategoryId, 
                         rp.PROJ_NM AS ProjectNumber
FROM            DQET036_RPT_PROPOS AS p INNER JOIN
                         DQET033_RPT_PROJ AS rp ON p.RPT_PRPOS_SQ = rp.RPT_PRPOS_SQ INNER JOIN
                         DQET030_RPT_CAT AS rc ON rp.RPT_PROJ_SQ = rc.RPT_PROJ_SQ INNER JOIN
                         DQET034_RPT_PRJ_IT AS rpi ON rc.RPT_CAT_SQ = rpi.RPT_CAT_SQ
WHERE        (p.PRPOS_NM = @ProposalNumber) AND (p.PRPOS_LVL_CD = @ProposalLevel) AND (rpi.NO_BID_CD = 'Y')</CommandText>
      </Query>
      <Fields>
        <Field Name="ProjectDescription">
          <DataField>ProjectDescription</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ItemNumber">
          <DataField>ItemNumber</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="LettingDate">
          <DataField>LettingDate</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="ProjectTotal">
          <DataField>ProjectTotal</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="WorkClass">
          <DataField>WorkClass</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ProjectItemDescription">
          <DataField>ProjectItemDescription</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DoNotBid">
          <DataField>DoNotBid</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TechSpec">
          <DataField>TechSpec</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ItemAlternateSet">
          <DataField>ItemAlternateSet</DataField>
