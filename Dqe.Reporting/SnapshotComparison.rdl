  <DataSets>
    <DataSet Name="UniqueProjectItems">
      <Query>
        <DataSourceName>DQE</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@NewestProjectEstimateId">
            <Value>=Parameters!NewestProjectEstimateId.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@OldestProjectEstimateId">
            <Value>=Parameters!OldestProjectEstimateId.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT DISTINCT pi.TRNSP_SYS_NUM, pi.ITM_NM
FROM            DQET028_PROJ_ESTM AS pe INNER JOIN
                         DQET027_CAT AS eg ON pe.PROJ_ESTM_SQ = eg.PROJ_ESTM_SQ INNER JOIN
                         DQET026_PROJ_ITM AS pi ON eg.CAT_SQ = pi.CAT_SQ
WHERE        (pe.PROJ_ESTM_SQ = @NewestProjectEstimateId) OR
                         (pe.PROJ_ESTM_SQ = @OldestProjectEstimateId)</CommandText>
      </Query>
      <Fields>
        <Field Name="TRNSP_SYS_NUM">
          <DataField>TRNSP_SYS_NUM</DataField>
          <rd:TypeName>System.Int64</rd:TypeName>
        </Field>
        <Field Name="ITM_NM">
          <DataField>ITM_NM</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="SnapshotNew">
      <Query>
        <DataSourceName>DQE</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@NewestProjectEstimateId">
            <Value>=Parameters!NewestProjectEstimateId.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT        p.PROJ_NM, pe.PROJ_VER_SQ, pe.ESTM_NUM, pi.TRNSP_SYS_NUM, pi.ITM_NM, pi.PRCE_AMT AS PRCE_NUM, pi.QTY_NUM, pv.VER_NUM, pe.LAST_UPDT_TMS
FROM            DQET020_PROJ AS p INNER JOIN
                         DQET029_PROJ_VER AS pv ON p.PROJ_SQ = pv.PROJ_SQ INNER JOIN
                         DQET028_PROJ_ESTM AS pe ON pv.PROJ_VER_SQ = pe.PROJ_VER_SQ INNER JOIN
                         DQET027_CAT AS eg ON pe.PROJ_ESTM_SQ = eg.PROJ_ESTM_SQ INNER JOIN
                         DQET026_PROJ_ITM AS pi ON eg.CAT_SQ = pi.CAT_SQ
WHERE        (pe.PROJ_ESTM_SQ = @NewestProjectEstimateId)</CommandText>
      </Query>
      <Fields>
        <Field Name="PROJ_NM">
          <DataField>PROJ_NM</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="PROJ_VER_SQ">
          <DataField>PROJ_VER_SQ</DataField>
          <rd:TypeName>System.Int64</rd:TypeName>
        </Field>
        <Field Name="ESTM_NUM">
          <DataField>ESTM_NUM</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="TRNSP_SYS_NUM">
          <DataField>TRNSP_SYS_NUM</DataField>
          <rd:TypeName>System.Int64</rd:TypeName>
        </Field>
        <Field Name="ITM_NM">
          <DataField>ITM_NM</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="PRCE_NUM">
          <DataField>PRCE_NUM</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="QTY_NUM">
          <DataField>QTY_NUM</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="VER_NUM">
          <DataField>VER_NUM</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="LAST_UPDT_TMS">
          <DataField>LAST_UPDT_TMS</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="SnapshotOld">
      <Query>
        <DataSourceName>DQE</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@OldestProjectEstimateId">
            <Value>=Parameters!OldestProjectEstimateId.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT        p.PROJ_NM, pe.PROJ_VER_SQ, pe.ESTM_NUM, pi.TRNSP_SYS_NUM, pi.ITM_NM, pi.PRCE_AMT AS PRCE_NUM, pi.QTY_NUM, pv.VER_NUM, pe.LAST_UPDT_TMS
FROM            DQET020_PROJ AS p INNER JOIN
                         DQET029_PROJ_VER AS pv ON p.PROJ_SQ = pv.PROJ_SQ INNER JOIN
                         DQET028_PROJ_ESTM AS pe ON pv.PROJ_VER_SQ = pe.PROJ_VER_SQ INNER JOIN
                         DQET027_CAT AS eg ON pe.PROJ_ESTM_SQ = eg.PROJ_ESTM_SQ INNER JOIN
                         DQET026_PROJ_ITM AS pi ON eg.CAT_SQ = pi.CAT_SQ
WHERE        (pe.PROJ_ESTM_SQ = @OldestProjectEstimateId)</CommandText>
      </Query>
      <Fields>
        <Field Name="PROJ_NM">
          <DataField>PROJ_NM</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TRNSP_SYS_NUM">
          <DataField>TRNSP_SYS_NUM</DataField>
          <rd:TypeName>System.Int64</rd:TypeName>
        </Field>
        <Field Name="PROJ_VER_SQ">
