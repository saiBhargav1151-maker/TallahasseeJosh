    <DataSet Name="ProjectSummary">
      <Query>
        <DataSourceName>DQE</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ReportProposalId">
            <Value>=Parameters!ReportProposalId.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ProjectNumber">
            <Value>=Parameters!ProjectNumber.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT        rps.RPT_PROJ_SUM_SQ AS Id, rps.ALT_DS AS AlternateDescription, rps.CAT_ALT_SET_TXT AS CategoryAlternateSet, rps.CAT_ALT_MBR_TXT AS CategoryAlternateMember, 
                         rps.ITM_ALT_SET_TXT AS ItemAlternateSet, rps.ITM_ALT_MBR_TXT AS ItemAlternateMember, rps.LOW_CST_CD AS IsLowCost, rps.TOT_NUM AS Total, rps.RPT_PROJ_SQ AS ReportProjectId
FROM            DQET033_RPT_PROJ AS rp INNER JOIN
                         DQET035_RPT_PRJ_SM AS rps ON rp.RPT_PROJ_SQ = rps.RPT_PROJ_SQ
WHERE        (rp.RPT_PRPOS_SQ = @ReportProposalId) AND (rp.PROJ_NM = @ProjectNumber)</CommandText>
      </Query>
