  <DataSets>
    <DataSet Name="ProjectDetail">
      <Query>
        <DataSourceName>DQE</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ReportProposalId">
            <Value>=Parameters!ReportProposalId.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ProjectNumber">
            <Value>=Parameters!ProjectNumber.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT        rp.PROJ_DS AS ProjectDescription, rp.LET_DT AS LettingDate, rp.TOT_NUM AS ProjectTotal, rpi.ITM_NM AS ItemNumber, rpi.ITM_DS AS ProjectItemDescription, rpi.WRK_CLS_TXT AS WorkClass, 
                         rpi.TECH_SPEC_TXT AS TechSpec, rpi.NO_BID_CD AS DoNotBid, rpi.ITM_ALT_SET_TXT AS ItemAlternateSet, rpi.ITM_ALT_MBR_TXT AS ItemAlternateMember, rpi.LOW_CST_CD AS IsLowCost, 
                         rpi.UNIT_TXT AS Unit, rpi.QTY_NUM AS Quantity, rpi.PRCE_NUM AS Price, rpi.OBSLT_DT AS ObsoleteDate, rpi.OBSLT_CD AS IsObsolete, rpi.TOT_NUM AS ProjectItemTotal, rpi.RPT_CAT_SQ AS ReportCategoryId, 
                         rp.PROJ_NM AS ProjectNumber
FROM            DQET033_RPT_PROJ AS rp INNER JOIN
                         DQET030_RPT_CAT AS rc ON rp.RPT_PROJ_SQ = rc.RPT_PROJ_SQ INNER JOIN
                         DQET034_RPT_PRJ_IT AS rpi ON rc.RPT_CAT_SQ = rpi.RPT_CAT_SQ
WHERE        (rp.RPT_PRPOS_SQ = @ReportProposalId) AND (rp.PROJ_NM = @ProjectNumber)</CommandText>
      </Query>
      <Fields>
        <Field Name="ProjectDescription">
          <DataField>ProjectDescription</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
