        </Field>
        <Field Name="ItemAlternateSet">
          <DataField>ItemAlternateSet</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ItemAlternateMember">
          <DataField>ItemAlternateMember</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="IsLowCost">
