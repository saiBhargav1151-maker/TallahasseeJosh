  <DataSources>
    <DataSource Name="DQE">
      <DataSourceReference>DQE</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>d0d812cd-eddf-429a-9934-e40e6ba265d6</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="ProposalHeader">
      <Query>
        <DataSourceName>DQE</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ProposalNumber">
            <Value>=Parameters!ProposalNumber.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ProposalLevel">
            <Value>=Parameters!ProposalLevel.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT        prop.PRPOS_NM AS ProposalNumber, prop.CNST_DY_NUM AS ConstructionDays, prop.DY_CST_NUM AS CostPerDay, prop.PRPOS_DS AS Description, prop.WRK_TYP_TXT AS WorkType, 
                         prop.CNTY_TXT AS County, prop.TOT_NUM AS ProposalTotal, prop.LAST_UPDT_USER_TXT AS LastUpdatedUser, proj.PROJ_NM AS ProjectNumber, proj.PROJ_DS AS ProjectDescription, 
                         proj.LET_DT AS ProjectLettingDate, proj.TOT_NUM AS ProjectTotal, let.LET_NM AS LettingName, let.LET_DT AS LettingDate
FROM            DQET036_RPT_PROPOS AS prop INNER JOIN
                         DQET033_RPT_PROJ AS proj ON prop.RPT_PRPOS_SQ = proj.RPT_PRPOS_SQ LEFT OUTER JOIN
                         DQET031_RPT_LET AS let ON prop.RPT_LET_SQ = let.RPT_LET_SQ
WHERE        (prop.PRPOS_NM = @ProposalNumber) AND (prop.PRPOS_LVL_NUM = @ProposalLevel)</CommandText>
      </Query>
      <Fields>
        <Field Name="ProposalNumber">
          <DataField>ProposalNumber</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="LettingDate">
          <DataField>LettingDate</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="ConstructionDays">
          <DataField>ConstructionDays</DataField>
          <rd:TypeName>System.Int64</rd:TypeName>
        </Field>
        <Field Name="CostPerDay">
          <DataField>CostPerDay</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="Description">
          <DataField>Description</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="WorkType">
          <DataField>WorkType</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="County">
          <DataField>County</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ProposalTotal">
          <DataField>ProposalTotal</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="LastUpdatedUser">
          <DataField>LastUpdatedUser</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ProjectNumber">
          <DataField>ProjectNumber</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ProjectDescription">
          <DataField>ProjectDescription</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ProjectLettingDate">
          <DataField>ProjectLettingDate</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="LettingName">
          <DataField>LettingName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ProjectTotal">
          <DataField>ProjectTotal</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ProposalDetail">
      <Query>
        <DataSourceName>DQE</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ProposalNumber">
            <Value>=Parameters!ProposalNumber.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ProposalLevel">
            <Value>=Parameters!ProposalLevel.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT        rpi.ITM_NM AS ItemNumber, rpi.CAT_DS AS CategoryDescription, rpi.ITM_DS AS ReportItemDescription, rpi.WRK_CLS_TXT AS WorkClass, rpi.TECH_SPEC_TXT AS TechSpec, rpi.NO_BID_CD AS DoNotBid, 
                         rpi.ALT_DS AS AlternateDescription, rpi.CAT_ALT_SET_TXT AS CategoryAlternateSet, rpi.CAT_ALT_MBR_TXT AS CategoryAlternateMember, rpi.ITM_ALT_SET_TXT AS ItemAlternateSet, 
                         rpi.ITM_ALT_MBR_TXT AS ItemAlternateMember, rpi.LOW_CST_CD AS IsLowCost, rpi.UNIT_TXT AS Unit, rpi.QTY_NUM AS Quantity, rpi.PRCE_NUM AS Price, rpi.OBSLT_DT AS ObsoleteDate, 
                         rpi.OBSLT_CD AS IsObsolete, rpi.TOT_NUM AS Expr3, rpi.RPT_PRPOS_SQ AS ReportProposalId
FROM            DQET036_RPT_PROPOS AS rp INNER JOIN
                         DQET037_RPT_PRO_IT AS rpi ON rp.RPT_PRPOS_SQ = rpi.RPT_PRPOS_SQ
WHERE        (rp.PRPOS_NM = @ProposalNumber) AND (rp.PRPOS_LVL_NUM = @ProposalLevel)</CommandText>
      </Query>
