        </QueryParameters>
        <CommandText>SELECT        rpi.ITM_NM AS ItemNumber, rpi.CAT_DS AS CategoryDescription, rpi.ITM_DS AS Description, rpi.WRK_CLS_TXT AS WorkClass, rpi.NO_BID_CD AS DoNotBid, rpi.ALT_DS AS AlternateDescription, 
                         rpi.CAT_ALT_SET_TXT AS CategoryAlternateSet, rpi.CAT_ALT_MBR_TXT AS CategoryAlternateMember, rpi.ITM_ALT_SET_TXT AS ItemAlternateSet, rpi.ITM_ALT_MBR_TXT AS ItemAlternateMember, 
                         rpi.UNIT_TXT AS Unit, rpi.QTY_NUM AS Quantity, rpi.PRCE_NUM AS Price, rpi.OBSLT_DT AS ObsoleteDate, rpi.OBSLT_CD AS IsObsolete, rpi.TOT_NUM AS Total, rpi.RPT_PRPOS_SQ AS ReportProposalId
FROM            DQET036_RPT_PROPOS AS rp INNER JOIN
                         DQET037_RPT_PRO_IT AS rpi ON rp.RPT_PRPOS_SQ = rpi.RPT_PRPOS_SQ
WHERE        (rp.PRPOS_NM = @ProposalNumber) AND (rp.PRPOS_LVL_NUM = @ProposalLevel) AND (rpi.NO_BID_CD = 'Y')</CommandText>
