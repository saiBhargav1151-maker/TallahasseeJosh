    <DataSet Name="ProjectDetail">
      <Query>
        <DataSourceName>DQE</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ProposalNumber">
            <Value>=Parameters!ProposalNumber.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ProposalLevel">
            <Value>=Parameters!ProposalLevel.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT        rproj.PROJ_NM AS ProjectNumber, rproj.RPT_PRPOS_SQ AS ReportProposalId
FROM            DQET036_RPT_PROPOS AS rprop INNER JOIN
                         DQET033_RPT_PROJ AS rproj ON rprop.RPT_PRPOS_SQ = rproj.RPT_PRPOS_SQ
WHERE        (rprop.PRPOS_NM = @ProposalNumber) AND (rprop.PRPOS_LVL_NUM = @ProposalLevel)</CommandText>
