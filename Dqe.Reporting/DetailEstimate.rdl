    <DataSet Name="AB_Milestone">
      <Query>
        <DataSourceName>DQE</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ProposalNumber">
            <Value>=Parameters!ProposalNumber.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ProposalLevel">
            <Value>=Parameters!ProposalLevel.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT        rpm.RPT_MLSTN_SQ AS Id, rpm.MLSTN_DS AS Description, rpm.UNIT_TXT AS Unit, rpm.DY_NUM AS ConstructionDays, rpm.DY_CST_AMT AS CostPerDay, rpm.TOT_AMT AS Total, 
                         rpm.RPT_PRPOS_SQ AS ReportProposalId
FROM            DQET036_RPT_PROPOS AS rp INNER JOIN
                         DQET038_RPT_MLSTN AS rpm ON rp.RPT_PRPOS_SQ = rpm.RPT_PRPOS_SQ
WHERE        (rp.PRPOS_NM = @ProposalNumber) AND (rp.PRPOS_LVL_CD = @ProposalLevel)</CommandText>
      </Query>
