    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DQE</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@PayItemStructureSequence">
            <Value>=Parameters!PayItemStructureSequence.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT        PAY_ITM_NM, PAY_ITM_DS, UNIT_TXT, OPEN_DT, OBSLT_DT
FROM            DQET008_PAY_ITM
WHERE        (PAY_ITM_STRCT_SQ = @PayItemStructureSequence) AND (OBSLT_DT IS NULL OR
                         OBSLT_DT &gt; SYSDATETIME())</CommandText>
      </Query>
      <Fields>
        <Field Name="PAY_ITM_NM">
          <DataField>PAY_ITM_NM</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="PAY_ITM_DS">
          <DataField>PAY_ITM_DS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="UNIT_TXT">
          <DataField>UNIT_TXT</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="OPEN_DT">
          <DataField>OPEN_DT</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="OBSLT_DT">
          <DataField>OBSLT_DT</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
