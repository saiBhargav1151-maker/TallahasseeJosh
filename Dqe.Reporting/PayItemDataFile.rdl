    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DQE</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@MasterFileSequence">
            <Value>=Parameters!MasterFileSequence.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT        pi.PAY_ITM_NM, pi.PAY_ITM_DS, pi.UNIT_CD AS UNIT_TXT, pi.OPEN_DT, pi.OBSLT_DT, pi.PAY_ITM_STRCT_SQ, pi.SPLMNT_RQIR_CD, pi.CMB_CD, pi.FED_FND_CD, pi.CNCRT_FCTR_NUM, pi.REF_PRCE_AMT, 
                         pi.ASPH_FCTR_NUM, pi.EFFCT_DT, pi.FCTR_NOTE_TXT, pi.SHRT_DS, pi.CMN_UNIT_TXT, pi.CNVT_FCTR_NUM, pi.NON_BID_CD, pi.FIX_PRCE_CD, pi.FRNT_LOAD_CD, pi.ITM_TYP_CD, pi.ITM_CLSF_CD, 
                         pi.CNTRT_CLSF_CD, pi.QTY_PRCIS_CD, pi.EXT_FLG_CD, pi.ST_AVG_PRCE_AMT, pi.LUMP_SUM_BID_CD, pi.ADM_CD, pi.AUTO_PD_CD, pi.APRV_RQIR_CD, pi.EXMPT_CD, pi.EXMPT_RTNG_CD, 
                         pi.FUEL_ADJ_CD, pi.FUEL_ADJ_TXT, pi.MAJ_ITM_CD, pi.PAY_PLN_CD, pi.PCT_SCH_CD, pi.INCLD_RGRS_CD, pi.SPCL_ITM_CD, ct.TMPLT_NM
FROM            DQET008_PAY_ITM AS pi LEFT OUTER JOIN
                         DQET009_CST_TMPLT AS ct ON pi.CST_TMPLT_SQ = ct.CST_TMPLT_SQ
WHERE        (pi.MSTR_FILE_SQ = @MasterFileSequence)</CommandText>
      </Query>
