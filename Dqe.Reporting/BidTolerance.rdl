  <DataSets>
    <DataSet Name="Official">
      <Query>
        <DataSourceName>DQE</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@LettingNumber">
            <Value>=Parameters!LettingNumber.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT        prop.PRPOS_NM, prop.TOT_NUM
FROM            DQET031_RPT_LET AS let INNER JOIN
                         DQET036_RPT_PROPOS AS prop ON let.RPT_LET_SQ = prop.RPT_LET_SQ
WHERE        (prop.PRPOS_LVL_NUM = 2) AND (let.LET_NM = @LettingNumber)</CommandText>
      </Query>
      <Fields>
        <Field Name="PRPOS_NM">
          <DataField>PRPOS_NM</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TOT_NUM">
          <DataField>TOT_NUM</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Advertised">
      <Query>
        <DataSourceName>DQE</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@LettingNumber">
            <Value>=Parameters!LettingNumber.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT        prop.PRPOS_NM, prop.TOT_NUM
FROM            DQET031_RPT_LET AS let INNER JOIN
                         DQET036_RPT_PROPOS AS prop ON let.RPT_LET_SQ = prop.RPT_LET_SQ
WHERE        (prop.PRPOS_LVL_NUM = 1) AND (let.LET_NM = @LettingNumber)</CommandText>
      </Query>
      <Fields>
        <Field Name="PRPOS_NM">
          <DataField>PRPOS_NM</DataField>
