  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="DQE">
      <DataSourceReference>DQE</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>f6fdc23e-7506-4ba9-b00e-cdc44b88a528</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="VendorMilestoneBid">
      <Query>
        <DataSourceName>DQE</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@MilestoneId">
            <Value>=Parameters!MilestoneId.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT        rpv.VEND_NM AS VendorName, rpv.TOT_AMT AS VendorTotal, rmb.BID_PRCE_AMT AS VendorBidPrice, rmb.DY_BID_NUM AS VendorDayBid, rmb.TLRAT_TXT AS Tolerance, rm.MLSTN_DS AS Description, 
                         rm.DY_CST_AMT AS MilestoneDayCost, rm.TOT_AMT AS MilestonItemTotal, rm.DY_NUM AS MilestoneNumberOfDays, rm.AVG_BID_PRCE_AMT AS AverageBidPrice, rm.UNIT_TXT AS UnitText
FROM            DQET036_RPT_PROPOS AS rp INNER JOIN
                         DQET040_RPT_PRO_VD AS rpv ON rp.RPT_PRPOS_SQ = rpv.RPT_PRPOS_SQ INNER JOIN
                         DQET043_RPT_MS_BID AS rmb ON rpv.RPT_PRPOS_VEND_SQ = rmb.RPT_PRPOS_VEND_SQ INNER JOIN
                         DQET038_RPT_MLSTN AS rm ON rmb.RPT_MLSTN_SQ = rm.RPT_MLSTN_SQ
WHERE        (rm.RPT_MLSTN_SQ = @MilestoneId)</CommandText>
      </Query>
      <Fields>
        <Field Name="VendorName">
          <DataField>VendorName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="VendorTotal">
          <DataField>VendorTotal</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="VendorBidPrice">
          <DataField>VendorBidPrice</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="Tolerance">
          <DataField>Tolerance</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Description">
          <DataField>Description</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MilestoneDayCost">
          <DataField>MilestoneDayCost</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="MilestonItemTotal">
          <DataField>MilestonItemTotal</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="MilestoneNumberOfDays">
