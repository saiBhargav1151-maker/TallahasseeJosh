  <Width>6.34375in</Width>
  <Page>
    <LeftMargin>1in</LeftMargin>
    <RightMargin>1in</RightMargin>
    <TopMargin>1in</TopMargin>
    <BottomMargin>1in</BottomMargin>
    <Style />
  </Page>
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="DQE">
      <DataSourceReference>DQE</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>90e845c3-e5ce-40e7-974d-ce9a2a9ad8cc</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DQE</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@MarketArea">
            <Value>=Parameters!MarketArea.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT        ph.ProposalNumber, ph.LettingDate, ph.County, ph.ContractType, ph.Quantity, bh.Price, pim.RefItemName, pim.Description, pim.SpecBook, pim.Unit, c.Code
FROM            ProposalHistory AS ph INNER JOIN
                         PayItemMaster AS pim ON pim.Id = ph.PayItemMasterId INNER JOIN
                         BidHistory AS bh ON bh.ProposalHistoryId = ph.Id INNER JOIN
                         County AS c ON c.Name = ph.County INNER JOIN
                         MarketArea AS ma ON ma.Id = c.MarketAreaId
WHERE        (bh.IsAwarded = 1) AND (ma.Name IN (@MarketArea))</CommandText>
      </Query>
      <Fields>
        <Field Name="ProposalNumber">
          <DataField>ProposalNumber</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="LettingDate">
          <DataField>LettingDate</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="County">
          <DataField>County</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ContractType">
          <DataField>ContractType</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="RefItemName">
          <DataField>RefItemName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Quantity">
          <DataField>Quantity</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="Description">
          <DataField>Description</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Price">
          <DataField>Price</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="SpecBook">
          <DataField>SpecBook</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Unit">
          <DataField>Unit</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Code">
          <DataField>Code</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
