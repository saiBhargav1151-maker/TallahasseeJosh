  <DataSources>
    <DataSource Name="DQE">
      <DataSourceReference>DQE</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>f9982aff-5584-4586-a0ea-4f11fe05af31</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="ProposalAlternateSummary">
      <Query>
        <DataSourceName>DQE</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ProposalNumber">
            <Value>=Parameters!ProposalNumber.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ProposalLevel">
            <Value>=Parameters!ProposalLevel.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT        rps.ALT_DS AS AlternateDescription, rps.CAT_ALT_SET_TXT AS CategoryAlternateSet, rps.CAT_ALT_MBR_TXT AS CategoryAlternateMember, rps.ITM_ALT_SET_TXT AS ItemAlternateSet, 
                         rps.ITM_ALT_MBR_TXT AS ItemAlternateMember, rps.LOW_CST_CD AS IsLowCost, rps.TOT_AMT AS Total
FROM            DQET036_RPT_PROPOS AS rp INNER JOIN
                         DQET039_RPT_PRO_SM AS rps ON rp.RPT_PRPOS_SQ = rps.RPT_PRPOS_SQ
WHERE        (rp.PRPOS_NM = @ProposalNumber) AND (rp.PRPOS_LVL_CD = @ProposalLevel)</CommandText>
      </Query>
      <Fields>
        <Field Name="AlternateDescription">
          <DataField>AlternateDescription</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CategoryAlternateSet">
          <DataField>CategoryAlternateSet</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CategoryAlternateMember">
          <DataField>CategoryAlternateMember</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ItemAlternateSet">
          <DataField>ItemAlternateSet</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ItemAlternateMember">
          <DataField>ItemAlternateMember</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="IsLowCost">
          <DataField>IsLowCost</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Total">
          <DataField>Total</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
  <ReportParameters>
    <ReportParameter Name="ProposalNumber">
      <DataType>String</DataType>
      <Prompt>Proposal Number</Prompt>
    </ReportParameter>
    <ReportParameter Name="ProposalLevel">
      <DataType>String</DataType>
      <Prompt>Proposal Level</Prompt>
    </ReportParameter>
  </ReportParameters>
