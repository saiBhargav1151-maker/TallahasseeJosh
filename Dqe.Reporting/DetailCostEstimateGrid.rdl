    <ReportParameter Name="Category">
      <DataType>String</DataType>
      <Prompt>Category</Prompt>
    </ReportParameter>
    <ReportParameter Name="Proposal">
      <DataType>String</DataType>
      <Prompt>Proposal</Prompt>
    </ReportParameter>
    <ReportParameter Name="EstimateType">
      <DataType>String</DataType>
      <Prompt>Estimate Type</Prompt>
    </ReportParameter>
  </ReportParameters>
