                <TablixCell>
                  <CellContents>
                    <Textbox Name="Textbox22">
                      <CanGrow>true</CanGrow>
                      <KeepTogether>true</KeepTogether>
                      <Paragraphs>
                        <Paragraph>
                          <TextRuns>
                            <TextRun>
                              <Value>=Fields!Quantity.Value * Fields!Price.Value</Value>
                              <Style>
                                <FontSize>8pt</FontSize>
                                <Format>'$'#,0.00;('$'#,0.00)</Format>
