  <DataSources>
    <DataSource Name="DQE">
      <DataSourceReference>DQE</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>b0ffdd69-1541-4a15-a415-2e0e9eae665e</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="ProjectDetail">
      <Query>
        <DataSourceName>DQE</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ReportProposalId">
            <Value>=Parameters!ReportProposalId.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ProjectNumber">
            <Value>=Parameters!ProjectNumber.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@CategoryDescription">
            <Value>=Parameters!CategoryDescription.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT        rp.PROJ_DS AS ProjectDescription, rp.LET_DT AS LettingDate, rp.TOT_AMT AS ProjectTotal, rc.CAT_DS AS CategoryDescription, rc.ALT_DS AS CategoryAlternateDescription, rpi.ITM_NM AS ItemNumber, 
                         rpi.ITM_DS AS ProjectItemDescription, rpi.WRK_CLS_TXT AS WorkClass, rpi.TECH_SPEC_TXT AS TechSpec, rpi.NO_BID_CD AS DoNotBid, rpi.ITM_ALT_SET_TXT AS ItemAlternateSet, 
                         rpi.ITM_ALT_MBR_TXT AS ItemAlternateMember, rpi.LOW_CST_CD AS IsLowCost, rpi.UNIT_TXT AS Unit, rpi.QTY_NUM AS Quantity, rpi.PRCE_AMT AS Price, rpi.OBSLT_DT AS ObsoleteDate, 
                         rpi.OBSLT_CD AS IsObsolete, rpi.TOT_AMT AS ProjectItemTotal, rpi.RPT_CAT_SQ AS ReportCategoryId, rpi.SPLMNT_DS AS SupplementalDescription, rpi.FND_TXT AS Fund, rp.PROJ_NM AS ProjectNumber, 
                         rp.WRK_TYP_TXT AS WorkType, rp.FED_PROJ_TXT AS FederalAid, rp.CNTY_TXT AS County, rp.DIST_TXT AS District
FROM            DQET033_RPT_PROJ AS rp INNER JOIN
                         DQET030_RPT_CAT AS rc ON rp.RPT_PROJ_SQ = rc.RPT_PROJ_SQ INNER JOIN
                         DQET034_RPT_PRJ_IT AS rpi ON rc.RPT_CAT_SQ = rpi.RPT_CAT_SQ
WHERE        (rp.RPT_PRPOS_SQ = @ReportProposalId) AND (rp.PROJ_NM = @ProjectNumber) AND (rc.CAT_DS = @CategoryDescription)
ORDER BY ItemNumber, SupplementalDescription</CommandText>
      </Query>
      <Fields>
        <Field Name="ProjectDescription">
          <DataField>ProjectDescription</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="LettingDate">
