    <DataSource Name="DQE">
      <DataSourceReference>DQE</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>76d8cd5d-8953-4ac0-9119-3d1756c68d3f</rd:DataSourceID>
