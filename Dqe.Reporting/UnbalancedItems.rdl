  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="DQE">
      <DataSourceReference>DQE</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>489d5c9c-0d57-4aad-9dbe-2f5194f0e3d7</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="UnbalancedItems">
      <Query>
        <DataSourceName>DQE</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ProposalNumber">
            <Value>=Parameters!ProposalNumber.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT DISTINCT rvb.RPT_PRPOS_ITM_SQ AS ReportProposalItemId
FROM            DQET036_RPT_PROPOS AS rp INNER JOIN
                         DQET037_RPT_PRO_IT AS rpi ON rp.RPT_PRPOS_SQ = rpi.RPT_PRPOS_SQ INNER JOIN
                         DQET041_RPT_VD_BID AS rvb ON rpi.RPT_PRPOS_ITM_SQ = rvb.RPT_PRPOS_ITM_SQ
WHERE        (rp.PRPOS_NM = @ProposalNumber) AND (rvb.TLRAT_TXT IS NOT NULL) AND (rp.PRPOS_LVL_NUM = 2)</CommandText>
      </Query>
      <Fields>
        <Field Name="ReportProposalItemId">
          <DataField>ReportProposalItemId</DataField>
          <rd:TypeName>System.Int64</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="HeaderInfromation">
      <Query>
        <DataSourceName>DQE</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ProposalNumber">
            <Value>=Parameters!ProposalNumber.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT        TOP (1) rl.LET_NM AS LettingName, rp.TOT_NUM AS EstimateTotal, rpv.VEND_NM AS Name, rpv.TOT_NUM AS VendorBidAmount
FROM            DQET036_RPT_PROPOS AS rp INNER JOIN
                         DQET040_RPT_PRO_VD AS rpv ON rp.RPT_PRPOS_SQ = rpv.RPT_PRPOS_SQ INNER JOIN
                         DQET031_RPT_LET AS rl ON rp.RPT_LET_SQ = rl.RPT_LET_SQ
WHERE        (rp.PRPOS_NM = @ProposalNumber) AND (rp.PRPOS_LVL_NUM = 2)
ORDER BY VendorBidAmount</CommandText>
      </Query>
      <Fields>
        <Field Name="LettingName">
          <DataField>LettingName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="EstimateTotal">
          <DataField>EstimateTotal</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="Name">
          <DataField>Name</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="VendorBidAmount">
          <DataField>VendorBidAmount</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
  <ReportParameters>
    <ReportParameter Name="ProposalNumber">
      <DataType>String</DataType>
      <Prompt>Proposal Number</Prompt>
    </ReportParameter>
    <ReportParameter Name="ShowEstimate">
      <DataType>String</DataType>
      <Prompt>ShowEstimate</Prompt>
    </ReportParameter>
  </ReportParameters>
  <Language>en-US</Language>
