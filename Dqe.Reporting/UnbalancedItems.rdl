  <DataSources>
    <DataSource Name="DQE">
      <DataSourceReference>DQE</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>489d5c9c-0d57-4aad-9dbe-2f5194f0e3d7</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="UnbalancedItems">
      <Query>
        <DataSourceName>DQE</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ProposalNumber">
            <Value>=Parameters!ProposalNumber.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT DISTINCT rpi.RPT_PRPOS_ITM_SQ AS ReportProposalItemId, rpi.LINE_TXT AS LineNumber, rpi.ESTM_DFFR_AMT AS Magnitude, rpi.ITM_NM AS PayItemNumber
FROM            DQET036_RPT_PROPOS AS rp INNER JOIN
                         DQET037_RPT_PRO_IT AS rpi ON rp.RPT_PRPOS_SQ = rpi.RPT_PRPOS_SQ INNER JOIN
                         DQET041_RPT_VD_BID AS rvb ON rpi.RPT_PRPOS_ITM_SQ = rvb.RPT_PRPOS_ITM_SQ
WHERE        (rp.PRPOS_NM = @ProposalNumber) AND (rp.PRPOS_LVL_CD = 'O')</CommandText>
      </Query>
      <Fields>
        <Field Name="ReportProposalItemId">
          <DataField>ReportProposalItemId</DataField>
          <rd:TypeName>System.Int64</rd:TypeName>
        </Field>
        <Field Name="LineNumber">
          <DataField>LineNumber</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Magnitude">
          <DataField>Magnitude</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="PayItemNumber">
          <DataField>PayItemNumber</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="HeaderInfromation">
      <Query>
        <DataSourceName>DQE</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ProposalNumber">
            <Value>=Parameters!ProposalNumber.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT        TOP (1) rl.LET_NM AS LettingName, rp.TOT_AMT AS EstimateTotal, rpv.VEND_NM AS Name, rpv.TOT_AMT AS VendorBidAmount
FROM            DQET036_RPT_PROPOS AS rp INNER JOIN
                         DQET040_RPT_PRO_VD AS rpv ON rp.RPT_PRPOS_SQ = rpv.RPT_PRPOS_SQ INNER JOIN
                         DQET031_RPT_LET AS rl ON rp.RPT_LET_SQ = rl.RPT_LET_SQ
WHERE        (rp.PRPOS_NM = @ProposalNumber) AND (rp.PRPOS_LVL_CD = 'O')
ORDER BY VendorBidAmount</CommandText>
      </Query>
      <Fields>
        <Field Name="LettingName">
          <DataField>LettingName</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="EstimateTotal">
          <DataField>EstimateTotal</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="Name">
          <DataField>Name</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="VendorBidAmount">
          <DataField>VendorBidAmount</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="TotalAverageBidAmount">
      <Query>
        <DataSourceName>DQE</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ProposalNumber">
            <Value>=Parameters!ProposalNumber.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT        SUM(rpi.QTY_NUM * rpi.AVG_BID_PRCE_AMT) AS TotalAverageBidAmount
FROM            DQET036_RPT_PROPOS AS rp INNER JOIN
                         DQET037_RPT_PRO_IT AS rpi ON rp.RPT_PRPOS_SQ = rpi.RPT_PRPOS_SQ
WHERE        (rp.PRPOS_NM = @ProposalNumber) AND (rp.PRPOS_LVL_CD = 'O')</CommandText>
      </Query>
      <Fields>
        <Field Name="TotalAverageBidAmount">
          <DataField>TotalAverageBidAmount</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="UnbalancedBMilestones">
      <Query>
        <DataSourceName>DQE</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ProposalNumber">
            <Value>=Parameters!ProposalNumber.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT DISTINCT rm.RPT_MLSTN_SQ AS ReportMilestoneId, rm.ESTM_DFFR_AMT AS Magnitude, rm.MLSTN_DS AS MilestoneDescription
FROM            DQET036_RPT_PROPOS AS rp INNER JOIN
                         DQET038_RPT_MLSTN AS rm ON rp.RPT_PRPOS_SQ = rm.RPT_PRPOS_SQ INNER JOIN
                         DQET043_RPT_MS_BID AS rmb ON rm.RPT_MLSTN_SQ = rmb.RPT_MLSTN_SQ
WHERE        (rp.PRPOS_NM = @ProposalNumber) AND (rp.PRPOS_LVL_CD = 'O')</CommandText>
      </Query>
      <Fields>
        <Field Name="ReportMilestoneId">
          <DataField>ReportMilestoneId</DataField>
          <rd:TypeName>System.Int64</rd:TypeName>
        </Field>
        <Field Name="Magnitude">
          <DataField>Magnitude</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="MilestoneDescription">
          <DataField>MilestoneDescription</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="TotalAverageBidAmountB">
      <Query>
        <DataSourceName>DQE</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ProposalNumber">
            <Value>=Parameters!ProposalNumber.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT        SUM(rm.DY_CST_AMT * rm.AVG_BID_PRCE_AMT) AS TotalAverageBidAmountB
FROM            DQET036_RPT_PROPOS AS rp INNER JOIN
                         DQET038_RPT_MLSTN AS rm ON rp.RPT_PRPOS_SQ = rm.RPT_PRPOS_SQ
WHERE        (rp.PRPOS_NM = @ProposalNumber) AND (rp.PRPOS_LVL_CD = 'O')</CommandText>
      </Query>
      <Fields>
        <Field Name="TotalAverageBidAmountB">
          <DataField>TotalAverageBidAmountB</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
  <ReportParameters>
    <ReportParameter Name="ProposalNumber">
      <DataType>String</DataType>
      <Prompt>Proposal Number</Prompt>
    </ReportParameter>
    <ReportParameter Name="ShowEstimate">
      <DataType>String</DataType>
      <Prompt>ShowEstimate</Prompt>
    </ReportParameter>
    <ReportParameter Name="Sort">
      <DataType>String</DataType>
      <Prompt>Sort</Prompt>
    </ReportParameter>
  </ReportParameters>
