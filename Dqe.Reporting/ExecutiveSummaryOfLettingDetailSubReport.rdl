  <DataSources>
    <DataSource Name="DQE">
      <DataSourceReference>DQE</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>1e7da0b8-6aec-4c28-a83b-e2ae6e5afb13</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="ProposalVendor">
      <Query>
        <DataSourceName>DQE</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ProposalNumber">
            <Value>=Parameters!ProposalNumber.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ProposalLevel">
            <Value>=Parameters!ProposalLevel.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT        rp.TOT_NUM AS ProposalTotal, rp.PRPOS_NM AS ProposalNumber, rpv.VEND_NM AS Name, rpv.BID_STAT_TXT AS BidStatus, rpv.AWRD_CD AS Awarded, rpv.TOT_NUM AS VendorBidTotal
FROM            DQET036_RPT_PROPOS AS rp INNER JOIN
                         DQET040_RPT_PRO_VD AS rpv ON rp.RPT_PRPOS_SQ = rpv.RPT_PRPOS_SQ
WHERE        (rp.PRPOS_NM = @ProposalNumber) AND (rp.PRPOS_LVL_NUM = @ProposalLevel)
ORDER BY VendorBidTotal</CommandText>
      </Query>
      <Fields>
        <Field Name="ProposalTotal">
          <DataField>ProposalTotal</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="ProposalNumber">
          <DataField>ProposalNumber</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Name">
          <DataField>Name</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="BidStatus">
          <DataField>BidStatus</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Awarded">
          <DataField>Awarded</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="VendorBidTotal">
          <DataField>VendorBidTotal</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ProjectInformation">
      <Query>
        <DataSourceName>DQE</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ProposalNumber">
            <Value>=Parameters!ProposalNumber.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ProposalLevel">
            <Value>=Parameters!ProposalLevel.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT        rpj.PROJ_NM, rpj.PROJ_DS, rpj.CNTY_TXT, rpj.DIST_TXT
FROM            DQET036_RPT_PROPOS AS rp INNER JOIN
                         DQET033_RPT_PROJ AS rpj ON rp.RPT_PRPOS_SQ = rpj.RPT_PRPOS_SQ
WHERE        (rp.PRPOS_NM = @ProposalNumber) AND (rp.PRPOS_LVL_NUM = @ProposalLevel)
ORDER BY rpj.PROJ_NM</CommandText>
      </Query>
      <Fields>
        <Field Name="PROJ_NM">
          <DataField>PROJ_NM</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="PROJ_DS">
          <DataField>PROJ_DS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CNTY_TXT">
          <DataField>CNTY_TXT</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DIST_TXT">
          <DataField>DIST_TXT</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
  <ReportParameters>
    <ReportParameter Name="ProposalNumber">
      <DataType>String</DataType>
      <Prompt>ProposalNumber</Prompt>
    </ReportParameter>
    <ReportParameter Name="ProposalLevel">
