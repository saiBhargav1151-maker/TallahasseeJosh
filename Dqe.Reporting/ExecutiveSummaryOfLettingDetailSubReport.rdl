  </Body>
  <Width>9.78125in</Width>
  <Page>
    <PageHeight>8.5in</PageHeight>
    <PageWidth>11in</PageWidth>
    <LeftMargin>0.5in</LeftMargin>
    <RightMargin>0.5in</RightMargin>
    <TopMargin>1in</TopMargin>
    <BottomMargin>1in</BottomMargin>
    <Style />
  </Page>
  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="DQE">
      <DataSourceReference>DQE</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>1e7da0b8-6aec-4c28-a83b-e2ae6e5afb13</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="ProposalVendor">
      <Query>
        <DataSourceName>DQE</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ProposalNumber">
            <Value>=Parameters!ProposalNumber.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ProposalLevel">
            <Value>=Parameters!ProposalLevel.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT        rp.TOT_AMT AS ProposalTotal, rp.PRPOS_NM AS ProposalNumber, rpv.VEND_NM AS Name, rpv.BID_STAT_TXT AS BidStatus, rpv.AWRD_CD AS Awarded, rpv.TOT_AMT AS VendorBidTotal
FROM            DQET036_RPT_PROPOS AS rp INNER JOIN
                         DQET040_RPT_PRO_VD AS rpv ON rp.RPT_PRPOS_SQ = rpv.RPT_PRPOS_SQ
WHERE        (rp.PRPOS_NM = @ProposalNumber) AND (rp.PRPOS_LVL_CD = @ProposalLevel)
ORDER BY VendorBidTotal</CommandText>
      </Query>
      <Fields>
        <Field Name="ProposalTotal">
          <DataField>ProposalTotal</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="ProposalNumber">
          <DataField>ProposalNumber</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Name">
          <DataField>Name</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="BidStatus">
          <DataField>BidStatus</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="Awarded">
          <DataField>Awarded</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="VendorBidTotal">
          <DataField>VendorBidTotal</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="ProjectInformation">
      <Query>
        <DataSourceName>DQE</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ProposalNumber">
            <Value>=Parameters!ProposalNumber.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ProposalLevel">
            <Value>=Parameters!ProposalLevel.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT        rpj.PROJ_NM, rpj.PROJ_DS, rpj.CNTY_TXT, rpj.DIST_TXT, rpj.FED_PROJ_TXT, rp.TOT_AMT
FROM            DQET036_RPT_PROPOS AS rp INNER JOIN
                         DQET033_RPT_PROJ AS rpj ON rp.RPT_PRPOS_SQ = rpj.RPT_PRPOS_SQ
WHERE        (rp.PRPOS_NM = @ProposalNumber) AND (rp.PRPOS_LVL_CD = @ProposalLevel)
ORDER BY rpj.PROJ_NM</CommandText>
      </Query>
      <Fields>
        <Field Name="PROJ_NM">
          <DataField>PROJ_NM</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="PROJ_DS">
          <DataField>PROJ_DS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CNTY_TXT">
          <DataField>CNTY_TXT</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DIST_TXT">
          <DataField>DIST_TXT</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="FED_PROJ_TXT">
          <DataField>FED_PROJ_TXT</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TOT_AMT">
          <DataField>TOT_AMT</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Milestone">
      <Query>
        <DataSourceName>DQE</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ProposalNumber">
            <Value>=Parameters!ProposalNumber.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ProposalLevel">
            <Value>=Parameters!ProposalLevel.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT        SUM(rpm.TOT_AMT) AS TOT_NUM
FROM            DQET036_RPT_PROPOS AS rp INNER JOIN
                         DQET038_RPT_MLSTN AS rpm ON rp.RPT_PRPOS_SQ = rpm.RPT_PRPOS_SQ
WHERE        (rp.PRPOS_NM = @ProposalNumber) AND (rp.PRPOS_LVL_CD = @ProposalLevel)</CommandText>
      </Query>
      <Fields>
        <Field Name="TOT_NUM">
          <DataField>TOT_NUM</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="Authorization">
      <Query>
        <DataSourceName>DQE</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ProposalNumber">
            <Value>=Parameters!ProposalNumber.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT        TOT_AMT
FROM            DQET036_RPT_PROPOS
WHERE        (PRPOS_NM = @ProposalNumber) AND (PRPOS_LVL_CD = 'A')</CommandText>
      </Query>
      <Fields>
        <Field Name="TOT_AMT">
          <DataField>TOT_AMT</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="BPortion">
      <Query>
        <DataSourceName>DQE</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ProposalNumber">
            <Value>=Parameters!ProposalNumber.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ProposalLevel">
            <Value>=Parameters!ProposalLevel.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT        rpv.VEND_NM, SUM(rmb.BID_PRCE_AMT * rmb.DY_BID_NUM) AS TotalBPortion
FROM            DQET036_RPT_PROPOS AS rp INNER JOIN
                         DQET040_RPT_PRO_VD AS rpv ON rp.RPT_PRPOS_SQ = rpv.RPT_PRPOS_SQ INNER JOIN
                         DQET043_RPT_MS_BID AS rmb ON rpv.RPT_PRPOS_VEND_SQ = rmb.RPT_PRPOS_VEND_SQ
WHERE        (rp.PRPOS_NM = @ProposalNumber) AND (rp.PRPOS_LVL_CD = @ProposalLevel)
GROUP BY rpv.VEND_NM</CommandText>
      </Query>
      <Fields>
        <Field Name="VEND_NM">
          <DataField>VEND_NM</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TotalBPortion">
          <DataField>TotalBPortion</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="APortion">
      <Query>
        <DataSourceName>DQE</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ProposalNumber">
            <Value>=Parameters!ProposalNumber.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ProposalLevel">
            <Value>=Parameters!ProposalLevel.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT        rpv.VEND_NM, SUM(rvb.BID_PRCE_AMT * rpi.QTY_NUM) AS TotalAPortion
FROM            DQET036_RPT_PROPOS AS rp INNER JOIN
                         DQET040_RPT_PRO_VD AS rpv ON rp.RPT_PRPOS_SQ = rpv.RPT_PRPOS_SQ INNER JOIN
                         DQET041_RPT_VD_BID AS rvb ON rpv.RPT_PRPOS_VEND_SQ = rvb.RPT_PRPOS_VEND_SQ INNER JOIN
                         DQET037_RPT_PRO_IT AS rpi ON rvb.RPT_PRPOS_ITM_SQ = rpi.RPT_PRPOS_ITM_SQ
WHERE        (rp.PRPOS_NM = @ProposalNumber) AND (rp.PRPOS_LVL_CD = @ProposalLevel)
GROUP BY rpv.VEND_NM</CommandText>
      </Query>
      <Fields>
        <Field Name="VEND_NM">
          <DataField>VEND_NM</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="TotalAPortion">
          <DataField>TotalAPortion</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="EstimateB">
      <Query>
        <DataSourceName>DQE</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ProposalNumber">
            <Value>=Parameters!ProposalNumber.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ProposalLevel">
            <Value>=Parameters!ProposalLevel.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT        SUM(rm.DY_NUM * rm.AVG_BID_PRCE_AMT) AS Total
FROM            DQET036_RPT_PROPOS AS rp INNER JOIN
                         DQET038_RPT_MLSTN AS rm ON rp.RPT_PRPOS_SQ = rm.RPT_PRPOS_SQ
WHERE        (rp.PRPOS_NM = @ProposalNumber) AND (rp.PRPOS_LVL_CD = @ProposalLevel)</CommandText>
      </Query>
      <Fields>
        <Field Name="Total">
          <DataField>Total</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
  <ReportParameters>
    <ReportParameter Name="ProposalNumber">
      <DataType>String</DataType>
      <Prompt>ProposalNumber</Prompt>
    </ReportParameter>
    <ReportParameter Name="ProposalLevel">
      <DataType>String</DataType>
      <Prompt>Proposal Level</Prompt>
    </ReportParameter>
  </ReportParameters>
  <Language>en-US</Language>
  <ConsumeContainerWhitespace>true</ConsumeContainerWhitespace>
