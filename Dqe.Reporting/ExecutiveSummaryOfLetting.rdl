  <DataSources>
    <DataSource Name="DQE">
      <DataSourceReference>DQE</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>6c35bd04-0832-4b76-9f2c-96108c8fca57</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="LettingSummary">
      <Query>
        <DataSourceName>DQE</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@LettingNumber">
            <Value>=Parameters!LettingNumber.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ProposalLevel">
            <Value>=Parameters!ProposalLevel.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT DISTINCT 
                         rtl.RPT_LET_SUM_SQ AS Id, rtl.CNTRT_RNG_TXT AS ContractRange, rtl.CNTCT_NUM AS NumberOfContracts, rtl.CAT_VAL_AMT AS ValueInCategory, rtl.ESTM_VAL_AMT AS ValueOfEstimate, 
                         rtl.CNTRT_RNG_PCT AS PercentageOfContracts, rtl.LET_TOT_PCT AS PercentageOfLettingTotal, rtl.CNTRT_UNDR_NUM AS NumberOfContractsBelowEstimate, 
                         rtl.PCT_UNDR_DFFR_TXT AS PercentageRangeDifferenceBelow, rtl.AVG_UNDR_DFFR_PCT AS AveragePercentageBelowEstimate, rtl.CNTRT_OV_NUM AS NumberOfContractsAboveEstimate, 
                         rtl.PCT_OV_DFFR_TXT AS PercentageRangeDifferenceAbove, rtl.AVG_OV_DFFR_PCT AS AveragePercentageAboveEstimate, rtl.AVG_CNTRT_BID_PCT AS AverageBidsPerContract
FROM            DQET031_RPT_LET AS rl INNER JOIN
                         DQET032_RPT_LET_SM AS rtl ON rl.RPT_LET_SQ = rtl.RPT_LET_SQ INNER JOIN
                         DQET036_RPT_PROPOS AS rp ON rl.RPT_LET_SQ = rp.RPT_LET_SQ
WHERE        (rl.LET_NM = @LettingNumber) AND (rp.PRPOS_LVL_CD = @ProposalLevel)
ORDER BY Id</CommandText>
      </Query>
      <Fields>
        <Field Name="Id">
          <DataField>Id</DataField>
          <rd:TypeName>System.Int64</rd:TypeName>
        </Field>
        <Field Name="ContractRange">
          <DataField>ContractRange</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="NumberOfContracts">
          <DataField>NumberOfContracts</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="ValueInCategory">
          <DataField>ValueInCategory</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="ValueOfEstimate">
          <DataField>ValueOfEstimate</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="PercentageOfContracts">
          <DataField>PercentageOfContracts</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="PercentageOfLettingTotal">
          <DataField>PercentageOfLettingTotal</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="NumberOfContractsBelowEstimate">
          <DataField>NumberOfContractsBelowEstimate</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="PercentageRangeDifferenceBelow">
          <DataField>PercentageRangeDifferenceBelow</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="AveragePercentageBelowEstimate">
          <DataField>AveragePercentageBelowEstimate</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="NumberOfContractsAboveEstimate">
          <DataField>NumberOfContractsAboveEstimate</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="PercentageRangeDifferenceAbove">
          <DataField>PercentageRangeDifferenceAbove</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="AveragePercentageAboveEstimate">
          <DataField>AveragePercentageAboveEstimate</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="AverageBidsPerContract">
          <DataField>AverageBidsPerContract</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="VendorBid">
      <Query>
        <DataSourceName>DQE</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@LettingNumber">
            <Value>=Parameters!LettingNumber.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ProposalLevel">
            <Value>=Parameters!ProposalLevel.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT        rp.TOT_AMT AS ProposalTotal, rp.PRPOS_NM AS ProposalNumber, rp.MNG_DIST_CD
FROM            DQET031_RPT_LET AS rl INNER JOIN
                         DQET036_RPT_PROPOS AS rp ON rl.RPT_LET_SQ = rp.RPT_LET_SQ
WHERE        (rl.LET_NM = @LettingNumber) AND (rp.PRPOS_LVL_CD = @ProposalLevel)
ORDER BY rp.MNG_DIST_CD</CommandText>
      </Query>
      <Fields>
        <Field Name="ProposalTotal">
          <DataField>ProposalTotal</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
        <Field Name="ProposalNumber">
          <DataField>ProposalNumber</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="MNG_DIST_CD">
          <DataField>MNG_DIST_CD</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="SumAPortionLowBids">
      <Query>
        <DataSourceName>DQE</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ProposalLevel">
            <Value>=Parameters!ProposalLevel.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@LettingNumber">
            <Value>=Parameters!LettingNumber.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT        SUM(rvb.BID_PRCE_AMT * rpi.QTY_NUM) AS TotalAPortion
FROM            DQET031_RPT_LET AS let INNER JOIN
                         DQET036_RPT_PROPOS AS rp ON let.RPT_LET_SQ = rp.RPT_LET_SQ INNER JOIN
                         DQET040_RPT_PRO_VD AS rpv ON rp.RPT_PRPOS_SQ = rpv.RPT_PRPOS_SQ INNER JOIN
                         DQET041_RPT_VD_BID AS rvb ON rpv.RPT_PRPOS_VEND_SQ = rvb.RPT_PRPOS_VEND_SQ INNER JOIN
                         DQET037_RPT_PRO_IT AS rpi ON rvb.RPT_PRPOS_ITM_SQ = rpi.RPT_PRPOS_ITM_SQ
WHERE        (rp.PRPOS_LVL_CD = @ProposalLevel) AND (rvb.LOW_CST_CD = 'Y') AND (let.LET_NM = @LettingNumber)</CommandText>
      </Query>
      <Fields>
        <Field Name="TotalAPortion">
          <DataField>TotalAPortion</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="PropopsalTotal">
      <Query>
        <DataSourceName>DQE</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ProposalLevel">
            <Value>=Parameters!ProposalLevel.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@LettingNumber">
            <Value>=Parameters!LettingNumber.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT        SUM(rp.TOT_AMT) AS TOT_AMT
FROM            DQET031_RPT_LET AS let INNER JOIN
                         DQET036_RPT_PROPOS AS rp ON let.RPT_LET_SQ = rp.RPT_LET_SQ
WHERE        (rp.PRPOS_LVL_CD = @ProposalLevel) AND (let.LET_NM = @LettingNumber)</CommandText>
      </Query>
      <Fields>
        <Field Name="TOT_AMT">
          <DataField>TOT_AMT</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="SumBPortionLowBids">
      <Query>
        <DataSourceName>DQE</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ProposalLevel">
            <Value>=Parameters!ProposalLevel.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@LettingNumber">
            <Value>=Parameters!LettingNumber.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT        SUM(rmb.BID_PRCE_AMT * rmb.DY_BID_NUM) AS TotalBPortion
FROM            DQET031_RPT_LET AS let INNER JOIN
                         DQET036_RPT_PROPOS AS rp ON let.RPT_LET_SQ = rp.RPT_LET_SQ INNER JOIN
                         DQET040_RPT_PRO_VD AS rpv ON rp.RPT_PRPOS_SQ = rpv.RPT_PRPOS_SQ INNER JOIN
                         DQET043_RPT_MS_BID AS rmb ON rpv.RPT_PRPOS_VEND_SQ = rmb.RPT_PRPOS_VEND_SQ INNER JOIN
                         DQET038_RPT_MLSTN AS rm ON rmb.RPT_MLSTN_SQ = rm.RPT_MLSTN_SQ
WHERE        (rp.PRPOS_LVL_CD = @ProposalLevel) AND (rmb.LOW_CST_CD = 'Y') AND (let.LET_NM = @LettingNumber)</CommandText>
      </Query>
      <Fields>
        <Field Name="TotalBPortion">
          <DataField>TotalBPortion</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="LettingTotal">
      <Query>
        <DataSourceName>DQE</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@LettingNumber">
            <Value>=Parameters!LettingNumber.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ProposalLevel">
            <Value>=Parameters!ProposalLevel.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT        let.TOT_AMT
FROM            DQET031_RPT_LET AS let INNER JOIN
                         DQET036_RPT_PROPOS AS rp ON let.RPT_LET_SQ = rp.RPT_LET_SQ
WHERE        (let.LET_NM = @LettingNumber) AND (rp.PRPOS_LVL_CD = @ProposalLevel)</CommandText>
      </Query>
      <Fields>
        <Field Name="TOT_AMT">
          <DataField>TOT_AMT</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="LettingBTotal">
      <Query>
        <DataSourceName>DQE</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@LettingNumber">
            <Value>=Parameters!LettingNumber.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@ProposalLevel">
            <Value>=Parameters!ProposalLevel.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT        SUM(rm.TOT_AMT) AS Expr1
FROM            DQET031_RPT_LET AS let INNER JOIN
                         DQET036_RPT_PROPOS AS rp ON let.RPT_LET_SQ = rp.RPT_LET_SQ INNER JOIN
                         DQET038_RPT_MLSTN AS rm ON rp.RPT_PRPOS_SQ = rm.RPT_PRPOS_SQ
WHERE        (let.LET_NM = @LettingNumber) AND (rp.PRPOS_LVL_CD = @ProposalLevel)</CommandText>
      </Query>
      <Fields>
        <Field Name="Expr1">
          <DataField>Expr1</DataField>
          <rd:TypeName>System.Decimal</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
  <ReportParameters>
    <ReportParameter Name="LettingNumber">
      <DataType>String</DataType>
      <Prompt>Letting Number</Prompt>
    </ReportParameter>
    <ReportParameter Name="ProposalLevel">
      <DataType>String</DataType>
      <Prompt>Proposal Level</Prompt>
    </ReportParameter>
  </ReportParameters>
