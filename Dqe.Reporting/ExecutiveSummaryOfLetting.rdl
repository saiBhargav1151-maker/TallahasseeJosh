      <Textbox Name="Textbox40">
        <CanGrow>true</CanGrow>
        <KeepTogether>true</KeepTogether>
        <Paragraphs>
          <Paragraph>
            <TextRuns>
              <TextRun>
                <Value>=(((Sum(Fields!TotalAPortion.Value, "SumAPortionLowBids") + Sum(Fields!TotalBPortion.Value, "SumBPortionLowBids")) / (Sum(Fields!TOT_AMT.Value, "LettingTotal") + Sum(Fields!Expr1.Value, "LettingBTotal"))) * 100) - 100</Value>
