        </Style>
      </Textbox>
      <Textbox Name="Textbox30">
        <CanGrow>true</CanGrow>
        <KeepTogether>true</KeepTogether>
        <Paragraphs>
          <Paragraph>
            <TextRuns>
              <TextRun>
                <Value>NOTICE – CONFIDENTIAL INFORMATION – NOT TO BE DISCLOSED</Value>
                <Style>
                  <FontStyle>Normal</FontStyle>
                  <FontSize>8pt</FontSize>
                  <FontWeight>Normal</FontWeight>
                  <TextDecoration>None</TextDecoration>
                  <Color>#000000</Color>
                </Style>
              </TextRun>
            </TextRuns>
            <Style />
          </Paragraph>
          <Paragraph>
            <TextRuns>
              <TextRun>
                <Value />
                <Style>
                  <FontStyle>Normal</FontStyle>
                  <FontSize>8pt</FontSize>
                  <FontWeight>Normal</FontWeight>
                  <TextDecoration>None</TextDecoration>
                  <Color>#000000</Color>
                </Style>
              </TextRun>
            </TextRuns>
            <Style>
              <TextAlign>Left</TextAlign>
              <LineHeight>13pt</LineHeight>
            </Style>
          </Paragraph>
          <Paragraph>
            <TextRuns>
              <TextRun>
                <Value>ANY INFORMATION related to the Departments official estimate is CONFIDENTIAL until the project is executed, per Florida Statute 337.168, which reads as follows:</Value>
                <Style>
                  <FontStyle>Normal</FontStyle>
                  <FontSize>8pt</FontSize>
                  <FontWeight>Normal</FontWeight>
                  <TextDecoration>None</TextDecoration>
                  <Color>#000000</Color>
                </Style>
              </TextRun>
            </TextRuns>
            <Style>
              <TextAlign>Left</TextAlign>
              <LineHeight>13pt</LineHeight>
            </Style>
          </Paragraph>
          <Paragraph>
            <TextRuns>
              <TextRun>
                <Value />
                <Style>
                  <FontStyle>Normal</FontStyle>
                  <FontSize>8pt</FontSize>
                  <FontWeight>Normal</FontWeight>
                  <TextDecoration>None</TextDecoration>
                  <Color>#000000</Color>
                </Style>
              </TextRun>
            </TextRuns>
            <Style>
              <TextAlign>Left</TextAlign>
              <LineHeight>13pt</LineHeight>
            </Style>
          </Paragraph>
          <Paragraph>
            <TextRuns>
              <TextRun>
                <Value>337.168 Confidentiality of official estimates, identities of potential bidders, and bid analysis and monitoring system.</Value>
                <Style>
                  <FontStyle>Normal</FontStyle>
                  <FontSize>8pt</FontSize>
                  <FontWeight>Normal</FontWeight>
                  <TextDecoration>None</TextDecoration>
                  <Color>#000000</Color>
                </Style>
              </TextRun>
            </TextRuns>
            <Style>
              <TextAlign>Left</TextAlign>
              <LineHeight>13pt</LineHeight>
            </Style>
          </Paragraph>
          <Paragraph>
            <TextRuns>
              <TextRun>
                <Value>(1) A document or electronic file revealing the official cost estimate of the department of a project is confidential and exempt from the provisions of s.</Value>
                <Style>
                  <FontStyle>Normal</FontStyle>
                  <FontSize>8pt</FontSize>
                  <FontWeight>Normal</FontWeight>
                  <TextDecoration>None</TextDecoration>
                  <Color>#000000</Color>
                </Style>
              </TextRun>
              <TextRun>
                <Value>119.07</Value>
                <ActionInfo>
                  <Actions>
                    <Action>
                      <Hyperlink>http://www.leg.state.fl.us/Statutes/index.cfm?App_mode=Display_Statute&amp;Search_String=&amp;URL=0100-0199/0119/Sections/0119.07.html</Hyperlink>
                    </Action>
                  </Actions>
                </ActionInfo>
                <Style>
                  <FontStyle>Normal</FontStyle>
                  <FontSize>8pt</FontSize>
                  <FontWeight>Normal</FontWeight>
                  <TextDecoration>None</TextDecoration>
                  <Color>#000000</Color>
                </Style>
              </TextRun>
              <TextRun>
                <Value>(1) until the contract for the project has been executed or until the project is no longer under active consideration.</Value>
                <Style>
                  <FontStyle>Normal</FontStyle>
                  <FontSize>8pt</FontSize>
                  <FontWeight>Normal</FontWeight>
                  <TextDecoration>None</TextDecoration>
                  <Color>#000000</Color>
                </Style>
              </TextRun>
            </TextRuns>
            <LeftIndent>0.5in</LeftIndent>
            <HangingIndent>-0.25in</HangingIndent>
            <Style>
              <TextAlign>Left</TextAlign>
            </Style>
          </Paragraph>
          <Paragraph>
            <TextRuns>
              <TextRun>
                <Value />
                <Style>
                  <FontStyle>Normal</FontStyle>
                  <FontSize>8pt</FontSize>
                  <FontWeight>Normal</FontWeight>
                  <TextDecoration>None</TextDecoration>
                  <Color>#000000</Color>
                </Style>
              </TextRun>
            </TextRuns>
            <LeftIndent>0.5in</LeftIndent>
            <HangingIndent>-0.25in</HangingIndent>
            <Style>
              <TextAlign>Left</TextAlign>
            </Style>
          </Paragraph>
          <Paragraph>
            <TextRuns>
              <TextRun>
                <Value>(2) A document that reveals the identity of a person who has requested or obtained a bid package, plan, or specifications pertaining to any project to be let by the department is confidential and exempt from the provisions of s.</Value>
                <Style>
                  <FontStyle>Normal</FontStyle>
                  <FontSize>8pt</FontSize>
                  <FontWeight>Normal</FontWeight>
                  <TextDecoration>None</TextDecoration>
                  <Color>#000000</Color>
                </Style>
              </TextRun>
              <TextRun>
                <Value>119.07</Value>
                <ActionInfo>
                  <Actions>
                    <Action>
                      <Hyperlink>http://www.leg.state.fl.us/Statutes/index.cfm?App_mode=Display_Statute&amp;Search_String=&amp;URL=0100-0199/0119/Sections/0119.07.html</Hyperlink>
                    </Action>
                  </Actions>
                </ActionInfo>
                <Style>
                  <FontStyle>Normal</FontStyle>
                  <FontSize>8pt</FontSize>
                  <FontWeight>Normal</FontWeight>
                  <TextDecoration>None</TextDecoration>
                  <Color>#000000</Color>
                </Style>
              </TextRun>
              <TextRun>
                <Value>(1) for the period that begins 2 working days before the deadline for obtaining bid packages, plans, or specifications and ends with the letting of the bid. A document that reveals the identity of a person who has requested or obtained a bid package, plan, or specifications pertaining to any project to be let by the department before the 2 working days before the deadline for obtaining bid packages, plans, or specifications remains a public record subject to s.</Value>
                <Style>
                  <FontStyle>Normal</FontStyle>
                  <FontSize>8pt</FontSize>
                  <FontWeight>Normal</FontWeight>
                  <TextDecoration>None</TextDecoration>
                  <Color>#000000</Color>
                </Style>
              </TextRun>
              <TextRun>
                <Value>119.07</Value>
                <ActionInfo>
                  <Actions>
                    <Action>
                      <Hyperlink>http://www.leg.state.fl.us/Statutes/index.cfm?App_mode=Display_Statute&amp;Search_String=&amp;URL=0100-0199/0119/Sections/0119.07.html</Hyperlink>
                    </Action>
                  </Actions>
                </ActionInfo>
                <Style>
                  <FontStyle>Normal</FontStyle>
                  <FontSize>8pt</FontSize>
                  <FontWeight>Normal</FontWeight>
                  <TextDecoration>None</TextDecoration>
                  <Color>#000000</Color>
                </Style>
              </TextRun>
              <TextRun>
                <Value>(1).</Value>
                <Style>
                  <FontStyle>Normal</FontStyle>
                  <FontSize>8pt</FontSize>
                  <FontWeight>Normal</FontWeight>
                  <TextDecoration>None</TextDecoration>
                  <Color>#000000</Color>
                </Style>
              </TextRun>
            </TextRuns>
            <LeftIndent>0.5in</LeftIndent>
            <HangingIndent>-0.25in</HangingIndent>
            <Style>
              <TextAlign>Left</TextAlign>
            </Style>
          </Paragraph>
          <Paragraph>
            <TextRuns>
              <TextRun>
                <Value />
                <Style>
                  <FontStyle>Normal</FontStyle>
                  <FontSize>8pt</FontSize>
                  <FontWeight>Normal</FontWeight>
                  <TextDecoration>None</TextDecoration>
                  <Color>#000000</Color>
                </Style>
              </TextRun>
            </TextRuns>
            <LeftIndent>0.5in</LeftIndent>
            <HangingIndent>-0.25in</HangingIndent>
            <Style>
              <TextAlign>Left</TextAlign>
            </Style>
          </Paragraph>
          <Paragraph>
            <TextRuns>
              <TextRun>
                <Value>(3) The bid analysis and monitoring system of the department is confidential and exempt from the provisions of s. </Value>
                <Style>
                  <FontStyle>Normal</FontStyle>
                  <FontSize>8pt</FontSize>
                  <FontWeight>Normal</FontWeight>
                  <TextDecoration>None</TextDecoration>
                  <Color>#000000</Color>
                </Style>
              </TextRun>
              <TextRun>
                <Value>119.07</Value>
                <ActionInfo>
                  <Actions>
                    <Action>
                      <Hyperlink>http://www.leg.state.fl.us/Statutes/index.cfm?App_mode=Display_Statute&amp;Search_String=&amp;URL=0100-0199/0119/Sections/0119.07.html</Hyperlink>
                    </Action>
                  </Actions>
                </ActionInfo>
                <Style>
                  <FontStyle>Normal</FontStyle>
                  <FontSize>8pt</FontSize>
                  <FontWeight>Normal</FontWeight>
                  <TextDecoration>None</TextDecoration>
                  <Color>#000000</Color>
                </Style>
              </TextRun>
              <TextRun>
                <Value>(1). This exemption applies to all system documentation, input, computer processes and programs, electronic data files, and output, but does not apply to the actual source documents, unless otherwise exempted under other provisions of law.</Value>
                <Style>
                  <FontStyle>Normal</FontStyle>
                  <FontSize>8pt</FontSize>
                  <FontWeight>Normal</FontWeight>
                  <TextDecoration>None</TextDecoration>
                  <Color>#000000</Color>
                </Style>
              </TextRun>
            </TextRuns>
            <LeftIndent>0.5in</LeftIndent>
            <HangingIndent>-0.25in</HangingIndent>
            <Style>
              <TextAlign>Left</TextAlign>
            </Style>
          </Paragraph>
        </Paragraphs>
        <rd:DefaultName>Textbox28</rd:DefaultName>
        <Top>0.5in</Top>
        <Left>0.42188in</Left>
