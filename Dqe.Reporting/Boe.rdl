  <DataSources>
    <DataSource Name="DQE">
      <DataSourceReference>DQE</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>dbc3d33f-0fc5-4aed-99ac-2e06c08e4aee</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DQE</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@StructureName1">
            <Value>=Parameters!StructureName1.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@StructureName2">
            <Value>=Parameters!StructureName2.Value</Value>
          </QueryParameter>
          <QueryParameter Name="@StructureName3">
            <Value>=Parameters!StructureName3.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT DISTINCT 
                         PAY_ITM_STRCT_SQ, STRCT_NM, TTL_TXT, PLN_QTY_CD, NOTE_TXT, DET_TXT, PLN_SUM_TXT, DSGN_FORM_TXT, CNST_FORM_TXT, CHPTR_TXT, TRNSP_TXT, OTH_TXT, STND_TXT, SPEC_TXT, STRCT_DS, 
                         MNTR_CD, STAF_MBR_CNCT_SQ, PEND_INFO_TXT, HST_TXT, RCNT_CHNG_DT, RCNT_CHNG_TXT
FROM            DQET002_ITM_STRCT AS s
WHERE        (STRCT_NM NOT LIKE '  %') AND (@StructureName1 = 'X') AND (STRCT_NM NOT LIKE ' 1%') AND (STRCT_NM NOT LIKE ' 2%') AND (STRCT_NM NOT LIKE ' 3%') AND (STRCT_NM NOT LIKE ' 4%') AND 
                         (STRCT_NM NOT LIKE ' 5%') AND (STRCT_NM NOT LIKE ' 6%') AND (STRCT_NM NOT LIKE ' 7%') AND (STRCT_NM NOT LIKE ' 8%') AND (STRCT_NM NOT LIKE ' 9%') AND (STRCT_NM NOT LIKE '1%') AND 
                         (OBSLT_CD = 'N') OR
                         (STRCT_NM LIKE ' ' + @StructureName1 + '%') OR
                         (STRCT_NM LIKE ' ' + @StructureName2 + '%') OR
                         (STRCT_NM LIKE ' ' + @StructureName3 + '%')
ORDER BY STRCT_NM</CommandText>
      </Query>
