  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="DQE">
      <DataSourceReference>DQE</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>931fe785-d291-457d-897c-a736d7bca8bc</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DQE</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@MarketArea">
            <Value>=Parameters!MarketArea.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT        ph.ProposalNumber, ph.LettingDate, ph.County, ph.ContractType, ph.Quantity, bh.Price, pim.RefItemName, pim.Description, pim.SpecBook, pim.Unit
FROM            ProposalHistory AS ph INNER JOIN
                         PayItemMaster AS pim ON pim.Id = ph.PayItemMasterId INNER JOIN
                         BidHistory AS bh ON bh.ProposalHistoryId = ph.Id INNER JOIN
                         County AS c ON c.Name = ph.County INNER JOIN
                         MarketArea AS ma ON ma.Id = c.MarketAreaId
WHERE        (bh.IsAwarded = 1) AND (ma.Name IN (@MarketArea))</CommandText>
      </Query>
      <Fields>
        <Field Name="ProposalNumber">
          <DataField>ProposalNumber</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="LettingDate">
          <DataField>LettingDate</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
        <Field Name="County">
          <DataField>County</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="ContractType">
          <DataField>ContractType</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="RefItemName">
