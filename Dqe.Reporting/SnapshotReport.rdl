    <DataSet Name="HeaderInfo">
      <Query>
        <DataSourceName>DQE</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ProjectEstimateId">
            <Value>=Parameters!ProjectEstimateId.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT        p.PROJ_NM, p.PROJ_DS, p.DIST_TXT, c.CNTY_NM, pv.VER_NUM, pe.ESTM_NUM, pe.LAST_UPDT_TMS
FROM            DQET020_PROJ AS p INNER JOIN
                         DQET017_CNTY AS c ON p.CNTY_SQ = c.CNTY_SQ INNER JOIN
                         DQET029_PROJ_VER AS pv ON p.PROJ_SQ = pv.PROJ_SQ INNER JOIN
                         DQET028_PROJ_ESTM AS pe ON pv.PROJ_VER_SQ = pe.PROJ_VER_SQ
WHERE        (pe.PROJ_ESTM_SQ = @ProjectEstimateId)</CommandText>
      </Query>
      <Fields>
        <Field Name="PROJ_NM">
          <DataField>PROJ_NM</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="PROJ_DS">
          <DataField>PROJ_DS</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="DIST_TXT">
          <DataField>DIST_TXT</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CNTY_NM">
          <DataField>CNTY_NM</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="VER_NUM">
          <DataField>VER_NUM</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="ESTM_NUM">
          <DataField>ESTM_NUM</DataField>
          <rd:TypeName>System.Int32</rd:TypeName>
        </Field>
        <Field Name="LAST_UPDT_TMS">
          <DataField>LAST_UPDT_TMS</DataField>
          <rd:TypeName>System.DateTime</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
