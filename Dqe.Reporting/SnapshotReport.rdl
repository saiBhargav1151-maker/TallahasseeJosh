  <DataSources>
    <DataSource Name="DQE">
      <DataSourceReference>DQE</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>96a675aa-037e-405a-be8f-25dc5032d957</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="ProjectItems">
      <Query>
        <DataSourceName>DQE</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="@ProjectEstimateId">
            <Value>=Parameters!ProjectEstimateId.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT        eg.CAT_NM, eg.CAT_DS AS EstimateGroupDescription, eg.ALT_SET_TXT AS CategoryAlternateSet, eg.ALT_MBR_TXT AS CategoryAlternateMember, pi.PROJ_ITM_SQ, pi.CAT_SQ, pi.PRPOS_ITM_SQ, 
                         pi.TRNSP_SYS_NUM, pi.QTY_NUM, pi.PRCE_AMT AS PRCE_NUM, pi.PREV_PRCE_AMT AS PREV_PRCE_NUM, pi.PUB_PRCE_AMT AS PUB_PRCE_NUM, pi.PRCE_TYP_CD AS PRCE_TYP_NUM, pi.ITM_NM, pi.ITM_DS, pi.UNIT_DS, pi.UNIT_TXT, pi.CMB_CD, pi.ALT_SET_TXT, 
                         pi.ALT_MBR_TXT, pi.SPLMNT_DS, pi.FND_TXT, pay.OBSLT_DT
FROM            DQET028_PROJ_ESTM AS pe INNER JOIN
                         DQET027_CAT AS eg ON pe.PROJ_ESTM_SQ = eg.PROJ_ESTM_SQ INNER JOIN
                         DQET026_PROJ_ITM AS pi ON eg.CAT_SQ = pi.CAT_SQ INNER JOIN
                         DQET029_PROJ_VER AS pv ON pe.PROJ_VER_SQ = pv.PROJ_VER_SQ INNER JOIN
                         DQET020_PROJ AS pj ON pv.PROJ_SQ = pj.PROJ_SQ INNER JOIN
                         DQET008_PAY_ITM AS pay ON pi.ITM_NM = pay.PAY_ITM_NM AND pj.MSTR_FILE_SQ = pay.MSTR_FILE_SQ
WHERE        (pe.PROJ_ESTM_SQ = @ProjectEstimateId)
ORDER BY eg.CAT_NM, pi.ITM_NM, pi.SPLMNT_DS</CommandText>
      </Query>
      <Fields>
        <Field Name="CAT_NM">
          <DataField>CAT_NM</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="EstimateGroupDescription">
          <DataField>EstimateGroupDescription</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CategoryAlternateSet">
          <DataField>CategoryAlternateSet</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="CategoryAlternateMember">
          <DataField>CategoryAlternateMember</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
        <Field Name="PROJ_ITM_SQ">
