  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="DQE">
      <DataSourceReference>DQE</DataSourceReference>
      <rd:SecurityType>None</rd:SecurityType>
      <rd:DataSourceID>80a8ed65-1eca-4b8f-b75b-620211fd3238</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>DQE</DataSourceName>
        <CommandText>SELECT DISTINCT eg.Name
FROM            Proposal AS ps INNER JOIN
                         Project AS pj ON ps.Id = pj.Id INNER JOIN
                         ProjectVersion AS pv ON pj.Id = pv.ProjectId INNER JOIN
                         ProjectEstimate AS pe ON pv.Id = pe.ProjectVersionId INNER JOIN
                         EstimateGroup AS eg ON pe.Id = eg.ProjectEstimateId INNER JOIN
                         ProjectItem AS pji ON eg.Id = pji.EstimateGroupId
WHERE        (pe.Estimate = 5) AND (ps.ProposalNumber = 'T7209')
ORDER BY eg.Name</CommandText>
      </Query>
      <Fields>
        <Field Name="Name">
          <DataField>Name</DataField>
          <rd:TypeName>System.String</rd:TypeName>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
  <ReportParameters>
    <ReportParameter Name="Proposal">
      <DataType>String</DataType>
      <Prompt>Proposal</Prompt>
    </ReportParameter>
    <ReportParameter Name="EstimateType">
      <DataType>String</DataType>
      <Prompt>Estimate Type</Prompt>
    </ReportParameter>
  </ReportParameters>
  <Language>en-US</Language>
  <ConsumeContainerWhitespace>true</ConsumeContainerWhitespace>
  <rd:ReportUnitType>Inch</rd:ReportUnitType>
  <rd:ReportID>cff4e5d7-5eb3-436e-a2d2-b3d5bbf2b666</rd:ReportID>
